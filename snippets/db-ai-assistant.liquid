<!-- snippets/db-ai-assistant.liquid -->
{% assign current_locale = request.locale.iso_code %}
{% assign is_arabic = false %}
{% if current_locale contains 'ar' %}{% assign is_arabic = true %}{% endif %}

<!-- AI Chat Floating Button -->
<div class="db-ai-btn" id="dbAIAssistant" role="button" aria-label="Open AI Assistant">
  <svg class="db-ai-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
    <!-- Beautiful AI sparkles SVG -->
    <path d="M12 3V6M12 18V21M21 12H18M6 12H3M18.36 5.64L16.24 7.76M7.76 16.24L5.64 18.36M18.36 18.36L16.24 16.24M7.76 7.76L5.64 9.88M12 8C9.79 8 8 9.79 8 12C8 14.21 9.79 16 12 16C14.21 16 16 14.21 16 12C16 9.79 14.21 8 12 8Z" stroke="#c9a96e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M12 10.5C11.17 10.5 10.5 11.17 10.5 12C10.5 12.83 11.17 13.5 12 13.5C12.83 13.5 13.5 12.83 13.5 12C13.5 11.17 12.83 10.5 12 10.5Z" fill="#c9a96e"/>
  </svg>
  <span class="db-ai-pulse-glow"></span>
</div>

<!-- AI Chat Modal -->
<div class="db-ai-modal" id="dbAIChatModal" style="display: none;">
  <!-- Modal Header -->
  <div class="db-ai-header">
    <div class="db-ai-header-inner">
      <div class="db-ai-header-title">
        <span class="db-ai-status-dot"></span>
        <img src="https://cdn.shopify.com/s/files/1/0749/0227/4185/files/header_logo_Donna_Bella.webp?v=1774436775" alt="Donna Bella" class="db-ai-header-logo" onerror="this.style.display='none'; this.nextElementSibling.style.display='inline-block';">
        <span class="db-ai-header-text" style="display: none;">{% if is_arabic %}دونا بيلا{% else %}Donna Bella{% endif %}</span>
      </div>
      <div class="db-ai-header-actions">
        <button type="button" class="db-ai-close-btn" id="dbAIChatClose" aria-label="Close"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width: 14px; height: 14px; display: block;"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg></button>
      </div>
    </div>
  </div>

  <!-- API Key Setup Overlay -->
  <div class="db-ai-settings-overlay" id="dbAISettingsOverlay" style="display: none;">
    <div class="db-ai-settings-content">
      <h4>Gemini API Key</h4>
      <p>{% if is_arabic %}أدخل مفتاح API لـ Gemini للتشغيل:{% else %}Enter Gemini API Key to enable assistant:{% endif %}</p>
      <input type="password" id="dbGeminiApiKeyInput" class="db-ai-input-field" placeholder="AIzaSy...">
      <div class="db-ai-settings-actions">
        <button type="button" id="dbAISaveSettings" class="db-ai-save-btn">{% if is_arabic %}حفظ{% else %}Save{% endif %}</button>
        <button type="button" id="dbAICloseSettings" class="db-ai-cancel-btn">{% if is_arabic %}إلغاء{% else %}Cancel{% endif %}</button>
      </div>
    </div>
  </div>

  <!-- Messages History -->
  <div class="db-ai-messages" id="dbAIMessagesArea">
    <!-- Welcome Message -->
    <div class="db-ai-msg assistant">
      <div class="db-ai-bubble">
        {% if is_arabic %}
          مرحباً! أنا مساعد دونا بيلا الذكي 🌸 كيف يمكنني مساعدتك في حجز خدمات التجميل الفاخرة في منزلك اليوم؟ يمكنك سؤالي عن خدماتنا، أسعارنا، عروضنا أو كيفية إتمام الحجز.
        {% else %}
          Hi! I am your Donna Bella AI Concierge 🌸 How can I help you book your luxury home beauty service today? You can ask me about our services, pricing, promotions, or how to proceed with checkout.
        {% endif %}
      </div>
    </div>

    <!-- Typing Indicator (inside messages area) -->
    <div class="db-ai-typing" id="dbAITypingIndicator" style="display: none;">
      <div class="db-ai-bubble">
        <span class="db-dot"></span>
        <span class="db-dot"></span>
        <span class="db-dot"></span>
      </div>
    </div>
  </div>

  <!-- Chat Input Footer -->
  <form class="db-ai-footer" id="dbAIChatForm">
    <input type="text" id="dbAIChatInput" class="db-ai-input-field" required placeholder="{% if is_arabic %}اكتب رسالتك هنا...{% else %}Type your message...{% endif %}" autocomplete="off">
    <button type="submit" class="db-ai-send-btn" aria-label="Send">
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" style="width: 16px; height: 16px; transform: rotate(45deg); display: block;">
        <path d="M22 2L11 13M22 2L15 22L11 13M11 13L2 9L22 2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </form>
</div>

<style>
  /* AI Button Positioning & Styles */
  .db-ai-btn {
    position: fixed !important;
    bottom: 90px !important; /* Floats directly above WhatsApp (30px + 60px) */
    left: 20px !important;
    z-index: 99 !important;
    display: flex !important;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    backdrop-filter: blur(20px) !important;
    -webkit-backdrop-filter: blur(20px) !important;
    background: rgba(255, 255, 255, 0.12) !important;
    border: 1px solid rgba(255, 200, 215, 0.3) !important;
    border-radius: 50% !important;
    cursor: pointer;
    box-shadow: 0 4px 20px rgba(255, 182, 193, 0.2), inset 0 1px 0 rgba(255, 255, 255, 0.25) !important;
    transition: transform 0.3s cubic-bezier(0.23, 1, 0.32, 1), bottom 0.3s ease;
  }

  .db-ai-icon {
    width: 24px;
    height: 24px;
    display: block;
    transition: transform 0.3s ease;
  }

  .db-ai-btn:hover {
    transform: translateY(-6px) scale(1.08) !important;
    background: rgba(255, 255, 255, 0.18) !important;
    border-color: rgba(255, 200, 215, 0.5) !important;
    box-shadow: 0 8px 25px rgba(255, 182, 193, 0.3), inset 0 1px 0 rgba(255, 255, 255, 0.35) !important;
  }

  .db-ai-pulse-glow {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    border: 1px solid rgba(255, 200, 215, 0.3);
    animation: db-ai-pulse 2s infinite ease-in-out;
    pointer-events: none;
    z-index: -1;
  }

  @keyframes db-ai-pulse {
    0% { transform: scale(1); opacity: 0.8; }
    100% { transform: scale(1.4); opacity: 0; }
  }

  /* Chat Modal Style - Glassmorphism Card matching Screenshot */
  .db-ai-modal {
    position: fixed !important;
    bottom: 150px !important;
    left: 20px !important;
    width: 360px;
    height: 480px;
    z-index: 1000 !important;
    backdrop-filter: blur(30px) !important;
    -webkit-backdrop-filter: blur(30px) !important;
    background: linear-gradient(135deg, rgba(26, 10, 30, 0.86) 0%, rgba(45, 27, 53, 0.86) 30%, rgba(30, 15, 42, 0.88) 60%, rgba(18, 8, 24, 0.92) 100%) !important;
    border: 1px solid rgba(255, 255, 255, 0.18) !important;
    border-radius: 24px !important;
    box-shadow: 0 20px 60px rgba(0,0,0,0.35), 0 0 40px rgba(255,182,193,0.12), inset 0 1px 0 rgba(255,255,255,0.22) !important;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    font-family: 'Jost', 'Cairo', sans-serif;
    animation: db-ai-slidein 0.3s forwards cubic-bezier(0.16, 1, 0.3, 1);
  }

  .db-ai-modal::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.5) 50%, transparent 100%);
    opacity: 0.6;
    z-index: 5;
    pointer-events: none;
  }

  .db-ai-modal::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 24px;
    background: radial-gradient(ellipse 80% 50% at 50% 0%, rgba(255,255,255,0.06) 0%, transparent 60%);
    pointer-events: none;
    z-index: 5;
  }

  @keyframes db-ai-slidein {
    from {
      opacity: 0;
      transform: translateY(20px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  /* Header banner */
  .db-ai-header {
    background: transparent;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding: 16px 20px;
    display: flex;
    align-items: center;
    position: relative;
    z-index: 6; /* sit above the gloss overlays */
  }

  .db-ai-header-inner {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .db-ai-header-title {
    color: #ffffff;
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    font-weight: 500;
    letter-spacing: 0.5px;
    display: flex;
    align-items: center;
    gap: 10px;
    text-shadow: 0 0 15px rgba(255,255,255,0.2);
  }

  .db-ai-header-logo {
    height: 24px;
    width: auto;
    object-fit: contain;
    display: block;
    max-width: 140px;
  }

  .db-ai-status-dot {
    width: 8px;
    height: 8px;
    background: #00e676;
    border-radius: 50%;
    display: inline-block;
    box-shadow: 0 0 8px #00e676;
  }

  .db-ai-header-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  /* Close Button Styled like the Card's Icon Box */
  .db-ai-close-btn {
    box-sizing: border-box !important;
    background: rgba(255,255,255,0.12) !important;
    border: 1px solid rgba(255,200,215,0.3) !important;
    color: #ffffff !important;
    width: 32px !important;
    height: 32px !important;
    border-radius: 50% !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    cursor: pointer !important;
    transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1) !important;
    box-shadow: 0 4px 15px rgba(255,182,193,0.15), inset 0 1px 0 rgba(255,255,255,0.2) !important;
    line-height: 0 !important;
    padding: 0 !important;
    margin: 0 !important;
  }
  .db-ai-close-btn svg {
    margin: 0 !important;
    padding: 0 !important;
    display: block !important;
    flex-shrink: 0 !important;
  }

  .db-ai-close-btn:hover {
    background: rgba(255, 255, 255, 0.22);
    border-color: rgba(255,200,215,0.6);
    box-shadow: 0 4px 20px rgba(255,182,193,0.3), inset 0 1px 0 rgba(255,255,255,0.3);
    color: #ffffff;
    transform: rotate(90deg);
  }

  /* Settings overlay for manual API key input */
  .db-ai-settings-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(26, 10, 30, 0.92) !important;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .db-ai-settings-content {
    backdrop-filter: blur(20px) !important;
    -webkit-backdrop-filter: blur(20px) !important;
    background: rgba(45, 27, 53, 0.85) !important;
    border: 1px solid rgba(255, 255, 255, 0.18) !important;
    padding: 24px;
    border-radius: 20px;
    width: 100%;
    max-width: 320px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.35), inset 0 1px 0 rgba(255,255,255,0.2);
  }

  .db-ai-settings-content h4 {
    color: #ffffff;
    font-family: 'Cormorant Garamond', serif;
    margin: 0 0 10px 0;
    font-size: 18px;
    font-weight: 500;
    letter-spacing: 0.5px;
  }

  .db-ai-settings-content p {
    color: rgba(255,255,255,0.7);
    font-size: 12px;
    margin: 0 0 16px 0;
    line-height: 1.5;
  }

  .db-ai-settings-actions {
    display: flex;
    justify-content: flex-end;
    gap: 8px;
    margin-top: 16px;
  }

  .db-ai-save-btn {
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 200, 215, 0.4);
    color: #ffffff;
    padding: 8px 18px;
    border-radius: 10px;
    cursor: pointer;
    font-weight: 600;
    font-size: 12px;
    transition: all 0.3s ease;
  }

  .db-ai-save-btn:hover {
    background: rgba(255, 255, 255, 0.25);
    border-color: rgba(255, 200, 215, 0.7);
  }

  .db-ai-cancel-btn {
    background: none;
    color: rgba(255,255,255,0.6);
    border: 1px solid rgba(255,255,255,0.15);
    padding: 8px 18px;
    border-radius: 10px;
    cursor: pointer;
    font-size: 12px;
    transition: all 0.3s ease;
  }

  .db-ai-cancel-btn:hover {
    background: rgba(255,255,255,0.05);
    color: #ffffff;
  }

  /* Message area scrollable body */
  .db-ai-messages {
    flex: 1;
    overflow-y: auto;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    scroll-behavior: smooth;
  }

  /* Custom scrollbar for messages area */
  .db-ai-messages::-webkit-scrollbar {
    width: 6px;
  }
  .db-ai-messages::-webkit-scrollbar-track {
    background: transparent;
  }
  .db-ai-messages::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.12);
    border-radius: 3px;
  }
  .db-ai-messages::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.25);
  }

  .db-ai-msg {
    display: flex;
    width: 100%;
    margin-bottom: 2px;
  }

  .db-ai-msg.assistant {
    justify-content: flex-start;
  }

  .db-ai-msg.user {
    justify-content: flex-end;
  }

  .db-ai-bubble {
    max-width: 85%;
    padding: 12px 18px;
    font-size: 13px;
    line-height: 1.6;
    word-wrap: break-word;
    font-family: inherit;
  }

  /* Assistant bubble - styled with soft glow matching design system */
  .db-ai-msg.assistant .db-ai-bubble {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-left: 3px solid rgba(255, 200, 215, 0.6);
    color: rgba(255, 255, 255, 0.95);
    border-radius: 18px;
    border-top-left-radius: 4px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.15);
  }

  /* User bubble - styled with translucent gold to fit the aesthetic */
  .db-ai-msg.user .db-ai-bubble {
    background: rgba(201, 169, 110, 0.18);
    border: 1px solid rgba(201, 169, 110, 0.35);
    color: #ffffff;
    font-weight: 400;
    border-radius: 18px;
    border-top-right-radius: 4px;
    box-shadow: 0 4px 15px rgba(201, 169, 110, 0.1);
  }

  /* Typing indicator container */
  .db-ai-typing {
    display: none;
    justify-content: flex-start;
    width: 100%;
    margin-bottom: 12px;
    padding: 0;
  }

  .db-ai-typing .db-ai-bubble {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-left: 3px solid rgba(255, 200, 215, 0.6);
    border-radius: 18px;
    border-top-left-radius: 4px;
    padding: 12px 18px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.15);
    width: auto;
  }

  .db-dot {
    width: 6px;
    height: 6px;
    background: rgba(255, 255, 255, 0.6);
    border-radius: 50%;
    animation: db-bounce 1.4s infinite ease-in-out both;
  }

  .db-dot:nth-child(1) { animation-delay: -0.32s; }
  .db-dot:nth-child(2) { animation-delay: -0.16s; }

  @keyframes db-bounce {
    0%, 80%, 100% { transform: scale(0); }
    40% { transform: scale(1.0); }
  }

  /* Chat Input footer */
  .db-ai-footer {
    padding: 16px 20px !important;
    background: transparent !important;
    border-top: 1px solid rgba(255, 255, 255, 0.08) !important;
    display: flex !important;
    gap: 12px !important;
    align-items: center !important;
    justify-content: center !important;
    position: relative !important;
    z-index: 6 !important;
    box-sizing: border-box !important;
  }

  .db-ai-input-field {
    flex: 1 !important;
    height: 42px !important;
    background: rgba(255, 255, 255, 0.06) !important;
    border: 1px solid rgba(255, 255, 255, 0.12) !important;
    border-radius: 14px !important;
    padding: 0 16px !important;
    color: #ffffff !important;
    font-size: 13px !important;
    outline: none !important;
    transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1) !important;
    box-shadow: inset 0 1px 2px rgba(0,0,0,0.15) !important;
    box-sizing: border-box !important;
    margin: 0 !important;
    align-self: center !important;
  }
  .db-ai-input-field::placeholder {
    color: rgba(255, 255, 255, 0.4) !important;
    opacity: 1 !important;
  }

  .db-ai-input-field:focus {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 200, 215, 0.4);
    box-shadow: 0 0 10px rgba(255, 182, 193, 0.15), inset 0 1px 2px rgba(0,0,0,0.15);
  }

  /* Send Button Styled like standard icon box but smaller */
  .db-ai-send-btn {
    background: rgba(255, 255, 255, 0.12) !important;
    border: 1px solid rgba(255, 200, 215, 0.3) !important;
    border-radius: 12px !important;
    width: 42px !important;
    height: 42px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    cursor: pointer !important;
    transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1) !important;
    box-shadow: 0 4px 15px rgba(255,182,193,0.1), inset 0 1px 0 rgba(255,255,255,0.2) !important;
    color: #ffffff !important;
    box-sizing: border-box !important;
    flex-shrink: 0 !important;
    margin: 0 !important;
    padding: 0 !important;
    align-self: center !important;
  }

  .db-ai-send-btn:hover {
    background: rgba(255, 255, 255, 0.22);
    border-color: rgba(255,200,215,0.5);
    box-shadow: 0 4px 20px rgba(255,182,193,0.2), inset 0 1px 0 rgba(255,255,255,0.3);
    color: #ffffff;
  }

  /* Mobile Responsive adjustments */
  @media (max-width: 600px) {
    .db-ai-btn {
      bottom: 65px !important; /* Floats above mobile WhatsApp (10px + 55px) */
      left: 12px !important;
      width: 44px;
      height: 44px;
    }

    .db-ai-btn.db-has-sticky-cart {
      bottom: 150px !important; /* Shifted higher on sticky cart pages (95px + 55px) */
    }

    .db-ai-modal {
      bottom: 20px !important;
      left: 10px !important;
      right: 10px !important;
      width: calc(100% - 20px);
      height: 70vh;
      max-height: 480px;
      border-radius: 24px !important;
    }

    .db-ai-icon {
      width: 22px;
      height: 22px;
    }
  }

  /* Desktop Full Screen slide-out console */
  @media (min-width: 1024px) {
    .db-ai-modal {
      bottom: 40px !important; /* Ends almost at the bottom of the first section */
      left: 110px !important; /* Pushed from the left to clear the social sidebar */
      right: 40px !important; /* Provides some space on the right */
      top: 100px !important; /* Starts from under the header */
      width: calc(100% - 150px) !important; /* 100% - left (110px) - right (40px) */
      height: calc(100vh - 140px) !important; /* covers height for any desktop screen */
      max-height: none !important;
      border-radius: 24px !important; /* rounded card since it does not touch edges */
      animation: db-ai-slidein-desktop 0.4s forwards cubic-bezier(0.16, 1, 0.3, 1) !important;
    }

    .db-ai-messages,
    .db-ai-footer {
      max-width: 800px !important;
      width: 100% !important;
      margin: 0 auto !important;
    }
  }

  @keyframes db-ai-slidein-desktop {
    from {
      opacity: 0;
      transform: translateX(100%);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }
</style>

<script>
(function() {
  var isCheckoutPage = window.location.pathname.indexOf('/pages/checkout') > -1;
  var assistantBtn = document.getElementById('dbAIAssistant');
  var chatModal = document.getElementById('dbAIChatModal');
  var chatClose = document.getElementById('dbAIChatClose');
  var chatForm = document.getElementById('dbAIChatForm');
  var chatInput = document.getElementById('dbAIChatInput');
  var messagesArea = document.getElementById('dbAIMessagesArea');
  var typingIndicator = document.getElementById('dbAITypingIndicator');

  // Settings elements for custom key input
  var settingsToggle = document.getElementById('dbAISettingsToggle');
  var settingsOverlay = document.getElementById('dbAISettingsOverlay');
  var saveSettingsBtn = document.getElementById('dbAISaveSettings');
  var closeSettingsBtn = document.getElementById('dbAICloseSettings');
  var apiKeyInput = document.getElementById('dbGeminiApiKeyInput');

  if (!assistantBtn || !chatModal) return;

  // Retrieve global setting key or local override
  var themeApiKey = "{{ settings.gemini_api_key | escape }}".trim();

  function getApiKey() {
    return themeApiKey || localStorage.getItem('gemini_api_key') || '';
  }

  // System instructions - Contains full details about Donna Bella services, location, bookings and discounts
  var SYSTEM_PROMPT = `You are the Donna Bella Luxury Home Services AI Assistant, a warm, professional, and helpful beauty concierge in the UAE.
Donna Bella provides premium at-home beauty services including Manicures, Pedicures, Acrylic/Gel Nails, Hair Styling, Massages, and Waxing. The team travels directly to the client's home/villa/apartment.

Locations Covered:
We travel to all UAE Emirates: Dubai, Abu Dhabi, Sharjah, Ajman, Umm Al Quwain, Ras Al Khaimah, and Fujairah.

Pricing and Services:
1. Women's Nails: Manicure (AED 100), Pedicure (AED 90), Acrylic Nails (AED 315), Gel Nails (AED 295), Polygel (AED 250), Mani-Pedi Gel (AED 250), Cutting & Shaping (AED 35), Nail Art (AED 10 per unit).
2. Women's Hair: Hair Collar (from AED 150), Straightening (from AED 600), Blow Dry (Short: AED 100, Medium: AED 150, Long: AED 180), Hot Oil (AED 150).
