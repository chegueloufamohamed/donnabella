  var conversationHistory = [];

  // Toggle Modal
  assistantBtn.addEventListener('click', function(e) {
    e.preventDefault();
    e.stopPropagation();
    if (chatModal.style.display === 'none') {
      chatModal.style.display = 'flex';
      scrollChatToBottom();
      
      // If API key is missing, prompt user
      if (!getApiKey()) {
        setTimeout(function() {
          appendSystemMessage("Please click the settings gear (⚙️) icon in the header to enter your Gemini API Key and start chatting with the smart assistant!");
        }, 500);
      }
    } else {
      chatModal.style.display = 'none';
    }
  });

  chatClose.addEventListener('click', function(e) {
    e.preventDefault();
    e.stopPropagation();
    chatModal.style.display = 'none';
  });

  // Settings Overlay Toggles
  if (settingsToggle) {
    settingsToggle.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      apiKeyInput.value = localStorage.getItem('gemini_api_key') || '';
      settingsOverlay.style.display = 'flex';
    });
  }

  if (closeSettingsBtn) {
    closeSettingsBtn.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      settingsOverlay.style.display = 'none';
    });
  }

  if (saveSettingsBtn) {
    saveSettingsBtn.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      var key = apiKeyInput.value.trim();
      if (key) {
        localStorage.setItem('gemini_api_key', key);
        settingsOverlay.style.display = 'none';
        appendSystemMessage("API Key saved successfully! Ask me anything.");
      } else {
        localStorage.removeItem('gemini_api_key');
        settingsOverlay.style.display = 'none';
      }
    });
  }

  // Chat Submissions
  chatForm.addEventListener('submit', function(e) {
    e.preventDefault();
    var text = chatInput.value.trim();
    if (!text) return;

    chatInput.value = '';
    appendUserMessage(text);
    scrollChatToBottom();

    // Call Gemini API
    var apiKey = getApiKey();
    if (!apiKey) {
      appendSystemMessage("API Key is missing. Click the settings gear (⚙️) icon above to enter your API key.");
      return;
    }

    typingIndicator.style.display = 'flex';
    scrollChatToBottom();

    // Prepare payload
    conversationHistory.push({
      role: 'user',
      parts: [{ text: text }]
    });

    var url = 'https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent';
    
    fetch(url, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-goog-api-key': apiKey
      },
      body: JSON.stringify({
        systemInstruction: {
          parts: [{ text: SYSTEM_PROMPT }]
        },
        contents: conversationHistory,
        generationConfig: {
          temperature: 0.7,
          maxOutputTokens: 800
        }
      })
    })
    .then(function(res) {
      if (!res.ok) {
        return res.json().then(function(errJson) {
          var errMsg = 'API Request failed (' + res.status + ')';
          if (errJson && errJson.error && errJson.error.message) {
            errMsg += ': ' + errJson.error.message;
          }
          console.error("Gemini API Error details:", errJson);
          throw new Error(errMsg);
        }).catch(function() {
          return res.text().then(function(errText) {
            console.error("Gemini API Error raw text:", errText);
            throw new Error('API Request failed (' + res.status + '): ' + errText);
          });
        });
      }
      return res.json();
    })
    .then(function(data) {
      typingIndicator.style.display = 'none';
      var replyText = '';
      try {
        replyText = data.candidates[0].content.parts[0].text;
      } catch (e) {
        replyText = "Sorry, I couldn't process that response. Please try again.";
      }
      
      // Save assistant reply to history
      conversationHistory.push({
        role: 'model',
        parts: [{ text: replyText }]
      });

      appendAssistantMessage(replyText);
      scrollChatToBottom();
    })
    .catch(function(err) {
      typingIndicator.style.display = 'none';
      appendSystemMessage(err.message || "An error occurred while contacting the AI server.");
      // Pop the last user message from history on error to prevent broken history
      conversationHistory.pop();
      scrollChatToBottom();
    });
  });

  // UI Helpers
  function appendUserMessage(text) {
    var msgDiv = document.createElement('div');
    msgDiv.className = 'db-ai-msg user';
    msgDiv.innerHTML = '<div class="db-ai-bubble"></div>';
    msgDiv.querySelector('.db-ai-bubble').textContent = text;
    messagesArea.appendChild(msgDiv);
  }

  function appendAssistantMessage(text) {
    var msgDiv = document.createElement('div');
    msgDiv.className = 'db-ai-msg assistant';
    msgDiv.innerHTML = '<div class="db-ai-bubble"></div>';
    
    // Parse markdown-like WhatsApp links and format them as HTML clickable links
    var formattedText = escapeHtml(text)
      .replace(/(https?:\/\/wa\.me\/[0-9]+)/g, '<a href="$1" target="_blank" style="color: #c9a96e; text-decoration: underline; font-weight: bold;">WhatsApp Link</a>')
      .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
      .replace(/\n/g, '<br>');

    msgDiv.querySelector('.db-ai-bubble').innerHTML = formattedText;
    messagesArea.appendChild(msgDiv);
  }

  function appendSystemMessage(text) {
    var msgDiv = document.createElement('div');
    msgDiv.className = 'db-ai-msg assistant';
    msgDiv.innerHTML = '<div class="db-ai-bubble" style="background: rgba(229, 57, 53, 0.1); border-left-color: #ff1744; font-style: italic;"></div>';
    msgDiv.querySelector('.db-ai-bubble').textContent = text;
    messagesArea.appendChild(msgDiv);
  }

  function scrollChatToBottom() {
    messagesArea.scrollTop = messagesArea.scrollHeight;
  }

  function escapeHtml(str) {
    return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
  }
})();
</script>
