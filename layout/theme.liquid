    <script>
      (function() {
        if (window.location.pathname.indexOf('/thank_you') > -1 || window.location.pathname.indexOf('/orders/') > -1) {
          try {
            localStorage.removeItem('donnabella_cart');
          } catch(e){}
        }

        // Helper to check if a URL is local and return its relative path
        function getRelativePath(href) {
          if (!href) return null;
          if (href.indexOf('#') === 0 || 
              href.indexOf('mailto:') === 0 || 
              href.indexOf('tel:') === 0 || 
              href.indexOf('javascript:') === 0 ||
              href.indexOf('sms:') === 0) {
            return null;
          }
          
          try {
            var urlObj = new URL(href, window.location.origin);
            var host = urlObj.host;
            var isLocal = (host === window.location.host || 
                           host === 'belladona.ae' || 
                           host === 'www.belladona.ae' || 
                           host === 'donnabella.ae' || 
                           host === 'www.donnabella.ae');
            if (isLocal) {
              return urlObj.pathname + urlObj.search + urlObj.hash;
            }
          } catch(e) {
            if (href.indexOf('http://') !== 0 && href.indexOf('https://') !== 0 && href.indexOf('//') !== 0) {
              return href;
            }
          }
          return null;
        }

        // Helper to check if a form action is local and return its relative path
        function getRelativeFormAction(action) {
          if (!action) return null;
          if (action.indexOf('javascript:') === 0 || action.indexOf('/localization') === 0) {
            return null;
          }
          try {
            var urlObj = new URL(action, window.location.origin);
            var host = urlObj.host;
            var isLocal = (host === window.location.host || 
                           host === 'belladona.ae' || 
                           host === 'www.belladona.ae' || 
                           host === 'donnabella.ae' || 
                           host === 'www.donnabella.ae');
            if (isLocal) {
              var path = urlObj.pathname + urlObj.search + urlObj.hash;
              if (path.indexOf('/localization') === 0) return null;
              return path;
            }
          } catch(e) {
            if (action.indexOf('http://') !== 0 && action.indexOf('https://') !== 0 && action.indexOf('//') !== 0) {
              return action;
            }
          }
          return null;
        }

        // Keep language locale sticky across navigations
        function localizeAllLinks() {
          var rootUrl = '{{ request.locale.root_url }}';
          if (!rootUrl || rootUrl === '/') return;

          // Localize relative links
          var links = document.querySelectorAll('a[href]');
          links.forEach(function(el) {
            var href = el.getAttribute('href');
            var relativePath = getRelativePath(href);
            if (!relativePath) return;

            if (relativePath === rootUrl || relativePath.indexOf(rootUrl + '/') === 0) {
              return;
            }
            var targetPath = relativePath;
            if (targetPath === '/') {
              el.setAttribute('href', rootUrl);
            } else {
              if (targetPath.charAt(0) !== '/') {
                targetPath = '/' + targetPath;
              }
              el.setAttribute('href', rootUrl + targetPath);
            }
          });

          // Localize relative forms
          var forms = document.querySelectorAll('form[action]');
          forms.forEach(function(el) {
            var action = el.getAttribute('action');
            var relativeAction = getRelativeFormAction(action);
            if (!relativeAction) return;

            if (relativeAction === rootUrl || relativeAction.indexOf(rootUrl + '/') === 0) {
              return;
            }
            var targetPath = relativeAction;
            if (targetPath === '/') {
              el.setAttribute('action', rootUrl);
            } else {
              if (targetPath.charAt(0) !== '/') {
                targetPath = '/' + targetPath;
              }
              el.setAttribute('action', rootUrl + targetPath);
            }
          });
        }

        // Run on initial load
        document.addEventListener('DOMContentLoaded', localizeAllLinks);
        window.addEventListener('load', localizeAllLinks);

        // Run when InstantClick transitions to a new page
        if (typeof InstantClick !== 'undefined' && InstantClick.on) {
          InstantClick.on('change', localizeAllLinks);
        }

        // Fallback: intercept interactions on any link and localize dynamically
        var interceptEvents = ['click', 'mousedown', 'touchstart'];
        interceptEvents.forEach(function(evt) {
          document.addEventListener(evt, function(e) {
            var anchor = e.target.closest('a[href]');
            if (!anchor) return;
            var rootUrl = '{{ request.locale.root_url }}';
            if (!rootUrl || rootUrl === '/') return;
            var href = anchor.getAttribute('href');
            
            var relativePath = getRelativePath(href);
            if (!relativePath) return;

            if (relativePath === rootUrl || relativePath.indexOf(rootUrl + '/') === 0) {
              return;
            }
            
            var targetPath = relativePath;
            if (targetPath === '/') {
              anchor.setAttribute('href', rootUrl);
            } else {
              if (targetPath.charAt(0) !== '/') {
                targetPath = '/' + targetPath;
              }
              anchor.setAttribute('href', rootUrl + targetPath);
            }
          }, { capture: true });
        });
      })();
    </script>
  </body>  
</html>