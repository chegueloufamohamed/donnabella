    "custom_liquid_Dc9x4H": {
      "type": "custom-liquid",
      "name": "Custom liquid",
      "settings": {
        "custom_liquid": "{% comment %}\n  Donna Bella — Men's Services Coming Soon\n  Custom Liquid — paste into any empty Men's service page\n  Same full-bleed technique as the Our Story placeholder\n{% endcomment %}\n\n{% assign is_arabic = false %}\n{% if request.locale.iso_code contains 'ar' %}\n  {% assign is_arabic = true %}\n{% endif %}\n\n<link href=\"https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Lora:ital,wght@0,300;1,300&family=Cairo:wght@300;400;600&display=swap\" rel=\"stylesheet\">\n\n<style>\n  /* ── Full-bleed wrapper ─────────────────────────────────── */\n  .dbm-bleed {\n    width:        100vw;\n    position:     relative;\n    left:         50%;\n    right:        50%;\n    margin-left:  -50vw;\n    margin-right: -50vw;\n  }\n\n  /* ── Main section ───────────────────────────────────────── */\n  .dbm-soon {\n    background:  #405264;\n    min-height:  580px;\n    display:     flex;\n    align-items: center;\n    justify-content: center;\n    padding:     90px 24px;\n    text-align:  center;\n    position:    relative;\n    overflow:    hidden;\n  }\n\n  /* diagonal texture lines */\n  .dbm-soon::before {\n    content:    '';\n    position:   absolute;\n    inset:      0;\n    background: repeating-linear-gradient(\n      -55deg,\n      transparent,\n      transparent 40px,\n      rgba(255,255,255,0.018) 40px,\n      rgba(255,255,255,0.018) 41px\n    );\n    pointer-events: none;\n  }\n\n  /* gold radial glow */\n  .dbm-soon::after {\n    content:    '';\n    position:   absolute;\n    inset:      0;\n    background: radial-gradient(ellipse at 50% 38%, rgba(201,169,110,0.13) 0%, transparent 65%);\n    pointer-events: none;\n  }\n\n  .dbm-soon__inner {\n    position:  relative;\n    z-index:   1;\n    max-width: 600px;\n    margin:    0 auto;\n  }\n\n  /* ── Icon ───────────────────────────────────────────────── */\n  .dbm-soon__icon {\n    width:         64px;\n    height:        64px;\n    margin:        0 auto 32px;\n    border-radius: 50%;\n    border:        1.5px solid rgba(201,169,110,0.5);\n    display:       flex;\n    align-items:   center;\n    justify-content: center;\n    color:         #C9A96E;\n  }\n\n  .dbm-soon__icon svg {\n    width:  28px;\n    height: 28px;\n    stroke: #C9A96E;\n    fill:   none;\n    stroke-width: 1.5;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n\n  /* ── Ornament ───────────────────────────────────────────── */\n  .dbm-soon__ornament {\n    display:         flex;\n    align-items:     center;\n    justify-content: center;\n    gap:             12px;\n    margin-bottom:   28px;\n  }\n\n  .dbm-soon__line {\n    width:      50px;\n    height:     1px;\n    background: linear-gradient(to right, transparent, #C9A96E);\n  }\n\n  .dbm-soon__line:last-child {\n    background: linear-gradient(to left, transparent, #C9A96E);\n  }\n\n  .dbm-soon__diamond {\n    width:       7px;\n    height:      7px;\n    background:  #C9A96E;\n    transform:   rotate(45deg);\n    flex-shrink: 0;\n  }\n\n  /* ── Label ──────────────────────────────────────────────── */\n  .dbm-soon__label {\n    display:        block;\n    font-family:    'Cormorant Garamond', Georgia, serif;\n    font-size:      11px;\n    font-weight:    600;\n    letter-spacing: 0.22em;\n    text-transform: uppercase;\n    color:          #8FAEAD;\n    margin-bottom:  18px;\n  }\n\n  /* ── Title ──────────────────────────────────────────────── */\n  .dbm-soon__title {\n    font-family:  'Cormorant Garamond', Georgia, serif;\n    font-size:    50px;\n    font-weight:  400;\n    line-height:  1.2;\n    color:        #FAF7F2;\n    margin:       0 0 22px;\n    letter-spacing: -0.01em;\n  }\n\n  /* ── Sub text ───────────────────────────────────────────── */\n  .dbm-soon__text {\n    font-family:  'Lora', Georgia, serif;\n    font-size:    16px;\n    font-weight:  300;\n    font-style:   italic;\n    line-height:  1.8;\n    color:        rgba(250,247,242,0.58);\n    margin:       0 0 48px;\n  }\n\n  /* ── Service tags (what's coming) ───────────────────────── */\n  .dbm-soon__tags {\n    display:         flex;\n    flex-wrap:       wrap;\n    align-items:     center;\n    justify-content: center;\n    gap:             10px;\n    margin-bottom:   48px;\n  }\n\n  .dbm-soon__tag {\n    font-family:    'Cormorant Garamond', Georgia, serif;\n    font-size:      12px;\n    font-weight:    600;\n    letter-spacing: 0.14em;\n    text-transform: uppercase;\n    color:          rgba(250,247,242,0.45);\n    border:         1px solid rgba(201,169,110,0.25);\n    border-radius:  40px;\n    padding:        7px 18px;\n    white-space:    nowrap;\n    transition:     all 0.3s ease;\n  }\n\n  .dbm-soon__tag:hover {\n    color:            #C9A96E;\n    border-color:     rgba(201,169,110,0.6);\n    background:       rgba(201,169,110,0.07);\n  }\n\n  /* ── Animated dots ──────────────────────────────────────── */\n  .dbm-soon__dots {\n    display:         flex;\n    align-items:     center;\n    justify-content: center;\n    gap:             10px;\n  }\n\n  .dbm-soon__dot {\n    width:         8px;\n    height:        8px;\n    border-radius: 50%;\n    background:    #C9A96E;\n    animation:     dbm-pulse 1.7s ease-in-out infinite;\n  }\n\n  .dbm-soon__dot:nth-child(2) {\n    animation-delay: 0.32s;\n    background:      #8FAEAD;\n  }\n\n  .dbm-soon__dot:nth-child(3) {\n    animation-delay: 0.64s;\n  }\n\n  @keyframes dbm-pulse {\n    0%, 100% { opacity: 0.28; transform: scale(0.82); }\n    50%       { opacity: 1;    transform: scale(1.12); }\n  }\n\n  /* ── Arabic overrides ───────────────────────────────────── */\n  .dbm-soon[dir=\"rtl\"] .dbm-soon__label,\n  .dbm-soon[dir=\"rtl\"] .dbm-soon__title,\n  .dbm-soon[dir=\"rtl\"] .dbm-soon__text,\n  .dbm-soon[dir=\"rtl\"] .dbm-soon__tag {\n    font-family:    'Cairo', sans-serif;\n    letter-spacing: 0;\n    text-transform: none;\n    font-style:     normal;\n  }\n\n  .dbm-soon[dir=\"rtl\"] .dbm-soon__label { font-size: 13px; }\n  .dbm-soon[dir=\"rtl\"] .dbm-soon__title { font-size: 38px; font-weight: 600; line-height: 1.4; }\n  .dbm-soon[dir=\"rtl\"] .dbm-soon__text  { font-size: 15px; }\n  .dbm-soon[dir=\"rtl\"] .dbm-soon__tag   { font-size: 13px; }\n\n  /* ── Mobile ─────────────────────────────────────────────── */\n  @media (max-width: 767px) {\n    .dbm-soon          { min-height: 420px; padding: 64px 20px; }\n    .dbm-soon__title   { font-size: 34px; }\n    .dbm-soon[dir=\"rtl\"] .dbm-soon__title { font-size: 28px; }\n    .dbm-soon__text    { font-size: 15px; }\n    .dbm-soon__tags    { gap: 8px; }\n    .dbm-soon__tag     { font-size: 11px; padding: 6px 14px; }\n  }\n</style>\n\n<div class=\"dbm-bleed\">\n  <div class=\"dbm-soon\" dir=\"{% if is_arabic %}rtl{% else %}ltr{% endif %}\">\n    <div class=\"dbm-soon__inner\">\n\n      {% comment %} — Icon ——————————————————————————————————— {% endcomment %}\n      <div class=\"dbm-soon__icon\">\n        <svg viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\">\n          <circle cx=\"12\" cy=\"8\" r=\"4\"/>\n          <path d=\"M4 20c0-4 3.6-7 8-7s8 3 8 7\"/>\n        </svg>\n      </div>\n\n      {% comment %} — Ornament ———————————————————————————————— {% endcomment %}\n      <div class=\"dbm-soon__ornament\">\n        <span class=\"dbm-soon__line\"></span>\n        <span class=\"dbm-soon__diamond\"></span>\n        <span class=\"dbm-soon__line\"></span>\n      </div>\n\n      {% comment %} — Label ———————————————————————————————————— {% endcomment %}\n      <span class=\"dbm-soon__label\">\n        {% if is_arabic %}خدمات الرجال{% else %}Men's Services{% endif %}\n      </span>\n\n      {% comment %} — Title ———————————————————————————————————— {% endcomment %}\n      <h2 class=\"dbm-soon__title\">\n        {% if is_arabic %}\n          نحن نعمل على هذا<br>قريباً لكم\n        {% else %}\n          We're working on<br>something great for you\n        {% endif %}\n      </h2>\n\n      {% comment %} — Sub text ——————————————————————————————— {% endcomment %}\n      <p class=\"dbm-soon__text\">\n        {% if is_arabic %}\n          خدماتنا للرجال قادمة قريباً.<br>نعمل على تجربة استثنائية تليق بكم.\n        {% else %}\n          Our men's services are coming soon.<br>We're putting the finishing touches on an exceptional experience for you.\n        {% endif %}\n      </p>\n\n      {% comment %} — Service tags ————————————————————————————\n        Edit these tags to match the specific page you're placing this on.\n        For example, on the Men's Hair page keep only Hair-related tags.\n        Or leave all tags to give a preview of everything coming.\n      {% endcomment %}\n      <div class=\"dbm-soon__tags\">\n        {% if is_arabic %}\n          <span class=\"dbm-soon__tag\">مساج</span>\n          <span class=\"dbm-soon__tag\">العناية بالشعر</span>\n          <span class=\"dbm-soon__tag\">مانيكير وباديكير</span>\n          <span class=\"dbm-soon__tag\">العناية بالبشرة</span>\n          <span class=\"dbm-soon__tag\">إزالة الشعر</span>\n          <span class=\"dbm-soon__tag\">الرموش والحواجب</span>\n        {% else %}\n          <span class=\"dbm-soon__tag\">Massage</span>\n          <span class=\"dbm-soon__tag\">Hair Care</span>\n          <span class=\"dbm-soon__tag\">Manicure & Pedicure</span>\n          <span class=\"dbm-soon__tag\">Skin Care</span>\n          <span class=\"dbm-soon__tag\">Waxing</span>\n          <span class=\"dbm-soon__tag\">Lashes & Brows</span>\n        {% endif %}\n      </div>\n\n      {% comment %} — Dots ———————————————————————————————————— {% endcomment %}\n      <div class=\"dbm-soon__dots\">\n        <span class=\"dbm-soon__dot\"></span>\n        <span class=\"dbm-soon__dot\"></span>\n        <span class=\"dbm-soon__dot\"></span>\n      </div>\n\n    </div>\n  </div>\n</div>",
        "padding_top": 0,
        "padding_bottom": 0,
        "css_class": "",
        "custom_css": ""
      }
    },
