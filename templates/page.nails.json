        "custom_html": "<body>\n\n\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Nail Treatment — Belladona Care</title>\n\n<style>\n  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n  :root {\n    --bg: #405264; --bg-dark: #2f3d4d; --bg-light: #4d6275; --bg-deeper: #354656;\n    --gold: #c9a96e; --gold-line: rgba(201,169,110,0.35);\n    --blush: #c9a0a0; --blush-dim: rgba(201,160,160,0.1); --blush-line: rgba(201,160,160,0.3);\n    --white: #ffffff; --white-60: rgba(255,255,255,0.6);\n    --glass: rgba(255,255,255,0.06); --glass-b: rgba(255,255,255,0.11);\n    --serif: 'Cormorant Garamond', Georgia, serif; --sans: 'Montserrat', sans-serif;\n  }\n  html { scroll-behavior: smooth; }\n  body { background-color: var(--bg); color: var(--white); font-family: var(--sans); font-weight: 300; overflow-x: hidden; }\n  body::before {\n    content: ''; position: fixed; inset: 0;\n    background-image: url(\"data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E\");\n    pointer-events: none; z-index: 0; opacity: 0.6;\n  }\n  @keyframes fadeUp { to { opacity: 1; transform: translateY(0); } }\n  @keyframes ringPulse {\n    0%,100% { opacity: 0.35; transform: translate(-50%,-50%) scale(1); }\n    50% { opacity: 0.8; transform: translate(-50%,-50%) scale(1.05); }\n  }\n\n  /* ── HERO ── */\n  .hero {\n    position: relative; min-height: 54vh;\n    display: flex; flex-direction: column; align-items: center; justify-content: center;\n    text-align: center; padding: 80px 30px 50px; overflow: hidden;\n  }\n  .hero::before {\n    content: ''; position: absolute; width: 600px; height: 600px; border-radius: 50%;\n    background: radial-gradient(circle, rgba(201,160,160,0.09) 0%, transparent 70%);\n    top: 50%; left: 50%; transform: translate(-50%,-50%); pointer-events: none;\n  }\n  .hero::after {\n    content: ''; position: absolute; width: 360px; height: 360px; border-radius: 50%;\n    border: 1px solid var(--blush-line); top: 50%; left: 50%;\n    transform: translate(-50%,-50%); pointer-events: none; animation: ringPulse 4s ease-in-out infinite;\n  }\n  .hero-eyebrow {\n    font-size: 11px; font-weight: 500; letter-spacing: 0.42em; text-transform: uppercase;\n    color: var(--blush); margin-bottom: 20px; position: relative; z-index: 1;\n    opacity: 0; transform: translateY(16px); animation: fadeUp 0.8s ease 0.2s forwards;\n  }\n  .hero-title {\n    font-family: var(--serif); font-size: clamp(48px, 9vw, 94px);\n    font-weight: 300; font-style: italic; line-height: 0.95; color: var(--white);\n    position: relative; z-index: 1; opacity: 0; transform: translateY(20px); animation: fadeUp 0.9s ease 0.4s forwards;\n  }\n  .hero-title span { color: var(--gold); font-style: normal; font-weight: 500; }\n  .hero-desc {\n    margin-top: 26px; font-size: 13px; letter-spacing: 0.14em; color: var(--white-60); text-transform: uppercase;\n    position: relative; z-index: 1; opacity: 0; transform: translateY(16px); animation: fadeUp 0.9s ease 0.6s forwards;\n  }\n  .hero-divider { margin-top: 40px; width: 1px; height: 60px; background: linear-gradient(to bottom, var(--gold), transparent); opacity: 0; animation: fadeUp 0.9s ease 0.8s forwards; }\n\n  /* ── LAYOUT ── */\n  .section { position: relative; z-index: 1; padding: 52px 0 62px; }\n  .section + .section { padding-top: 0; }\n  .section-inner { max-width: 1160px; margin: 0 auto; padding: 0 30px; }\n\n  .section-divider {\n    position: relative; z-index: 1;\n    max-width: 1160px; margin: 0 auto 0; padding: 48px 30px 0;\n    display: flex; align-items: center; gap: 20px;\n  }\n  .sd-line { flex: 1; height: 1px; background: rgba(255,255,255,0.08); }\n  .sd-label {\n    font-family: var(--serif); font-size: 30px; font-style: italic;\n    font-weight: 300; color: var(--white-60); white-space: nowrap; letter-spacing: 0.02em;\n  }\n\n  .section-label {\n    display: flex; align-items: center; gap: 18px; margin-bottom: 42px;\n    opacity: 0; transform: translateX(-20px); transition: opacity 0.7s ease, transform 0.7s ease;\n  }\n  .section-label.visible { opacity: 1; transform: translateX(0); }\n  .section-label-line { flex: 1; height: 1px; background: linear-gradient(to right, var(--gold-line), transparent); }\n  .section-label-text { font-size: 10px; font-weight: 500; letter-spacing: 0.45em; text-transform: uppercase; color: var(--gold); white-space: nowrap; }\n\n  /* ── HERO PAIR (Mani + Pedi + Combo) ── */\n  .hero-trio { display: grid; grid-template-columns: 1fr 1fr 2fr; gap: 2px; margin-bottom: 2px; }\n\n  .classic-card {\n    background: var(--glass); border: 1px solid var(--glass-b);\n    padding: 34px 28px; cursor: default; display: flex; flex-direction: column;\n    opacity: 0; transform: translateY(22px);\n    transition: opacity 0.65s ease, transform 0.65s ease, background 0.3s, border-color 0.3s;\n  }\n  .classic-card.visible { opacity: 1; transform: translateY(0); }\n  .classic-card:hover { background: rgba(255,255,255,0.1); border-color: var(--gold-line); }\n\n  .combo-card {\n    position: relative;\n    background: linear-gradient(135deg, rgba(201,169,110,0.13) 0%, rgba(201,169,110,0.03) 100%);\n    border: 1px solid var(--gold-line); padding: 38px 38px 34px;\n    cursor: default; display: flex; flex-direction: column; overflow: hidden;\n    opacity: 0; transform: translateY(22px);\n    transition: opacity 0.65s ease, transform 0.65s ease, background 0.4s;\n  }\n  .combo-card.visible { opacity: 1; transform: translateY(0); }\n  .combo-card:hover { background: linear-gradient(135deg, rgba(201,169,110,0.2) 0%, rgba(201,169,110,0.06) 100%); }\n  .combo-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(to right, transparent 10%, var(--gold) 50%, transparent 90%); }\n  .combo-bg { position: absolute; bottom: 10px; right: 20px; font-family: var(--serif); font-size: 100px; font-weight: 300; color: rgba(201,169,110,0.07); line-height: 1; user-select: none; }\n\n  .card-icon { font-size: 20px; margin-bottom: 14px; display: block; }\n  .card-tag { font-size: 9px; font-weight: 500; letter-spacing: 0.42em; text-transform: uppercase; color: var(--gold); margin-bottom: 10px; }\n  .card-tag.blush { color: var(--blush); }\n  .card-title { font-family: var(--serif); font-size: 22px; font-weight: 400; color: var(--white); margin-bottom: 4px; line-height: 1.2; }\n  .combo-card .card-title { font-size: 30px; }\n  .card-subtitle { font-family: var(--serif); font-style: italic; font-size: 12px; color: var(--gold); margin-bottom: 10px; opacity: 0.9; }\n  .card-desc { font-size: 11.5px; line-height: 1.72; color: var(--white-60); margin-bottom: 20px; flex: 1; }\n  .card-footer { display: flex; align-items: flex-end; justify-content: space-between; border-top: 1px solid var(--glass-b); padding-top: 14px; margin-top: auto; }\n  .card-price { font-family: var(--serif); font-size: 28px; font-weight: 300; color: var(--white); }\n  .card-price sup { font-size: 11px; font-family: var(--sans); vertical-align: super; opacity: 0.7; }\n  .combo-card .card-price { font-size: 42px; }\n  .card-dur { font-size: 10px; color: var(--white-60); letter-spacing: 0.06em; text-align: right; line-height: 1.5; }\n  .card-dur span { display: block; color: var(--gold); font-size: 13px; margin-bottom: 2px; }\n\n  /* ── THREE GRID ── */\n  .three-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; }\n  .two-grid   { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2px; }\n  .four-grid  { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2px; }\n\n  /* standard tile used in all grids */\n  .tile {\n    background: var(--glass); border: 1px solid var(--glass-b);\n    padding: 30px 26px 26px; cursor: default; display: flex; flex-direction: column;\n    opacity: 0; transform: translateY(20px);\n    transition: opacity 0.65s ease, transform 0.65s ease, background 0.3s, border-color 0.3s;\n  }\n  .tile.visible { opacity: 1; transform: translateY(0); }\n  .tile:hover { background: rgba(255,255,255,0.1); border-color: var(--gold-line); }\n  .tile.blush-bg { background: linear-gradient(135deg, var(--blush-dim) 0%, rgba(201,160,160,0.02) 100%); border-color: var(--blush-line); }\n  .tile.blush-bg:hover { background: linear-gradient(135deg, rgba(201,160,160,0.16) 0%, rgba(201,160,160,0.04) 100%); border-color: rgba(201,160,160,0.5); }\n  .tile.gold-bg { background: linear-gradient(135deg, rgba(201,169,110,0.12) 0%, rgba(201,169,110,0.03) 100%); border-color: var(--gold-line); }\n  .tile.gold-bg:hover { background: linear-gradient(135deg, rgba(201,169,110,0.18) 0%, rgba(201,169,110,0.06) 100%); }\n  .tile.gold-bg::before, .tile.top-gold::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(to right, transparent 10%, var(--gold) 50%, transparent 90%); }\n  .tile.top-gold { position: relative; }\n\n  .tile-icon { font-size: 18px; margin-bottom: 12px; display: block; }\n  .tile-tag { font-size: 9px; font-weight: 500; letter-spacing: 0.4em; text-transform: uppercase; color: var(--gold); margin-bottom: 8px; }\n  .tile-tag.blush { color: var(--blush); }\n  .tile-title { font-family: var(--serif); font-size: 20px; font-weight: 400; color: var(--white); margin-bottom: 4px; line-height: 1.2; }\n  .tile-subtitle { font-family: var(--serif); font-style: italic; font-size: 11px; color: var(--gold); margin-bottom: 10px; opacity: 0.85; }\n  .tile-subtitle.blush { color: var(--blush); }\n  .tile-desc { font-size: 11.5px; line-height: 1.7; color: var(--white-60); margin-bottom: 18px; flex: 1; }\n  .tile-footer { display: flex; align-items: flex-end; justify-content: space-between; border-top: 1px solid var(--glass-b); padding-top: 12px; margin-top: auto; }\n  .tile-price { font-family: var(--serif); font-size: 26px; font-weight: 300; color: var(--white); }\n  .tile-price sup { font-size: 11px; font-family: var(--sans); vertical-align: super; opacity: 0.7; }\n  .tile-dur { font-size: 10px; color: var(--white-60); letter-spacing: 0.06em; }\n\n  /* ── FEATURE CARD (wide, 2-col grid) ── */\n  .feature-card {\n    position: relative; background: var(--glass); border: 1px solid var(--glass-b);\n    padding: 40px 44px; display: grid; grid-template-columns: 1fr auto;\n    gap: 40px; align-items: center; overflow: hidden; margin-bottom: 2px;\n    cursor: default; opacity: 0; transform: translateY(24px);\n    transition: opacity 0.75s ease, transform 0.75s ease, background 0.35s, border-color 0.35s;\n  }\n  .feature-card.visible { opacity: 1; transform: translateY(0); }\n  .feature-card:hover { background: rgba(255,255,255,0.09); border-color: var(--gold-line); }\n  .feature-card.gold-bg { background: linear-gradient(135deg, rgba(201,169,110,0.12) 0%, rgba(201,169,110,0.03) 100%); border-color: var(--gold-line); }\n  .feature-card.gold-bg::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(to right, transparent 10%, var(--gold) 50%, transparent 90%); }\n  .feature-card.blush-bg { background: linear-gradient(135deg, var(--blush-dim) 0%, rgba(201,160,160,0.02) 100%); border-color: var(--blush-line); border-left: 2px solid var(--blush); }\n  .fc-tag { font-size: 9px; font-weight: 500; letter-spacing: 0.42em; text-transform: uppercase; color: var(--gold); margin-bottom: 10px; }\n  .fc-tag.blush { color: var(--blush); }\n  .fc-title { font-family: var(--serif); font-size: 30px; font-weight: 400; color: var(--white); line-height: 1.15; margin-bottom: 6px; }\n  .fc-subtitle { font-family: var(--serif); font-style: italic; font-size: 13px; color: var(--gold); margin-bottom: 12px; opacity: 0.9; }\n  .fc-subtitle.blush { color: var(--blush); }\n  .fc-desc { font-size: 12.5px; line-height: 1.75; color: var(--white-60); max-width: 460px; }\n  .fc-right { text-align: right; flex-shrink: 0; }\n  .fc-label { font-size: 9px; letter-spacing: 0.35em; text-transform: uppercase; color: var(--gold); margin-bottom: 5px; }\n  .fc-label.blush { color: var(--blush); }\n  .fc-price { font-family: var(--serif); font-size: 44px; font-weight: 300; color: var(--white); line-height: 1; }\n  .fc-price sup { font-size: 15px; font-family: var(--sans); vertical-align: super; opacity: 0.7; }\n  .fc-dur { font-size: 10px; color: var(--white-60); margin-top: 8px; letter-spacing: 0.08em; }\n\n  /* ── PRICE TABLE ── */\n  .price-table { border: 1px solid var(--glass-b); overflow: hidden; opacity: 0; transform: translateY(20px); transition: opacity 0.7s ease, transform 0.7s ease; }\n  .price-table.visible { opacity: 1; transform: translateY(0); }\n  .pt-header { background: rgba(201,169,110,0.1); border-bottom: 1px solid var(--gold-line); padding: 14px 28px; display: grid; grid-template-columns: 1fr auto auto; gap: 24px; font-size: 9px; font-weight: 500; letter-spacing: 0.4em; text-transform: uppercase; color: var(--gold); }\n  .pt-header span:last-child { text-align: right; }\n  .pt-row { display: grid; grid-template-columns: 1fr auto auto; gap: 24px; padding: 16px 28px; border-bottom: 1px solid rgba(255,255,255,0.04); align-items: center; transition: background 0.25s; cursor: default; }\n  .pt-row:last-child { border-bottom: none; }\n  .pt-row:hover { background: rgba(255,255,255,0.05); }\n  .pt-row.gel { border-left: 2px solid var(--blush); }\n  .pt-row.french { border-left: 2px solid rgba(201,169,110,0.6); }\n  .pt-name { font-family: var(--serif); font-size: 17px; font-weight: 400; color: var(--white); line-height: 1.2; }\n  .pt-name small { display: block; font-family: var(--sans); font-size: 10px; color: var(--white-60); margin-top: 2px; }\n  .pt-name small.blush { color: var(--blush); }\n  .pt-name small.gold  { color: var(--gold); }\n  .pt-dur { font-size: 10px; color: var(--white-60); white-space: nowrap; letter-spacing: 0.06em; text-align: right; }\n  .pt-price { font-family: var(--serif); font-size: 22px; font-weight: 300; color: var(--white); text-align: right; white-space: nowrap; min-width: 72px; }\n  .pt-price sup { font-size: 10px; font-family: var(--sans); vertical-align: super; opacity: 0.7; }\n\n  .legend { display: flex; align-items: center; gap: 20px; margin-top: 13px; padding-left: 4px; flex-wrap: wrap; }\n  .legend-item { display: flex; align-items: center; gap: 8px; }\n  .legend-dot { width: 10px; height: 10px; border-radius: 2px; flex-shrink: 0; }\n  .legend-text { font-size: 10px; letter-spacing: 0.1em; color: rgba(255,255,255,0.4); }\n\n  /* ── CHAPTER BANNER (separates nail treatment from extensions) ── */\n  .chapter-banner {\n    position: relative; z-index: 1;\n    background: linear-gradient(to right, var(--bg-dark), var(--bg-deeper), var(--bg-dark));\n    border-top: 1px solid var(--glass-b); border-bottom: 1px solid var(--glass-b);\n    padding: 60px 30px; text-align: center; overflow: hidden; margin-top: 60px;\n    opacity: 0; transform: translateY(20px); transition: opacity 0.8s ease, transform 0.8s ease;\n  }\n  .chapter-banner.visible { opacity: 1; transform: translateY(0); }\n  .chapter-banner::before {\n    content: ''; position: absolute; inset: 0;\n    background: radial-gradient(ellipse at center, rgba(201,160,160,0.06) 0%, transparent 70%);\n  }\n  .chapter-banner-eyebrow { font-size: 10px; font-weight: 500; letter-spacing: 0.5em; text-transform: uppercase; color: var(--blush); margin-bottom: 16px; position: relative; }\n  .chapter-banner-title { font-family: var(--serif); font-size: clamp(36px, 6vw, 62px); font-weight: 300; font-style: italic; color: var(--white); line-height: 1.05; position: relative; }\n  .chapter-banner-title span { color: var(--gold); font-style: normal; }\n  .chapter-banner-sub { margin-top: 14px; font-size: 12px; letter-spacing: 0.18em; color: var(--white-60); text-transform: uppercase; position: relative; }\n\n  /* ── BOTTOM ── */\n  .bottom-tagline { text-align: center; padding: 80px 30px 100px; position: relative; z-index: 1; opacity: 0; transform: translateY(20px); transition: opacity 0.9s ease, transform 0.9s ease; }\n  .bottom-tagline.visible { opacity: 1; transform: translateY(0); }\n  .tl-line { display: flex; align-items: center; justify-content: center; gap: 20px; margin-bottom: 30px; }\n  .tl-rule { width: 60px; height: 1px; background: var(--gold-line); }\n  .tl-diamond { color: var(--gold); font-size: 10px; }\n  .bottom-tagline h2 { font-family: var(--serif); font-size: clamp(28px, 5vw, 52px); font-weight: 300; font-style: italic; color: var(--white); line-height: 1.2; margin-bottom: 16px; }\n  .bottom-tagline p { font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--white-60); }\n\n  /* ── RESPONSIVE ── */\n  @media (max-width: 960px) {\n    .hero-trio   { grid-template-columns: 1fr 1fr; }\n    .hero-trio > *:last-child { grid-column: 1 / -1; }\n    .three-grid  { grid-template-columns: 1fr 1fr; }\n    .four-grid   { grid-template-columns: 1fr 1fr; }\n    .feature-card { grid-template-columns: 1fr; }\n    .fc-right    { text-align: left; }\n    .pt-header, .pt-row { grid-template-columns: 1fr auto; }\n    .pt-header > *:nth-child(2), .pt-row > *:nth-child(2) { display: none; }\n  }\n  @media (max-width: 600px) {\n    .three-grid { grid-template-columns: 1fr; }\n    .two-grid   { grid-template-columns: 1fr; }\n    .four-grid  { grid-template-columns: 1fr; }\n    .hero-trio  { grid-template-columns: 1fr; }\n    .hero-trio > *:last-child { grid-column: auto; }\n  }\n</style>\n\n\n\n<!-- ════════════════ HERO ════════════════ -->\n<section class=\"hero\">\n  <p class=\"hero-eyebrow\">Belladona Care · Dubai</p>\n  <h1 class=\"hero-title\">Polish &<br><span>Perfection</span>\n</h1>\n  <p class=\"hero-desc\">Nail Treatment & Extensions · Home Service</p>\n  <div class=\"hero-divider\"></div>\n</section>\n\n<!-- ════════════════ CLASSIC MANI + PEDI + COMBO ════════════════ -->\n<section class=\"section\">\n  <div class=\"section-inner\">\n    <div class=\"section-label\" data-reveal>\n      <span class=\"section-label-text\">Classic Care</span>\n      <div class=\"section-label-line\"></div>\n    </div>\n\n    <div class=\"hero-trio\">\n      <div class=\"classic-card\" data-reveal data-delay=\"0\">\n        <span class=\"card-icon\">💅</span>\n        <p class=\"card-tag\">Nail · Hands</p>\n        <h3 class=\"card-title\">Classic Manicure</h3>\n        <p class=\"card-subtitle\">Simple care for beautiful hands</p>\n        <p class=\"card-desc\">Cleans and cares for your nails and cuticles, leaving your hands neat and fresh.</p>\n        <div class=\"card-footer\">\n          <div class=\"card-price\">\n<sup>AED </sup>94</div>\n          <div class=\"card-dur\">\n<span>◷</span>1 hr</div>\n        </div>\n      </div>\n\n      <div class=\"classic-card\" data-reveal data-delay=\"80\">\n        <span class=\"card-icon\">🦶</span>\n        <p class=\"card-tag\">Nail · Feet</p>\n        <h3 class=\"card-title\">Classic Pedicure</h3>\n        <p class=\"card-subtitle\">Feel fresh from heel to toe</p>\n        <p class=\"card-desc\">Cleans and cares for your feet and nails, leaving them smooth, neat, and refreshed.</p>\n        <div class=\"card-footer\">\n          <div class=\"card-price\">\n<sup>AED </sup>100</div>\n          <div class=\"card-dur\">\n<span>◷</span>1 hr</div>\n        </div>\n      </div>\n\n      <div class=\"combo-card\" data-reveal data-delay=\"160\">\n        <span class=\"combo-bg\">✦</span>\n        <p class=\"card-tag\">Gelish · Mani & Pedi</p>\n        <h3 class=\"card-title\">Gelish Mani-Pedi</h3>\n        <p class=\"card-subtitle\">Gloss that stays</p>\n        <p class=\"card-desc\">Cares for your hands and feet while applying long-lasting gel polish for a glossy, chip-resistant finish that keeps you looking polished for weeks.</p>\n        <div class=\"card-footer\">\n          <div class=\"card-price\">\n<sup>AED </sup>284</div>\n          <div class=\"card-dur\">\n<span>◷</span>2 hrs</div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- ════════════════ GELISH ════════════════ -->\n<section class=\"section\">\n  <div class=\"section-inner\">\n    <div class=\"section-label\" data-reveal>\n      <span class=\"section-label-text\">Gelish</span>\n      <div class=\"section-label-line\"></div>\n    </div>\n\n    <div class=\"two-grid\">\n      <div class=\"tile blush-bg\" data-reveal data-delay=\"0\">\n        <span class=\"tile-icon\">💅</span>\n        <p class=\"tile-tag blush\">Gelish · Hands</p>\n        <h3 class=\"tile-title\">Gelish Manicure</h3>\n        <p class=\"tile-subtitle\">Gloss made to stay</p>\n        <p class=\"tile-desc\">Cares for your nails and applies long-lasting gel polish for a smooth, shiny finish that stays beautiful for weeks.</p>\n        <div class=\"tile-footer\">\n          <div class=\"tile-price\">\n<sup>AED </sup>137</div>\n          <div class=\"tile-dur\">1 hr</div>\n        </div>\n      </div>\n\n      <div class=\"tile blush-bg\" data-reveal data-delay=\"100\">\n        <span class=\"tile-icon\">🦶</span>\n        <p class=\"tile-tag blush\">Gelish · Feet</p>\n        <h3 class=\"tile-title\">Gelish Pedicure</h3>\n        <p class=\"tile-subtitle\">Long-lasting, chip-resistant shine</p>\n        <p class=\"tile-desc\">Refreshes your feet and finishes with a chip-resistant gel color cured under LED light for extended shine and wear.</p>\n        <div class=\"tile-footer\">\n          <div class=\"tile-price\">\n<sup>AED </sup>158</div>\n          <div class=\"tile-dur\">1 hr</div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- ════════════════ FRENCH ════════════════ -->\n<section class=\"section\">\n  <div class=\"sect