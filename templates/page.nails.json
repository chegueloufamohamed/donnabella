up>242</div>\n          <div class=\"tile-dur\">1 hr 30 min</div>\n        </div>\n      </div>\n\n      <div class=\"tile\" data-reveal data-delay=\"100\">\n        <p class=\"tile-tag\">Gel Overlay · French</p>\n        <h3 class=\"tile-title\">Gel French Overlay</h3>\n        <p class=\"tile-subtitle\">Classic tips with gel strength</p>\n        <p class=\"tile-desc\">Adds a layer of strengthening gel over your natural nails, finished with a classic French tip.</p>\n        <div class=\"tile-footer\">\n          <div class=\"tile-price\">\n<sup>AED </sup>260</div>\n          <div class=\"tile-dur\">1 hr</div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- ════════════════ GEL REFILLS ════════════════ -->\n<section class=\"section\">\n  <div class=\"section-inner\">\n    <div class=\"section-label\" data-reveal>\n      <span class=\"section-label-text\">Gel Refills</span>\n      <div class=\"section-label-line\"></div>\n    </div>\n\n    <div class=\"price-table\" data-reveal>\n      <div class=\"pt-header\">\n        <span>Service</span>\n        <span>Duration</span>\n        <span>Price</span>\n      </div>\n      <div class=\"pt-row gel\">\n        <div class=\"pt-name\">Gel Refill Natural<small class=\"blush\">Gel · Refresh your natural shine</small>\n</div>\n        <div class=\"pt-dur\">2 hr</div>\n        <div class=\"pt-price\">\n<sup>AED </sup>210</div>\n      </div>\n      <div class=\"pt-row french\">\n        <div class=\"pt-name\">Gel Refill French<small class=\"gold\">French · Clean tips restored</small>\n</div>\n        <div class=\"pt-dur\">2 hr</div>\n        <div class=\"pt-price\">\n<sup>AED </sup>263</div>\n      </div>\n      <div class=\"pt-row gel\">\n        <div class=\"pt-name\">Gel Refill Ombré<small class=\"blush\">Gel · Refresh your ombré shine</small>\n</div>\n        <div class=\"pt-dur\">1 hr 30 min</div>\n        <div class=\"pt-price\">\n<sup>AED </sup>315</div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- ════════════════ ACRYLIC EXTENSIONS ════════════════ -->\n<section class=\"section\">\n  <div class=\"section-inner\">\n    <div class=\"section-label\" data-reveal>\n      <span class=\"section-label-text\">Acrylic Extensions</span>\n      <div class=\"section-label-line\"></div>\n    </div>\n\n    <div class=\"three-grid\">\n      <div class=\"tile gold-bg top-gold\" data-reveal data-delay=\"0\">\n        <p class=\"tile-tag\">Acrylic Extension · French</p>\n        <h3 class=\"tile-title\">Acrylic Extension French</h3>\n        <p class=\"tile-subtitle\">Longer nails, classic French</p>\n        <p class=\"tile-desc\">Adds length using acrylic, finished with classic white French tips.</p>\n        <div class=\"tile-footer\">\n          <div class=\"tile-price\">\n<sup>AED </sup>315</div>\n          <div class=\"tile-dur\">2 hr 30 min</div>\n        </div>\n      </div>\n\n      <div class=\"tile gold-bg top-gold\" data-reveal data-delay=\"80\">\n        <p class=\"tile-tag\">Acrylic Extension · Natural</p>\n        <h3 class=\"tile-title\">Acrylic Extension Natural</h3>\n        <p class=\"tile-subtitle\">Naturally longer, effortlessly elegant</p>\n        <p class=\"tile-desc\">Durable acrylic extensions designed to look soft, clean, and effortlessly natural.</p>\n        <div class=\"tile-footer\">\n          <div class=\"tile-price\">\n<sup>AED </sup>294</div>\n          <div class=\"tile-dur\">2 hr</div>\n        </div>\n      </div>\n\n      <div class=\"tile\" data-reveal data-delay=\"160\">\n        <p class=\"tile-tag\">Acrylic Overlay · Natural</p>\n        <h3 class=\"tile-title\">Acrylic Overlay Natural</h3>\n        <p class=\"tile-subtitle\">Natural look, extra strength</p>\n        <p class=\"tile-desc\">Adds a thin acrylic layer over your natural nails for strength and durability without adding length.</p>\n        <div class=\"tile-footer\">\n          <div class=\"tile-price\">\n<sup>AED </sup>242</div>\n          <div class=\"tile-dur\">1 hr 30 min</div>\n        </div>\n      </div>\n\n      <div class=\"tile\" data-reveal data-delay=\"0\">\n        <p class=\"tile-tag\">Acrylic Overlay · French</p>\n        <h3 class=\"tile-title\">Acrylic Overlay French</h3>\n        <p class=\"tile-subtitle\">Strong nails, classic style</p>\n        <p class=\"tile-desc\">Strengthens your natural nails with a thin layer of acrylic, finished with a classic French style.</p>\n        <div class=\"tile-footer\">\n          <div class=\"tile-price\">\n<sup>AED </sup>263</div>\n          <div class=\"tile-dur\">2 hr</div>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- ════════════════ ACRYLIC REFILLS ════════════════ -->\n<section class=\"section\">\n  <div class=\"section-inner\">\n    <div class=\"section-label\" data-reveal>\n      <span class=\"section-label-text\">Acrylic Refills</span>\n      <div class=\"section-label-line\"></div>\n    </div>\n\n    <div class=\"price-table\" data-reveal>\n      <div class=\"pt-header\">\n        <span>Service</span>\n        <span>Duration</span>\n        <span>Price</span>\n      </div>\n      <div class=\"pt-row\">\n        <div class=\"pt-name\">Acrylic Refill Natural<small>Maintain your natural look — fills grown-out area, restores smooth surface</small>\n</div>\n        <div class=\"pt-dur\">1 hr</div>\n        <div class=\"pt-price\">\n<sup>AED </sup>210</div>\n      </div>\n      <div class=\"pt-row french\">\n        <div class=\"pt-name\">Acrylic Refill French<small class=\"gold\">French · Refresh your French tips</small>\n</div>\n        <div class=\"pt-dur\">2 hr</div>\n        <div class=\"pt-price\">\n<sup>AED </sup>263</div>\n      </div>\n      <div class=\"pt-row\">\n        <div class=\"pt-name\">Acrylic Refill Ombré<small>Refresh your ombré glow — restores the soft ombré blend</small>\n</div>\n        <div class=\"pt-dur\">2 hr</div>\n        <div class=\"pt-price\">\n<sup>AED </sup>315</div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- ════════════════ POLY GEL + REMOVAL + MAINTENANCE ════════════════ -->\n<section class=\"section\">\n  <div class=\"section-inner\">\n    <div class=\"section-label\" data-reveal>\n      <span class=\"section-label-text\">Poly Gel & Maintenance</span>\n      <div class=\"section-label-line\"></div>\n    </div>\n\n    <div class=\"price-table\" data-reveal>\n      <div class=\"pt-header\">\n        <span>Service</span>\n        <span>Duration</span>\n        <span>Price</span>\n      </div>\n      <div class=\"pt-row\">\n        <div class=\"pt-name\">Poly Gel Natural<small>Lightweight, flexible, and natural-looking gel system</small>\n</div>\n        <div class=\"pt-dur\">2 hr</div>\n        <div class=\"pt-price\">\n<sup>AED </sup>294</div>\n      </div>\n      <div class=\"pt-row\">\n        <div class=\"pt-name\">Buff and File<small>Simple care, polished look — shapes and smooths for a clean natural finish</small>\n</div>\n        <div class=\"pt-dur\">1 hr</div>\n        <div class=\"pt-price\">\n<sup>AED </sup>100</div>\n      </div>\n      <div class=\"pt-row\">\n        <div class=\"pt-name\">Hard Gel Removal<small>Safe removal, healthy nails — no damage to the natural nail</small>\n</div>\n        <div class=\"pt-dur\">30 min</div>\n        <div class=\"pt-price\">\n<sup>AED </sup>53</div>\n      </div>\n      <div class=\"pt-row\">\n        <div class=\"pt-name\">Poly Gel Removal<small>Safe and clean removal</small>\n</div>\n        <div class=\"pt-dur\">30 min</div>\n        <div class=\"pt-price\">\n<sup>AED </sup>53</div>\n      </div>\n      <div class=\"pt-row\">\n        <div class=\"pt-name\">Gel Repair<small>Small repair, flawless look — fixes cracked, chipped, or lifted gel nails</small>\n</div>\n        <div class=\"pt-dur\">20 min</div>\n        <div class=\"pt-price\">\n<sup>AED </sup>37</div>\n      </div>\n    </div>\n  </div>\n</section>\n\n<!-- ════════════════ BOTTOM ════════════════ -->\n<div class=\"bottom-tagline\" data-reveal>\n  <div class=\"tl-line\">\n    <div class=\"tl-rule\"></div>\n    <span class=\"tl-diamond\">◆</span>\n    <div class=\"tl-rule\"></div>\n  </div>\n  <h2>Beautiful nails,<br><em>beautifully done</em>\n</h2>\n  <p>All services available at your home across the UAE</p>\n</div>\n\n<script>\n  const observer = new IntersectionObserver((entries) => {\n    entries.forEach(entry => {\n      if (entry.isIntersecting) {\n        const el = entry.target;\n        const delay = parseInt(el.dataset.delay || 0);\n        setTimeout(() => el.classList.add('visible'), delay);\n        observer.unobserve(el);\n      }\n    });\n  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });\n  document.querySelectorAll('[data-reveal]').forEach(el => observer.observe(el));\n</script>\n\n</body>",
