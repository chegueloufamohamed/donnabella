gin-bottom:  20px;\n    display:        block;\n  }\n\n  /* headline */\n  .db-soon__title {\n    font-family:  'Cormorant Garamond', Georgia, serif;\n    font-size:    48px;\n    font-weight:  400;\n    line-height:  1.2;\n    color:        #FAF7F2;\n    margin:       0 0 20px;\n    letter-spacing: -0.01em;\n  }\n\n  /* sub text */\n  .db-soon__text {\n    font-family:  'Lora', Georgia, serif;\n    font-size:    16px;\n    font-weight:  300;\n    font-style:   italic;\n    line-height:  1.75;\n    color:        rgba(250,247,242,0.6);\n    margin:       0 0 44px;\n  }\n\n  /* progress dots */\n  .db-soon__dots {\n    display:         flex;\n    align-items:     center;\n    justify-content: center;\n    gap:             10px;\n  }\n\n  .db-soon__dot {\n    width:         8px;\n    height:        8px;\n    border-radius: 50%;\n    background:    #C9A96E;\n    animation:     db-pulse 1.6s ease-in-out infinite;\n  }\n\n  .db-soon__dot:nth-child(2) { animation-delay: 0.3s; background: #8FAEAD; }\n  .db-soon__dot:nth-child(3) { animation-delay: 0.6s; }\n\n  @keyframes db-pulse {\n    0%, 100% { opacity: 0.3; transform: scale(0.85); }\n    50%       { opacity: 1;   transform: scale(1.1);  }\n  }\n\n  /* Arabic overrides */\n  .db-soon[dir=\"rtl\"] .db-soon__label,\n  .db-soon[dir=\"rtl\"] .db-soon__title,\n  .db-soon[dir=\"rtl\"] .db-soon__text {\n    font-family:    'Cairo', 'Tajawal', sans-serif;\n    letter-spacing: 0;\n    text-transform: none;\n    font-style:     normal;\n  }\n\n  .db-soon[dir=\"rtl\"] .db-soon__label { font-size: 13px; }\n  .db-soon[dir=\"rtl\"] .db-soon__title { font-size: 38px; font-weight: 600; }\n  .db-soon[dir=\"rtl\"] .db-soon__text  { font-size: 15px; }\n\n  /* Mobile */\n  @media (max-width: 767px) {\n    .db-soon           { min-height: 380px; padding: 64px 20px; }\n    .db-soon__title    { font-size: 34px; }\n    .db-soon[dir=\"rtl\"] .db-soon__title { font-size: 28px; }\n    .db-soon__text     { font-size: 15px; }\n  }\n</style>\n\n\n\n<