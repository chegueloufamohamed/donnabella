iewBox=\"0 0 24 24\" aria-hidden=\"true\">\n            <path d=\"M7 14c2.5 0 3.2-2 5-2s2.5 2 5 2\"></path>\n            <path d=\"M8 11c1.2 0 2-.8 2-2\"></path>\n            <path d=\"M16 11c-1.2 0-2-.8-2-2\"></path>\n            <path d=\"M6 16c1.5 2 3.5 3 6 3s4.5-1 6-3\"></path>\n          </svg>\n        </div>\n        <div class=\"db-card-title\">Sports Massage</div>\n        <div class=\"db-card-desc\">Deep tissue and sports massage to relieve muscle tension, improve recovery, and restore peak performance.</div>\n        <a class=\"db-card-arrow\" href=\"/pages/men\">\n          Explore\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M5 12h14M12 5l7 7-7 7\"></path></svg>\n        </a>\n      </div>\n\n      <div class=\"db-service-card\">\n        <div class=\"db-card-icon\">\n          <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n            <path d=\"M6 18l8-8\"></path>\n            <path d=\"M12 6l6 6\"></path>\n            <path d=\"M14 4l6 6\"></path>\n            <path d=\"M4 20l4-4\"></path>\n          </svg>\n        </div>\n        <div class=\"db-card-title\">Waxing & Grooming</div>\n        <div class=\"db-card-desc\">Clean, precise waxing for chest, back, and facial areas. Professional results with premium, skin-safe wax.</div>\n        <a class=\"db-card-arrow\" href=\"/pages/men\">\n          Explore\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M5 12h14M12 5l7 7-7 7\"></path></svg>\n        </a>\n      </div>\n\n      <div class=\"db-service-card\">\n        <div class=\"db-card-icon\">\n          <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n            <path d=\"M7 6c0-1 .8-2 1.8-2H15\"></path>\n            <path d=\"M9 4v5\"></path>\n            <path d=\"M12 4v6\"></path>\n            <path d=\"M15 4v5\"></path>\n            <path d=\"M7 10c0 5 2.5 8 5 8s5-3 5-8\"></path>\n            <path d=\"M7 10h10\"></path>\n          </svg>\n        </div>\n        <div class=\"db-card-title\">Manicure & Pedicure</div>\n        <div class=\"db-card-desc\">Clean, shaped, and polished nails with a relaxing hand and foot treatment. Grooming at its finest.</div>\n        <a class=\"db-card-arrow\" href=\"/pages/men\">\n          Explore\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M5 12h14M12 5l7 7-7 7\"></path></svg>\n        </a>\n      </div>\n\n      <div class=\"db-service-card\">\n        <div class=\"db-card-icon\">\n          <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n            <path d=\"M10 5h4\"></path>\n            <path d=\"M9 5h6v3l-1 2v8a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1v-8L9 8V5z\"></path>\n            <path d=\"M10 12h4\"></path>\n          </svg>\n        </div>\n        <div class=\"db-card-title\">Men's Facial</div>\n        <div class=\"db-card-desc\">Deep pore cleansing, exfoliation, and hydration treatments designed specifically for men's skin. Clear, healthy skin awaits.</div>\n        <a class=\"db-card-arrow\" href=\"/pages/men\">\n          Explore\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M5 12h14M12 5l7 7-7 7\"></path></svg>\n        </a>\n      </div>\n\n    </div>\n\n    <div class=\"db-section-cta\">\n      <a class=\"db-btn-primary\" href=\"/pages/men\">\n        <svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z\"></path></svg>\n        Explore All Men Services\n      </a>\n      <a class=\"db-btn-secondary\" href=\"/pages/contact?booking=men\">Book a Consultation</a>\n    </div>\n\n  </div>\n</section>\n\n</div>",
