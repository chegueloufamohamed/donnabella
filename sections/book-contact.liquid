  };

  var t = themes[gender];
  var photoEl = document.querySelector('.book-dynamic-photo-' + id);

  if (photoEl) {
    if (gender === 'women' && photoEl.dataset.photoWomen) {
      photoEl.src = photoEl.dataset.photoWomen;
    } else if (gender === 'men' && photoEl.dataset.photoMen) {
      photoEl.src = photoEl.dataset.photoMen;
    }
  }

  if (!t) return;

  var css = '\n'
    + '.book-section-' + id + '{background:' + t.sectionBg + '!important}\n'
    + '.book-blob-1-' + id + '{background:' + t.blob1 + '!important}\n'
    + '.book-blob-2-' + id + '{background:' + t.blob2 + '!important}\n'
    + '.book-blob-3-' + id + '{background:' + t.blob3 + '!important}\n'
    + '.book-heading-' + id + '{color:' + t.headingColor + '!important}\n'
    + '.book-subheading-' + id + '{color:' + t.subheadingColor + '!important}\n'
    + '.book-label-' + id + '{color:' + t.labelColor + '!important}\n'
    + '.book-glass-' + id + '{background:' + t.cardBg + '!important;border:' + t.cardBorder + '!important;box-shadow:' + t.cardShadow + '!important}\n'
    + '.book-input-' + id + ',.book-textarea-' + id + '{background:' + t.inputBg + '!important;border:' + t.inputBorder + '!important;color:' + t.inputText + '!important}\n'
    + '.book-input-' + id + ':focus,.book-textarea-' + id + ':focus{background:' + t.inputFocusBg + '!important;box-shadow:0 0 0 2px ' + t.inputFocusShadow + '!important}\n'
    + '.book-input-' + id + '::placeholder,.book-textarea-' + id + '::placeholder{color:' + t.placeholder + '!important;opacity:1!important}\n'
    + '.book-input-' + id + '[type="date"]::-webkit-calendar-picker-indicator{filter:' + t.calendarFilter + '}\n'
    + '.book-btn-' + id + '{background:' + t.btnBg + '!important;border:' + t.btnBorder + '!important;color:#fff!important}\n'
    + '.book-btn-' + id + ':hover{background:' + t.btnHoverBg + '!important;box-shadow:0 8px 30px rgba(0,0,0,0.35)!important}\n'
    + '.book-glow-border-' + id + '{background:linear-gradient(90deg,transparent 0%,transparent 10%,' + t.glowColor + ' 50%,transparent 90%,transparent 100%)!important}\n'
    + '.book-trust-' + id + '{border-top-color:' + t.trustBorder + '!important}\n'
    + '.book-trust-item-' + id + '{color:' + t.trustText + '!important}\n';

  var el = document.createElement('style');
  el.textContent = css;
  document.head.appendChild(el);
})();
</script>

