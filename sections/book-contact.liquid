{% comment %}
  Book Now Section - Two Column Layout
  Left: Photo | Right: Header + Form
  Arabic/English bilingual - auto-switches via request.locale
{% endcomment %}

{% assign current_locale = request.locale.iso_code %}
{% assign is_arabic = false %}
{% if current_locale contains 'ar' %}
  {% assign is_arabic = true %}
{% endif %}

{% assign text_dir = 'ltr' %}
{% if is_arabic %}
  {% assign text_dir = 'rtl' %}
{% endif %}

{% if is_arabic %}
  {% assign active_heading = section.settings.heading_ar | default: section.settings.heading %}
  {% assign active_subheading = section.settings.subheading_ar | default: section.settings.subheading %}
  {% assign active_button_text = section.settings.button_text_ar | default: section.settings.button_text %}
  {% assign label_name = section.settings.label_name_ar | default: "الاسم الكامل" %}
  {% assign label_phone = section.settings.label_phone_ar | default: "رقم الهاتف" %}
  {% assign label_email = section.settings.label_email_ar | default: "البريد الإلكتروني" %}
  {% assign label_date = section.settings.label_date_ar | default: "التاريخ المفضل" %}
  {% assign label_message = section.settings.label_message_ar | default: "طلبات خاصة" %}
  {% assign label_optional = section.settings.label_optional_ar | default: "(اختياري)" %}
  {% assign placeholder_name = section.settings.placeholder_name_ar | default: "أدخل اسمك" %}
  {% assign placeholder_phone = section.settings.placeholder_phone_ar | default: "+971 XX XXX XXXX" %}
  {% assign placeholder_email = section.settings.placeholder_email_ar | default: "بريدك@example.com" %}
  {% assign placeholder_message = section.settings.placeholder_message_ar | default: "أخبرينا عن أي متطلبات خاصة..." %}
  {% assign trust_1 = section.settings.trust_1_ar | default: "تأكيد فوري" %}
  {% assign trust_2 = section.settings.trust_2_ar | default: "حجز آمن" %}
  {% assign trust_3 = section.settings.trust_3_ar | default: "خدمة احترافية" %}
  {% assign active_heading_font = section.settings.heading_font_family_ar %}
  {% assign active_subheading_font = section.settings.subheading_font_family_ar %}
  {% assign active_body_font = section.settings.body_font_family_ar %}
  {% assign active_label_font = section.settings.label_font_family_ar %}
{% else %}
  {% assign active_heading = section.settings.heading %}
  {% assign active_subheading = section.settings.subheading %}
  {% assign active_button_text = section.settings.button_text | default: "Book Your Appointment" %}
  {% assign label_name = "Full Name" %}
  {% assign label_phone = "Phone Number" %}
  {% assign label_email = "Email Address" %}
  {% assign label_date = "Preferred Date" %}
  {% assign label_message = "Special Requests" %}
  {% assign label_optional = "(Optional)" %}
  {% assign placeholder_name = "Enter your name" %}
  {% assign placeholder_phone = "+971 XX XXX XXXX" %}
  {% assign placeholder_email = "your@email.com" %}
  {% assign placeholder_message = "Tell us about any specific requirements..." %}
  {% assign trust_1 = "Instant Confirmation" %}
  {% assign trust_2 = "Secure Booking" %}
  {% assign trust_3 = "Professional Service" %}
  {% assign active_heading_font = section.settings.heading_font_family %}
  {% assign active_subheading_font = section.settings.subheading_font_family %}
  {% assign active_body_font = section.settings.body_font_family %}
  {% assign active_label_font = section.settings.label_font_family %}
{% endif %}

{% assign default_photo = blank %}
{% if section.settings.photo_women != blank %}
  {% assign default_photo = section.settings.photo_women %}
{% elsif section.settings.photo_men != blank %}
  {% assign default_photo = section.settings.photo_men %}
{% endif %}

<section id="{{ section.settings.anchor_id | default: 'book-now' }}" class="book-section-{{ section.id }}" dir="{{ text_dir }}">

  <div class="book-bg-{{ section.id }}" aria-hidden="true">
    <div class="book-blob-1-{{ section.id }}"></div>
    <div class="book-blob-2-{{ section.id }}"></div>
    <div class="book-blob-3-{{ section.id }}"></div>
  </div>

  <div class="book-layout-{{ section.id }}">

    <div class="book-photo-col-{{ section.id }}">
      {% if default_photo != blank %}
        <div class="book-photo-wrap-{{ section.id }}">
          <img
            src="{{ default_photo | image_url: width: 1200 }}"
            alt="{{ section.settings.photo_alt | default: 'Booking image' }}"
            class="book-photo-{{ section.id }} book-dynamic-photo-{{ section.id }}"
            loading="eager"
            {% if section.settings.photo_women != blank %}data-photo-women="{{ section.settings.photo_women | image_url: width: 1200 }}"{% endif %}
            {% if section.settings.photo_men != blank %}data-photo-men="{{ section.settings.photo_men | image_url: width: 1200 }}"{% endif %}
          >
          {% if section.settings.photo_overlay_opacity > 0 %}
            <div class="book-photo-overlay-{{ section.id }}"></div>
          {% endif %}
        </div>
      {% else %}
        <div class="book-photo-placeholder-{{ section.id }}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="2"></rect>
            <circle cx="8.5" cy="8.5" r="1.5"></circle>
            <path d="M21 15l-5-5L5 21"></path>
          </svg>
          <span>Add a photo in settings</span>
        </div>
      {% endif %}
    </div>

    <div class="book-right-col-{{ section.id }}">

      <div class="book-header-{{ section.id }}">
        {% if active_heading != blank %}
          <h2 class="book-heading-{{ section.id }}">{{ active_heading }}</h2>
        {% endif %}
        {% if active_subheading != blank %}
          <p class="book-subheading-{{ section.id }}">{{ active_subheading }}</p>
        {% endif %}
      </div>

      <div class="book-glass-{{ section.id }}">

        {% if section.settings.enable_glow %}
          <div class="book-glow-border-{{ section.id }}" aria-hidden="true"></div>
        {% endif %}

        <form class="book-form-{{ section.id }}" action="{{ section.settings.form_action }}" method="post" accept-charset="UTF-8">

          <div class="book-row-{{ section.id }}">
            <div class="book-field-{{ section.id }}">
              <label for="book-name-{{ section.id }}" class="book-label-{{ section.id }}">{{ label_name }}</label>
              <input type="text" id="book-name-{{ section.id }}" name="name" class="book-input-{{ section.id }}" placeholder="{{ placeholder_name }}" required>
            </div>
            <div class="book-field-{{ section.id }}">
              <label for="book-phone-{{ section.id }}" class="book-label-{{ section.id }}">{{ label_phone }}</label>
              <input type="tel" id="book-phone-{{ section.id }}" name="phone" class="book-input-{{ section.id }}" placeholder="{{ placeholder_phone }}" required>
            </div>
          </div>

          <div class="book-row-{{ section.id }}">
            <div class="book-field-{{ section.id }}">
              <label for="book-email-{{ section.id }}" class="book-label-{{ section.id }}">{{ label_email }}</label>
              <input type="email" id="book-email-{{ section.id }}" name="email" class="book-input-{{ section.id }}" placeholder="{{ placeholder_email }}" required>
            </div>
            <div class="book-field-{{ section.id }}">
              <label for="book-date-{{ section.id }}" class="book-label-{{ section.id }}">{{ label_date }}</label>
              <input type="date" id="book-date-{{ section.id }}" name="date" class="book-input-{{ section.id }}" required>
            </div>
          </div>

          <div class="book-field-{{ section.id }}">
            <label for="book-message-{{ section.id }}" class="book-label-{{ section.id }}">
              {{ label_message }} <span style="opacity:0.5;font-weight:400">{{ label_optional }}</span>
            </label>
            <textarea id="book-message-{{ section.id }}" name="message" class="book-textarea-{{ section.id }}" rows="2" placeholder="{{ placeholder_message }}"></textarea>
          </div>

          <button type="submit" class="book-btn-{{ section.id }}">
            <span>{{ active_button_text }}</span>
            {% if is_arabic %}
              <span class="book-btn-arrow-{{ section.id }}">←</span>
            {% else %}
              <span class="book-btn-arrow-{{ section.id }}">→</span>
            {% endif %}
          </button>

        </form>

        {% if section.settings.show_trust_badges %}
          <div class="book-trust-{{ section.id }}">
            <div class="book-trust-item-{{ section.id }}"><span>⚡</span> {{ trust_1 }}</div>
            <div class="book-trust-item-{{ section.id }}"><span>🔒</span> {{ trust_2 }}</div>
            <div class="book-trust-item-{{ section.id }}"><span>💫</span> {{ trust_3 }}</div>
          </div>
        {% endif %}

      </div>
    </div>
  </div>

</section>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@300;400;500;600;700;800;900&family=Montserrat:wght@300;400;500;600;700;800;900&family=Merriweather:wght@300;400;700;900&family=Cormorant+Garamond:wght@300;400;500;600;700&family=Lato:wght@300;400;700;900&family=Raleway:wght@300;400;500;600;700;800;900&family=Poppins:wght@300;400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700;800;900&family=EB+Garamond:wght@400;500;600;700;800&family=Cinzel:wght@400;500;600;700;800;900&family=Crimson+Text:wght@400;600;700&family=Roboto:wght@300;400;500;700;900&family=Open+Sans:wght@300;400;600;700;800&family=Nunito:wght@300;400;600;700;800;900&family=Work+Sans:wght@300;400;500;600;700;800;900&family=Oswald:wght@300;400;500;600;700&family=Tajawal:wght@300;400;500;700;800;900&family=Cairo:wght@300;400;600;700;900&family=Almarai:wght@300;400;700;800&family=Noto+Kufi+Arabic:wght@300;400;500;600;700;800;900&display=swap');

  {% assign bg_color = section.settings.background_color %}
  {% assign bg_r = bg_color | color_extract: 'red' %}
  {% assign bg_g = bg_color | color_extract: 'green' %}
  {% assign bg_b = bg_color | color_extract: 'blue' %}
  {% assign frame_color = section.settings.frame_color %}
  {% assign frame_r = frame_color | color_extract: 'red' %}
  {% assign frame_g = frame_color | color_extract: 'green' %}
  {% assign frame_b = frame_color | color_extract: 'blue' %}
  {% assign input_bg = section.settings.input_bg_color %}
  {% assign input_r = input_bg | color_extract: 'red' %}
  {% assign input_g = input_bg | color_extract: 'green' %}
  {% assign input_b = input_bg | color_extract: 'blue' %}

  .book-section-{{ section.id }} {
    position: relative;
    width: 100%;
    min-height: {{ section.settings.section_min_height }}px;
    background: rgba({{ bg_r }}, {{ bg_g }}, {{ bg_b }}, {{ section.settings.bg_opacity_pct | divided_by: 100.0 }});
    overflow: hidden;
    display: flex;
    align-items: center;
    font-family: '{{ active_body_font }}', sans-serif;
    padding-top: {{ section.settings.section_padding_top }}px;
    padding-bottom: {{ section.settings.section_padding_bottom }}px;
  }

  {% if is_arabic %}
  .book-section-{{ section.id }} .book-header-{{ section.id }},
  .book-section-{{ section.id }} .book-heading-{{ section.id }},
  .book-section-{{ section.id }} .book-subheading-{{ section.id }},
  .book-section-{{ section.id }} .book-label-{{ section.id }},
  .book-section-{{ section.id }} .book-input-{{ section.id }},
  .book-section-{{ section.id }} .book-textarea-{{ section.id }} {
    direction: rtl !important;
    text-align: right !important;
    letter-spacing: 0 !important;
    text-transform: none !important;
  }
  {% endif %}

  .book-bg-{{ section.id }} {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .book-blob-1-{{ section.id }},
  .book-blob-2-{{ section.id }},
  .book-blob-3-{{ section.id }} {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: {{ section.settings.blob_opacity | divided_by: 100.0 }};
    animation: blobFloat-{{ section.id }} 20s ease-in-out infinite;
  }

  .book-blob-1-{{ section.id }} {
    width: 420px;
    height: 420px;
    background: {{ section.settings.blob_1_color }};
    top: -120px;
    left: -100px;
  }

  .book-blob-2-{{ section.id }} {
    width: 360px;
    height: 360px;
    background: {{ section.settings.blob_2_color }};
    bottom: -80px;
    right: -80px;
    animation-delay: -7s;
  }

  .book-blob-3-{{ section.id }} {
    width: 280px;
    height: 280px;
    background: {{ section.settings.blob_3_color }};
    top: 40%;
    right: 15%;
    animation-delay: -13s;
  }

  @keyframes blobFloat-{{ section.id }} {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(20px, -30px) scale(0.95); }
  }

  .book-layout-{{ section.id }} {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 30px;
    display: grid;
    grid-template-columns: {{ section.settings.photo_col_width }}fr {{ 100 | minus: section.settings.photo_col_width }}fr;
    gap: {{ section.settings.column_gap }}px;
    align-items: stretch;
  }

  .book-photo-col-{{ section.id }} {
    position: relative;
    min-width: 0;
    min-height: {{ section.settings.photo_min_height }}px;
    max-height: {{ section.settings.photo_max_height }}px;
    display: flex;
    flex-direction: column;
  }

  .book-photo-wrap-{{ section.id }} {
    position: relative;
    width: 100%;
    flex: 1;
    border-radius: {{ section.settings.photo_radius }}px;
    overflow: hidden;
    {% if section.settings.photo_shadow %}
    box-shadow: {{ section.settings.photo_shadow_x }}px {{ section.settings.photo_shadow_y }}px {{ section.settings.photo_shadow_blur }}px rgba(0,0,0,{{ section.settings.photo_shadow_opacity | divided_by: 100.0 }});
    {% endif %}
  }

  .book-photo-{{ section.id }} {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.photo_fit }};
    object-position: {{ section.settings.photo_position }};
    display: block;
    {% if section.settings.photo_scale != 100 %}
    transform: scale({{ section.settings.photo_scale | divided_by: 100.0 }});
    transform-origin: {{ section.settings.photo_position }};
    {% endif %}
  }

  {% if section.settings.photo_overlay_opacity > 0 %}
  .book-photo-overlay-{{ section.id }} {
    position: absolute;
    inset: 0;
    background: {{ section.settings.photo_overlay_color }};
    opacity: {{ section.settings.photo_overlay_opacity | divided_by: 100.0 }};
    pointer-events: none;
  }
  {% endif %}

  .book-photo-placeholder-{{ section.id }} {
    flex: 1;
    min-height: {{ section.settings.photo_min_height }}px;
    background: rgba({{ frame_r }}, {{ frame_g }}, {{ frame_b }}, 0.3);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    color: {{ section.settings.heading_color }};
    opacity: 0.4;
    border-radius: {{ section.settings.photo_radius }}px;
    overflow: hidden;
  }

  .book-photo-placeholder-{{ section.id }} svg {
    width: 48px;
    height: 48px;
  }

  .book-photo-placeholder-{{ section.id }} span {
    font-size: 13px;
  }

  .book-right-col-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.header_form_gap }}px;
    align-self: center;
    min-width: 0;
  }

  .book-header-{{ section.id }} {
    background: none !important;
    border: none !important;
    box-shadow: none !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  .book-heading-{{ section.id }} {
    font-family: '{{ active_heading_font }}', serif;
    font-size: clamp(22px, 2.8vw, {{ section.settings.heading_size }}px);
    font-weight: {{ section.settings.heading_weight }};
    letter-spacing: {{ section.settings.heading_letter_spacing }}px;
    color: {{ section.settings.heading_color }};
    margin: 0 0 8px;
    line-height: 1.15;
  }

  .book-subheading-{{ section.id }} {
    font-family: '{{ active_subheading_font }}', sans-serif;
    font-size: clamp(13px, 1.1vw, {{ section.settings.subheading_size }}px);
    font-weight: {{ section.settings.subheading_weight }};
    letter-spacing: {{ section.settings.subheading_letter_spacing }}px;
    color: {{ section.settings.subheading_color }};
    margin: 0;
    line-height: 1.5;
    opacity: 0.8;
  }

  .book-glass-{{ section.id }} {
    position: relative;
    background: rgba({{ frame_r }}, {{ frame_g }}, {{ frame_b }}, {{ section.settings.frame_opacity_pct | divided_by: 100.0 }});
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border-radius: {{ section.settings.frame_radius }}px;
    padding: {{ section.settings.form_padding }}px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.1);
    overflow: hidden;
    flex-shrink: 0;
  }

  {% if section.settings.enable_glow %}
  .book-glow-border-{{ section.id }} {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 2px;
    background: linear-gradient(90deg, transparent 0%, transparent 10%, {{ section.settings.glow_color }} 50%, transparent 90%, transparent 100%);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    animation: glowMove-{{ section.id }} {{ section.settings.glow_speed }}s linear infinite;
    pointer-events: none;
    opacity: {{ section.settings.glow_opacity | divided_by: 100.0 }};
  }

  @keyframes glowMove-{{ section.id }} {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }
  {% endif %}

  .book-form-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .book-row-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .book-field-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .book-label-{{ section.id }} {
    font-family: '{{ active_label_font }}', sans-serif;
    font-size: {{ section.settings.label_font_size }}px;
    font-weight: {{ section.settings.label_font_weight }};
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: {{ section.settings.label_color }};
  }

  .book-input-{{ section.id }},
  .book-textarea-{{ section.id }} {
    padding: 9px 13px;
    background: rgba({{ input_r }}, {{ input_g }}, {{ input_b }}, {{ section.settings.input_opacity_pct | divided_by: 100.0 }});
    border: none;
    border-radius: 8px;
    font-size: {{ section.settings.input_font_size }}px;
    font-family: '{{ active_body_font }}', sans-serif;
    color: {{ section.settings.input_text_color }};
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    width: 100%;
    box-sizing: border-box;
  }

  {% if section.settings.enable_glow %}
  .book-input-{{ section.id }}:focus,
  .book-textarea-{{ section.id }}:focus {
    outline: none;
    background: rgba({{ input_r }}, {{ input_g }}, {{ input_b }}, {{ section.settings.input_focus_opacity_pct | divided_by: 100.0 }});
    box-shadow: 0 0 0 2px {{ section.settings.glow_color }};
    transform: translateY(-1px);
  }
  {% else %}
  .book-input-{{ section.id }}:focus,
  .book-textarea-{{ section.id }}:focus {
    outline: none;
    background: rgba({{ input_r }}, {{ input_g }}, {{ input_b }}, {{ section.settings.input_focus_opacity_pct | divided_by: 100.0 }});
    transform: translateY(-1px);
  }
  {% endif %}

  .book-input-{{ section.id }}::placeholder,
  .book-textarea-{{ section.id }}::placeholder {
    color: {{ section.settings.placeholder_color }};
    opacity: 0.45;
  }

  .book-textarea-{{ section.id }} {
    resize: none;
    min-height: 56px;
  }

  .book-btn-{{ section.id }} {
    width: 100%;
    padding: 12px 24px;
    background: {{ section.settings.button_bg_color }};
    color: {{ section.settings.button_text_color }};
    border: none;
    border-radius: 8px;
    font-size: {{ section.settings.button_font_size }}px;
    font-weight: {{ section.settings.button_font_weight }};
    font-family: '{{ active_body_font }}', sans-serif;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    transition: transform 0.25s, box-shadow 0.25s, background 0.25s;
    margin-top: 2px;
  }

  .book-btn-{{ section.id }}:hover {
    background: {{ section.settings.button_hover_color }};
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0,0,0,0.18);
  }

  .book-btn-arrow-{{ section.id }} {
    font-size: 17px;
    transition: transform 0.25s;
  }

  {% if is_arabic %}
  .book-btn-{{ section.id }}:hover .book-btn-arrow-{{ section.id }} {
    transform: translateX(-4px);
  }
  {% else %}
  .book-btn-{{ section.id }}:hover .book-btn-arrow-{{ section.id }} {
    transform: translateX(4px);
  }
  {% endif %}

  .book-trust-{{ section.id }} {
    display: flex;
    justify-content: center;
    gap: 18px;
    padding-top: 14px;
    margin-top: 4px;
    border-top: 1px solid {{ section.settings.trust_border_color }};
    flex-wrap: wrap;
  }

  .book-trust-item-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    font-weight: 500;
    font-family: '{{ active_body_font }}', sans-serif;
    color: {{ section.settings.trust_text_color }};
    opacity: 0.75;
  }

  @media (max-width: 768px) {
    .book-section-{{ section.id }} {
      padding-top: {{ section.settings.section_padding_top_mobile }}px;
      padding-bottom: {{ section.settings.section_padding_bottom_mobile }}px;
    }

    .book-layout-{{ section.id }} {
      grid-template-columns: 1fr;
      padding: 0 20px;
      gap: 24px;
      align-items: start;
    }

    .book-photo-col-{{ section.id }} {
      min-height: 260px;
      max-height: 320px;
    }

    .book-photo-wrap-{{ section.id }} {
      border-radius: {{ section.settings.photo_radius | times: 0.7 | round }}px;
    }

    .book-right-col-{{ section.id }} {
      height: auto;
    }

    .book-row-{{ section.id }} {
      grid-template-columns: 1fr;
    }

    .book-heading-{{ section.id }} {
      font-size: {{ section.settings.heading_size | times: 0.7 }}px;
    }

    .book-subheading-{{ section.id }} {
      font-size: {{ section.settings.subheading_size | times: 0.9 }}px;
    }
  }
</style>

<script>
(function () {
  var id = '{{ section.id }}';
  var bookingParam = new URLSearchParams(window.location.search).get('booking');
  var gender = bookingParam === 'men' ? 'men' : 'women';

  if (!id) return;

  var themes = {
    women: {
      sectionBg: [
        'radial-gradient(ellipse 80% 60% at 20% 50%, rgba(255,182,193,0.22) 0%, transparent 60%)',
