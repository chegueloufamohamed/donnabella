{% assign current_locale = request.locale.iso_code %}
{% assign is_arabic = false %}
{% if current_locale contains 'ar' %}
  {% assign is_arabic = true %}
{% endif %}
{% assign text_dir = 'ltr' %}
{% if is_arabic %}
  {% assign text_dir = 'rtl' %}
{% endif %}

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Jost:wght@200;300;400;500;600;700&family=Cairo:wght@300;400;600;700;900&family=Tajawal:wght@300;400;500;700;800;900&display=swap" rel="stylesheet">

<style>
.ma-wrap *, .ma-wrap *::before, .ma-wrap *::after { box-sizing: border-box; margin: 0; padding: 0; }

.ma-wrap {
  --bg:        #3d5060;
  --bg-dark:   #2f3d4d;
  --bg-darker: #202c38;
  --bg-light:  #4d6275;
  --gold:      #c9a96e;
  --gold-dim:  rgba(201,169,110,0.18);
  --gold-line: rgba(201,169,110,0.35);
  --white:     #ffffff;
  --white-80:  rgba(255,255,255,0.8);
  --white-60:  rgba(255,255,255,0.6);
  --white-40:  rgba(255,255,255,0.4);
  --white-20:  rgba(255,255,255,0.12);
  --white-10:  rgba(255,255,255,0.06);
  --glass:     rgba(255,255,255,0.06);
  --glass-b:   rgba(255,255,255,0.12);
  --serif:  'Cormorant Garamond', Georgia, serif;
  --sans:   'Jost', sans-serif;
  --arabic: 'Cairo', 'Tajawal', sans-serif;
  font-family: {% if is_arabic %}var(--arabic){% else %}var(--sans){% endif %};
  font-weight: 300;
  color: var(--white);
  overflow-x: hidden;
  line-height: 1.6;
  background-color: var(--bg);
  direction: {{ text_dir }};
}

@keyframes ma-fadeUp   { to { opacity: 1; transform: translateY(0); } }
@keyframes ma-fadeIn   { to { opacity: 1; } }
@keyframes ma-ringPulse {
  0%,100%{ opacity:0.3; transform:translate(-50%,-50%) scale(1); }
  50%    { opacity:0.7; transform:translate(-50%,-50%) scale(1.06); }
}
@keyframes ma-scrollLine { 0%{transform:scaleY(0);opacity:0;} 50%{opacity:1;} 100%{transform:scaleY(1);opacity:0;} }
@keyframes ma-glowSlide { 0%{left:-100%;} 100%{left:200%;} }

.ma-hero {
  position: relative; min-height: 100vh;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  text-align: center; padding: 100px 40px 80px;
  overflow: hidden;
}
.ma-hero-bg {
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 80% 60% at 20% 40%, rgba(201,169,110,0.08) 0%, transparent 60%),
    radial-gradient(ellipse 60% 70% at 80% 70%, rgba(77,98,117,0.4) 0%, transparent 60%),
    linear-gradient(180deg, var(--bg-darker) 0%, var(--bg) 50%, var(--bg-dark) 100%);
  pointer-events: none;
}
.ma-hero-ring {
  position: absolute; border-radius: 50%;
  border: 1px solid var(--gold-line);
  top: 50%; left: 50%; transform: translate(-50%,-50%);
  pointer-events: none; animation: ma-ringPulse 5s ease-in-out infinite;
}
.ma-hero-ring-1 { width: 600px; height: 600px; animation-delay: 0s; opacity: 0.25; }
.ma-hero-ring-2 { width: 860px; height: 860px; animation-delay: 1.5s; opacity: 0.12; }
.ma-hero-ring-3 { width: 1100px; height: 1100px; animation-delay: 3s; opacity: 0.06; }
.ma-hero-content { position: relative; z-index: 2; max-width: 900px; }
.ma-hero-tag {
  display: inline-flex; align-items: center; gap: 12px;
  font-size: {% if is_arabic %}13px{% else %}10px{% endif %};
  font-weight: 500;
  letter-spacing: {% if is_arabic %}0{% else %}0.45em{% endif %};
  {% unless is_arabic %}text-transform: uppercase;{% endunless %}
  color: var(--gold); margin-bottom: 32px;
  opacity: 0; transform: translateY(16px);
  animation: ma-fadeUp 0.9s ease 0.3s forwards;
}
.ma-hero-tag::before, .ma-hero-tag::after {
  content: ''; display: block; width: 40px; height: 1px; background: var(--gold-line);
}
.ma-hero-title {
  font-family: {% if is_arabic %}var(--arabic){% else %}var(--serif){% endif %};
  font-size: clamp(44px, 9vw, 110px);
  font-weight: {% if is_arabic %}600{% else %}300{% endif %};
  line-height: {% if is_arabic %}1.3{% else %}0.95{% endif %};
  {% unless is_arabic %}letter-spacing: -0.02em; font-style: normal;{% endunless %}
  color: var(--white); margin-bottom: 32px;
  opacity: 0; transform: translateY(24px);
  animation: ma-fadeUp 1s ease 0.5s forwards;
}
.ma-hero-title em { font-style: italic; color: var(--gold); {% if is_arabic %}font-style: normal;{% endif %} }
.ma-hero-title strong { font-weight: {% if is_arabic %}700{% else %}500{% endif %}; display: block; }
.ma-hero-sub {
  font-size: {% if is_arabic %}15px{% else %}13px{% endif %};
  font-weight: 300;
  letter-spacing: {% if is_arabic %}0{% else %}0.15em{% endif %};
  {% unless is_arabic %}text-transform: uppercase;{% endunless %}
  color: var(--white-60); margin-bottom: 52px; line-height: 1.8;
  opacity: 0; transform: translateY(16px);
  animation: ma-fadeUp 0.9s ease 0.7s forwards;
}
.ma-hero-btns {
  display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;
  opacity: 0; animation: ma-fadeUp 0.9s ease 0.9s forwards;
}
.ma-btn-primary {
  padding: 16px 44px; background: var(--gold); color: var(--bg-darker);
  font-size: {% if is_arabic %}13px{% else %}11px{% endif %};
  font-weight: 600;
  letter-spacing: {% if is_arabic %}0{% else %}0.35em{% endif %};
  {% unless is_arabic %}text-transform: uppercase;{% endunless %}
  text-decoration: none; position: relative; overflow: hidden;
  transition: all 0.35s ease; display: inline-block;
  font-family: {% if is_arabic %}var(--arabic){% else %}var(--sans){% endif %};
}
.ma-btn-primary::after {
  content: ''; position: absolute; top: 0; left: -100%; width: 60%; height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
  animation: ma-glowSlide 3s ease-in-out infinite;
}
.ma-btn-primary:hover { background: #d4b87e; transform: translateY(-2px); box-shadow: 0 12px 40px rgba(201,169,110,0.35); }
.ma-btn-outline {
  padding: 16px 44px; border: 1px solid var(--glass-b);
  color: var(--white-80);
  font-size: {% if is_arabic %}13px{% else %}11px{% endif %};
  font-weight: 400;
  letter-spacing: {% if is_arabic %}0{% else %}0.35em{% endif %};
  {% unless is_arabic %}text-transform: uppercase;{% endunless %}
  text-decoration: none; transition: all 0.3s ease; display: inline-block;
  font-family: {% if is_arabic %}var(--arabic){% else %}var(--sans){% endif %};
}
.ma-btn-outline:hover { border-color: var(--gold-line); color: var(--gold); background: var(--gold-dim); }
.ma-scroll-hint {
  position: absolute; bottom: 48px; left: 50%; transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center; gap: 10px;
  opacity: 0; animation: ma-fadeIn 1s ease 1.5s forwards;
}
.ma-scroll-hint span {
  font-size: 9px; letter-spacing: 0.4em; text-transform: uppercase; color: var(--white-40);
}
.ma-scroll-line {
  width: 1px; height: 48px;
  background: linear-gradient(to bottom, var(--gold), transparent);
  animation: ma-scrollLine 2s ease-in-out infinite;
}

.ma-inner { max-width: 1200px; margin: 0 auto; padding: 0 40px; }
.ma-sec-label {
  display: flex; align-items: center; gap: 18px; margin-bottom: 56px;
  opacity: 0; transform: translateX({% if is_arabic %}20px{% else %}-20px{% endif %});
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.ma-sec-label.ma-visible { opacity: 1; transform: translateX(0); }
.ma-sec-label-text {
  font-size: {% if is_arabic %}12px{% else %}10px{% endif %};
  font-weight: 500;
  letter-spacing: {% if is_arabic %}0{% else %}0.45em{% endif %};
  {% unless is_arabic %}text-transform: uppercase;{% endunless %}
  color: var(--gold); white-space: nowrap;
}
.ma-sec-label-line { flex: 1; height: 1px; background: linear-gradient(to {% if is_arabic %}left{% else %}right{% endif %}, var(--gold-line), transparent); }

.ma-stats-bar { background: var(--bg-dark); border-top: 1px solid var(--white-10); border-bottom: 1px solid var(--white-10); padding: 48px 0; }
.ma-stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); }
.ma-stat-item { text-align: center; padding: 0 24px; border-{% if is_arabic %}left{% else %}right{% endif %}: 1px solid var(--white-10); opacity: 0; transform: translateY(16px); transition: opacity 0.6s ease, transform 0.6s ease; }
.ma-stat-item:last-child { border: none; }
.ma-stat-item.ma-visible { opacity: 1; transform: translateY(0); }
.ma-stat-num { font-family: var(--serif); font-size: 52px; font-weight: 300; color: var(--white); line-height: 1; margin-bottom: 6px; }
.ma-stat-num em { font-style: normal; color: var(--gold); }
.ma-stat-label { font-size: {% if is_arabic %}12px{% else %}10px{% endif %}; font-weight: 400; letter-spacing: {% if is_arabic %}0{% else %}0.3em{% endif %}; {% unless is_arabic %}text-transform: uppercase;{% endunless %} color: var(--white-40); }

.ma-services-sec { padding: 100px 0; }
.ma-services-intro { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: end; margin-bottom: 72px; }
.ma-services-title { font-family: {% if is_arabic %}var(--arabic){% else %}var(--serif){% endif %}; font-size: clamp(32px, 5vw, 64px); font-weight: {% if is_arabic %}600{% else %}300{% endif %}; line-height: {% if is_arabic %}1.4{% else %}1.1{% endif %}; opacity: 0; transform: translateY(20px); transition: opacity 0.8s ease, transform 0.8s ease; }
.ma-services-title.ma-visible { opacity: 1; transform: translateY(0); }
.ma-services-title em { font-style: {% if is_arabic %}normal{% else %}italic{% endif %}; color: var(--gold); }
.ma-services-desc { font-size: 14px; line-height: 1.9; color: var(--white-60); opacity: 0; transform: translateY(16px); transition: opacity 0.8s ease 0.2s, transform 0.8s ease 0.2s; }
.ma-services-desc.ma-visible { opacity: 1; transform: translateY(0); }
.ma-services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; }
.ma-svc-card { background: var(--glass); border: 1px solid var(--glass-b); padding: 44px 36px 40px; position: relative; overflow: hidden; cursor: default; opacity: 0; transform: translateY(30px); transition: opacity 0.7s ease, transform 0.7s ease, background 0.4s, border-color 0.4s; }
.ma-svc-card.ma-visible { opacity: 1; transform: translateY(0); }
.ma-svc-card:hover { background: rgba(255,255,255,0.1); border-color: var(--gold-line); }
.ma-svc-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(to right, transparent, var(--gold), transparent); opacity: 0; transition: opacity 0.4s; }
.ma-svc-card:hover::before { opacity: 1; }
.ma-svc-num { font-family: var(--serif); font-size: 80px; font-weight: 300; color: rgba(201,169,110,0.08); line-height: 1; position: absolute; top: 16px; {% if is_arabic %}left{% else %}right{% endif %}: 24px; user-select: none; transition: color 0.4s; }
.ma-svc-card:hover .ma-svc-num { color: rgba(201,169,110,0.18); }
.ma-svc-icon { width: 48px; height: 48px; margin-bottom: 24px; border: 1px solid var(--gold-line); display: flex; align-items: center; justify-content: center; font-size: 20px; color: var(--gold); transition: transform 0.4s ease; }
.ma-svc-card:hover .ma-svc-icon { transform: rotate(-6deg) scale(1.1); }
.ma-svc-name { font-family: {% if is_arabic %}var(--arabic){% else %}var(--serif){% endif %}; font-size: {% if is_arabic %}20px{% else %}24px{% endif %}; font-weight: {% if is_arabic %}600{% else %}400{% endif %}; color: var(--white); margin-bottom: 8px; line-height: 1.3; }
.ma-svc-sub { font-family: {% if is_arabic %}var(--arabic){% else %}var(--serif){% endif %}; font-style: {% if is_arabic %}normal{% else %}italic{% endif %}; font-size: 13px; color: var(--gold); margin-bottom: 16px; opacity: 0.85; }
.ma-svc-desc { font-size: 12.5px; line-height: 1.75; color: var(--white-60); }
.ma-svc-card-wide { grid-column: span 3; display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: 48px; padding: 40px 44px; }
.ma-svc-card-wide .ma-svc-name { font-size: {% if is_arabic %}22px{% else %}28px{% endif %}; }

.ma-why-sec { padding: 100px 0; background: var(--bg-dark); border-top: 1px solid var(--white-10); border-bottom: 1px solid var(--white-10); }
.ma-why-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
.ma-why-tagline { font-family: {% if is_arabic %}var(--arabic){% else %}var(--serif){% endif %}; font-size: clamp(30px, 5vw, 60px); font-weight: {% if is_arabic %}600{% else %}300{% endif %}; line-height: {% if is_arabic %}1.4{% else %}1.15{% endif %}; margin-bottom: 28px; opacity: 0; transform: translateY(20px); transition: opacity 0.8s ease, transform 0.8s ease; }
.ma-why-tagline.ma-visible { opacity: 1; transform: translateY(0); }
.ma-why-tagline em { font-style: {% if is_arabic %}normal{% else %}italic{% endif %}; color: var(--gold); display: block; }
.ma-why-body { font-size: 14px; line-height: 1.9; color: var(--white-60); margin-bottom: 36px; opacity: 0; transition: opacity 0.8s ease 0.2s; }
.ma-why-body.ma-visible { opacity: 1; }
.ma-why-points { display: flex; flex-direction: column; gap: 16px; }
.ma-why-point { display: flex; gap: 16px; align-items: flex-start; opacity: 0; transform: translateX({% if is_arabic %}16px{% else %}-16px{% endif %}); transition: opacity 0.6s ease, transform 0.6s ease; }
.ma-why-point.ma-visible { opacity: 1; transform: translateX(0); }
.ma-why-dot { width: 32px; height: 32px; flex-shrink: 0; border: 1px solid var(--gold-line); display: flex; align-items: center; justify-content: center; font-size: 14px; color: var(--gold); }
.ma-why-point-text strong { display: block; font-size: 13px; font-weight: 500; color: var(--white); margin-bottom: 3px; }
.ma-why-point-text span { font-size: 12px; color: var(--white-60); }
.ma-why-right { display: flex; flex-direction: column; gap: 2px; }
.ma-why-card { background: var(--glass); border: 1px solid var(--glass-b); padding: 28px 32px; display: flex; gap: 20px; align-items: flex-start; opacity: 0; transform: translateX({% if is_arabic %}-20px{% else %}20px{% endif %}); transition: opacity 0.6s ease, transform 0.6s ease, background 0.3s; }
.ma-why-card.ma-visible { opacity: 1; transform: translateX(0); }
.ma-why-card:hover { background: rgba(255,255,255,0.09); }
.ma-why-card-num { font-family: var(--serif); font-size: 28px; font-weight: 300; color: var(--gold); opacity: 0.4; flex-shrink: 0; line-height: 1; }
.ma-why-card-title { font-family: {% if is_arabic %}var(--arabic){% else %}var(--serif){% endif %}; font-size: 18px; font-weight: {% if is_arabic %}600{% else %}400{% endif %}; color: var(--white); margin-bottom: 4px; }
.ma-why-card-desc { font-size: 12px; color: var(--white-60); line-height: 1.7; }

.ma-industries-sec { padding: 80px 0; background: var(--bg-darker); border-top: 1px solid var(--white-10); }
.ma-industries-label { text-align: center; font-size: {% if is_arabic %}13px{% else %}10px{% endif %}; font-weight: 500; letter-spacing: {% if is_arabic %}0{% else %}0.45em{% endif %}; {% unless is_arabic %}text-transform: uppercase;{% endunless %} color: var(--gold); margin-bottom: 48px; }
.ma-industries-scroll { display: flex; gap: 2px; overflow-x: auto; scrollbar-width: none; {% if is_arabic %}direction: rtl;{% endif %} }
.ma-industries-scroll::-webkit-scrollbar { display: none; }
.ma-industry-tag { flex-shrink: 0; padding: 20px 32px; border: 1px solid var(--glass-b); background: var(--glass); font-family: {% if is_arabic %}var(--arabic){% else %}var(--serif){% endif %}; font-size: 18px; font-weight: {% if is_arabic %}500{% else %}400{% endif %}; color: var(--white-60); white-space: nowrap; transition: all 0.3s ease; cursor: default; }
.ma-industry-tag:hover, .ma-industry-tag.ma-featured { border-color: var(--gold-line); color: var(--gold); background: var(--gold-dim); }

.ma-process-sec { padding: 100px 0; }
.ma-process-title { font-family: {% if is_arabic %}var(--arabic){% else %}var(--serif){% endif %}; font-size: clamp(32px, 5vw, 60px); font-weight: {% if is_arabic %}600{% else %}300{% endif %}; line-height: {% if is_arabic %}1.4{% else %}1.2{% endif %}; text-align: center; margin-bottom: 72px; opacity: 0; transform: translateY(20px); transition: opacity 0.8s ease, transform 0.8s ease; }
.ma-process-title.ma-visible { opacity: 1; transform: translateY(0); }
.ma-process-title em { font-style: {% if is_arabic %}normal{% else %}italic{% endif %}; color: var(--gold); }
.ma-process-track { position: relative; display: grid; grid-template-columns: repeat(5, 1fr); gap: 2px; }
.ma-process-track::before { content: ''; position: absolute; top: 48px; left: 10%; right: 10%; height: 1px; background: linear-gradient(to right, transparent, var(--gold-line) 20%, var(--gold-line) 80%, transparent); z-index: 0; }
.ma-process-step { text-align: center; padding: 0 16px 40px; position: relative; z-index: 1; opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
.ma-process-step.ma-visible { opacity: 1; transform: translateY(0); }
.ma-process-circle { width: 80px; height: 80px; border-radius: 50%; border: 1px solid var(--gold-line); background: var(--bg-dark); display: flex; align-items: center; justify-content: center; margin: 0 auto 24px; font-family: var(--serif); font-size: 28px; font-weight: 300; color: var(--gold); transition: background 0.3s, border-color 0.3s; }
.ma-process-step:hover .ma-process-circle { background: var(--gold-dim); border-color: var(--gold); }
.ma-process-name { font-family: {% if is_arabic %}var(--arabic){% else %}var(--serif){% endif %}; font-size: {% if is_arabic %}15px{% else %}17px{% endif %}; font-weight: {% if is_arabic %}600{% else %}400{% endif %}; color: var(--white); margin-bottom: 8px; }
.ma-process-desc { font-size: 11.5px; color: var(--white-60); line-height: 1.7; }

.ma-results-sec { padding: 100px 0; }
.ma-results-card { position: relative; background: linear-gradient(135deg, rgba(201,169,110,0.14) 0%, rgba(201,169,110,0.04) 100%); border: 1px solid var(--gold-line); padding: 72px 80px; display: grid; grid-template-columns: 1fr auto; gap: 60px; align-items: center; overflow: hidden; opacity: 0; transform: translateY(24px); transition: opacity 0.7s ease, transform 0.7s ease; }
.ma-results-card.ma-visible { opacity: 1; transform: translateY(0); }
.ma-results-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(to right, transparent 10%, var(--gold) 50%, transparent 90%); }
.ma-results-card::after { content: '"'; position: absolute; font-family: var(--serif); font-size: 280px; font-weight: 300; font-style: italic; color: rgba(201,169,110,0.06); line-height: 1; top: -20px; {% if is_arabic %}left{% else %}right{% endif %}: 40px; pointer-events: none; }
.ma-results-badge { position: absolute; top: 20px; {% if is_arabic %}right{% else %}left{% endif %}: 32px; background: var(--gold); color: var(--bg-darker); font-size: 9px; font-weight: 600; letter-spacing: {% if is_arabic %}0{% else %}0.3em{% endif %}; {% unless is_arabic %}text-transform: uppercase;{% endunless %} padding: 6px 14px; font-family: {% if is_arabic %}var(--arabic){% else %}var(--sans){% endif %}; }
.ma-results-title { font-family: {% if is_arabic %}var(--arabic){% else %}var(--serif){% endif %}; font-size: clamp(24px, 4vw, 46px); font-weight: {% if is_arabic %}600{% else %}300{% endif %}; line-height: {% if is_arabic %}1.4{% else %}1.2{% endif %}; margin-bottom: 8px; }
.ma-results-sub { font-family: {% if is_arabic %}var(--arabic){% else %}var(--serif){% endif %}; font-style: {% if is_arabic %}normal{% else %}italic{% endif %}; font-size: 15px; color: var(--gold); margin-bottom: 20px; }
.ma-results-body { font-size: 14px; color: var(--white-60); line-height: 1.8; }
.ma-results-numbers { display: flex; flex-direction: column; gap: 28px; flex-shrink: 0; }
.ma-result-num { text-align: center; border: 1px solid var(--gold-line); padding: 20px 32px; background: rgba(201,169,110,0.06); }
.ma-result-num-val { font-family: var(--serif); font-size: 42px; font-weight: 300; color: var(--white); line-height: 1; }
.ma-result-num-val em { font-style: normal; color: var(--gold); }
.ma-result-num-label { font-size: {% if is_arabic %}11px{% else %}10px{% endif %}; letter-spacing: {% if is_arabic %}0{% else %}0.25em{% endif %}; {% unless is_arabic %}text-transform: uppercase;{% endunless %} color: var(--white-40); margin-top: 5px; font-family: {% if is_arabic %}var(--arabic){% else %}var(--sans){% endif %}; }

.ma-testi-sec { padding: 100px 0; background: var(--bg-dark); border-top: 1px solid var(--white-10); }
.ma-testi-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; }
.ma-testi-card { background: var(--glass); border: 1px solid var(--glass-b); padding: 40px 36px; opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease, background 0.3s; }
.ma-testi-card.ma-visible { opacity: 1; transform: translateY(0); }
.ma-testi-card:hover { background: rgba(255,255,255,0.09); }
.ma-testi-stars { color: var(--gold); font-size: 14px; letter-spacing: 3px; margin-bottom: 20px; }
.ma-testi-text { font-family: {% if is_arabic %}var(--arabic){% else %}var(--serif){% endif %}; font-style: {% if is_arabic %}normal{% else %}italic{% endif %}; font-size: {% if is_arabic %}15px{% else %}17px{% endif %}; font-weight: 300; line-height: 1.7; color: var(--white-80); margin-bottom: 28px; }
.ma-testi-divider { height: 1px; background: var(--white-10); margin-bottom: 20px; }
