  .ma-process-track::before { display: none; }
  .ma-testi-grid { grid-template-columns: 1fr 1fr; }
  .ma-results-card { grid-template-columns: 1fr; }
  .ma-results-numbers { flex-direction: row; justify-content: center; }
}
@media (max-width: 768px) {
  .ma-hero-title { font-size: 44px; }
