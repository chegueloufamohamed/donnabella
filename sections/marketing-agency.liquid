.ma-cta-ring { position: absolute; border-radius: 50%; border: 1px solid var(--gold-line); top: 50%; left: 50%; transform: translate(-50%,-50%); pointer-events: none; animation: ma-ringPulse 4s ease-in-out infinite; }
.ma-cta-ring-1 { width: 500px; height: 500px; opacity: 0.15; }
.ma-cta-ring-2 { width: 750px; height: 750px; opacity: 0.07; animation-delay: 2s; }
.ma-cta-content { position: relative; z-index: 2; }
.ma-cta-eyebrow { font-size: {% if is_arabic %}13px{% else %}10px{% endif %}; font-weight: 500; letter-spacing: {% if is_arabic %}0{% else %}0.5em{% endif %}; {% unless is_arabic %}text-transform: uppercase;{% endunless %} color: var(--gold); margin-bottom: 28px; opacity: 0; transition: opacity 0.8s ease; }
.ma-cta-eyebrow.ma-visible { opacity: 1; }
.ma-cta-title { font-family: {% if is_arabic %}var(--arabic){% else %}var(--serif){% endif %}; font-size: clamp(36px, 6vw, 80px); font-weight: {% if is_arabic %}600{% else %}300{% endif %}; line-height: {% if is_arabic %}1.4{% else %}1.05{% endif %}; margin-bottom: 24px; opacity: 0; transform: translateY(20px); transition: opacity 0.8s ease 0.1s, transform 0.8s ease 0.1s; }
.ma-cta-title.ma-visible { opacity: 1; transform: translateY(0); }
.ma-cta-title em { font-style: {% if is_arabic %}normal{% else %}italic{% endif %}; color: var(--gold); display: block; }
.ma-cta-sub { font-size: {% if is_arabic %}14px{% else %}13px{% endif %}; color: var(--white-60); letter-spacing: {% if is_arabic %}0{% else %}0.12em{% endif %}; {% unless is_arabic %}text-transform: uppercase;{% endunless %} margin-bottom: 52px; opacity: 0; transition: opacity 0.8s ease 0.2s; }
.ma-cta-sub.ma-visible { opacity: 1; }
.ma-cta-btns { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; opacity: 0; transition: opacity 0.8s ease 0.3s; }
.ma-cta-btns.ma-visible { opacity: 1; }
.ma-cta-note { margin-top: 28px; font-size: 11px; color: var(--white-40); letter-spacing: 0.15em; opacity: 0; transition: opacity 0.8s ease 0.4s; }
.ma-cta-note.ma-visible { opacity: 1; }

@media (max-width: 1024px) {
  .ma-services-intro { grid-template-columns: 1fr; gap: 32px; }
