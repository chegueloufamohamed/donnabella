  .ma-services-grid { grid-template-columns: 1fr; }
  .ma-svc-card-wide { grid-template-columns: 1fr; gap: 20px; }
  .ma-testi-grid { grid-template-columns: 1fr; }
  .ma-process-track { grid-template-columns: 1fr 1fr; }
  .ma-results-card { padding: 48px 32px; }
  .ma-inner { padding: 0 20px; }
}
