    <div class="ma-industries-label">{% if is_arabic %}قطاعات التجميل التي نخدمها{% else %}Beauty Verticals We Serve{% endif %}</div>
    <div class="ma-industries-scroll">
      {% if is_arabic %}
        <div class="ma-industry-tag ma-featured">صالونات نساء</div>
        <div class="ma-industry-tag">صالونات رجال</div>
        <div class="ma-industry-tag ma-featured">مساج وسبا</div>
        <div class="ma-industry-tag">استوديوهات أظافر</div>
        <div class="ma-industry-tag">عيادات التجميل</div>
        <div class="ma-industry-tag ma-featured">بلو-دراي بارز</div>
        <div class="ma-industry-tag">استوديوهات رموش وحواجب</div>
        <div class="ma-industry-tag">مراكز العافية</div>
        <div class="ma-industry-tag">عيادات زراعة الشعر</div>
        <div class="ma-industry-tag ma-featured">خدمات التجميل المنزلية</div>
        <div class="ma-industry-tag">صالات العرائس</div>
        <div class="ma-industry-tag">ميدي سبا</div>
      {% else %}
        <div class="ma-industry-tag ma-featured">Ladies Salons</div>
        <div class="ma-industry-tag">Gents Salons</div>
        <div class="ma-industry-tag ma-featured">Massage & Spa</div>
        <div class="ma-industry-tag">Nail Studios</div>
        <div class="ma-industry-tag">Aesthetic Clinics</div>
        <div class="ma-industry-tag ma-featured">Blow-Dry Bars</div>
        <div class="ma-industry-tag">Lash & Brow Studios</div>
        <div class="ma-industry-tag">Wellness Centers</div>
        <div class="ma-industry-tag">Hair Transplant Clinics</div>
        <div class="ma-industry-tag ma-featured">Home Beauty Services</div>
        <div class="ma-industry-tag">Bridal Suites</div>
        <div class="ma-industry-tag">Medi-Spas</div>
      {% endif %}
