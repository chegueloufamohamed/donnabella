<!-- ── PROCESS ── -->
<section class="ma-process-sec" id="ma-process">
  <div class="ma-inner">
    <div class="ma-sec-label" data-ma-reveal style="justify-content:center;margin-bottom:24px">
      <div class="ma-sec-label-line" style="max-width:60px"></div>
      <span class="ma-sec-label-text">{% if is_arabic %}كيف نعمل{% else %}How We Work{% endif %}</span>
      <div class="ma-sec-label-line" style="max-width:60px"></div>
    </div>
    <h2 class="ma-process-title" data-ma-reveal>
      {% if is_arabic %}من أول مكالمة إلى <em>النمو الكامل</em><br>في خمس خطوات{% else %}From first call to <em>full growth</em><br>in five steps{% endif %}
    </h2>
    <div class="ma-process-track">
      <div class="ma-process-step" data-ma-reveal>
        <div class="ma-process-circle">1</div>
        <div class="ma-process-name">{% if is_arabic %}مكالمة الاكتشاف{% else %}Discovery Call{% endif %}</div>
        <div class="ma-process-desc">{% if is_arabic %}نتعرف على صالونك وأهدافك وتسويقك الحالي ومنافسيك. مجاناً، بلا التزام، 45 دقيقة.{% else %}We learn your salon, your goals, your current marketing, and your competition. Free, no obligation, 45 minutes.{% endif %}</div>
      </div>
      <div class="ma-process-step" data-ma-reveal style="transition-delay:0.1s">
        <div class="ma-process-circle">2</div>
        <div class="ma-process-name">{% if is_arabic %}التدقيق والاستراتيجية{% else %}Audit & Strategy{% endif %}</div>
        <div class="ma-process-desc">{% if is_arabic %}تدقيق شامل لحضورك الرقمي وإعلاناتك وتقييماتك ومنافسيك. خارطة طريق نمو مخصصة لـ 90 يوماً خلال 5 أيام.{% else %}Full audit of your online presence, ads, reviews, and competitors. A custom 90-day growth roadmap delivered within 5 days.{% endif %}</div>
      </div>
      <div class="ma-process-step" data-ma-reveal style="transition-delay:0.2s">
        <div class="ma-process-circle">3</div>
        <div class="ma-process-name">{% if is_arabic %}العلامة والإبداع{% else %}Brand & Creative{% endif %}</div>
        <div class="ma-process-desc">{% if is_arabic %}نجدد أو نبني أصول علامتك وخطة المحتوى والإعلانات الإبداعية. صالونك يحصل على مظهر متسق ومميز فوراً.{% else %}We refresh or build your brand assets, content calendar, and ad creative. Your salon gets a consistent, elevated look immediately.{% endif %}</div>
      </div>
      <div class="ma-process-step" data-ma-reveal style="transition-delay:0.3s">
        <div class="ma-process-circle">4</div>
        <div class="ma-process-name">{% if is_arabic %}الإطلاق والتوسع{% else %}Launch & Scale{% endif %}</div>
        <div class="ma-process-desc">{% if is_arabic %}تنطلق الحملات. ندير ونُحسّن ونُكيّف في الوقت الفعلي بناءً على ما يحقق الحجوزات وما لا يفعل.{% else %}Campaigns go live. We manage, optimise, and iterate in real time based on what's driving bookings and what isn't.{% endif %}</div>
      </div>
      <div class="ma-process-step" data-ma-reveal style="transition-delay:0.4s">
        <div class="ma-process-circle">5</div>
        <div class="ma-process-name">{% if is_arabic %}التقرير والنمو{% else %}Report & Grow{% endif %}</div>
        <div class="ma-process-desc">{% if is_arabic %}مراجعات أداء شهرية ومقاييس واضحة. نضع أهداف الشهر القادم معاً ونرفع السقف في كل دورة.{% else %}Monthly performance reviews. Clear metrics. We set next month's targets together and raise the bar every cycle.{% endif %}</div>
      </div>
    </div>
  </div>
</section>

<!-- ── RESULTS ── -->
<section class="ma-results-sec" id="ma-results">
  <div class="ma-inner">
    <div class="ma-sec-label" data-ma-reveal>
      <span class="ma-sec-label-text">{% if is_arabic %}نتائج عملائنا{% else %}Client Results{% endif %}</span>
      <div class="ma-sec-label-line"></div>
    </div>
    <div class="ma-results-card" data-ma-reveal>
      <div class="ma-results-badge">{% if is_arabic %}دراسة حالة{% else %}Case Study{% endif %}</div>
      <div>
        <div class="ma-results-title">{% if is_arabic %}كيف ضاعف صالون نسائي في دبي حجوزاته الشهرية ثلاث مرات{% else %}How a Dubai ladies salon tripled its monthly bookings{% endif %}</div>
        <div class="ma-results-sub">{% if is_arabic %}في أقل من ستة أشهر، بلا تخفيضات في الأسعار{% else %}in under six months, with no price discounting{% endif %}</div>
        <div class="ma-results-body">{% if is_arabic %}جاءنا صالون نسائي متوسط الحجم في جميرا بخدمات ممتازة وحضور رقمي ضعيف. لا موقع إلكتروني، إنستغرام غير منتظم، وصفر إعلانات مدفوعة. خلال 90 يوماً من إطلاق استراتيجيتنا التسويقية الشاملة — السوشيال والإعلانات والسيو وواتساب — ارتفعت حجوزاتهم من 180 إلى 540 شهرياً. تحسّن الاحتفاظ بنسبة 44%. وارتفع تقييمهم على جوجل من 3.9 إلى 4.8 نجوم.{% else %}A mid-size ladies salon in Jumeirah came to us with strong services and a weak online presence. No website, inconsistent Instagram, and zero paid ads. Within 90 days of launching our full-stack marketing strategy — social, ads, SEO, and WhatsApp CRM — they went from 180 to 540 bookings per month. Retention improved by 44%. Their Google rating climbed from 3.9 to 4.8 stars.{% endif %}</div>
      </div>
      <div class="ma-results-numbers">
        <div class="ma-result-num">
          <div class="ma-result-num-val">3<em>×</em></div>
          <div class="ma-result-num-label">{% if is_arabic %}الحجوزات الشهرية{% else %}Monthly Bookings{% endif %}</div>
        </div>
        <div class="ma-result-num">
          <div class="ma-result-num-val">4.8<em>★</em></div>
          <div class="ma-result-num-label">{% if is_arabic %}تقييم جوجل{% else %}Google Rating{% endif %}</div>
        </div>
        <div class="ma-result-num">
          <div class="ma-result-num-val">44<em>%</em></div>
          <div class="ma-result-num-label">{% if is_arabic %}تحسن الاحتفاظ{% else %}Retention Uplift{% endif %}</div>
        </div>
      </div>
    </div>
  </div>
</section>

