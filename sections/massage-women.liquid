      <span class="mw-list-num">06</span>
      <div class="mw-list-body">
        <h3 class="mw-list-title">{% if is_arabic %}تصريف الليمفاوي{% else %}Lymphatic Drainage{% endif %}</h3>
        <p class="mw-list-sub">{% if is_arabic %}تخلصي مما يُثقل كاهلكِ{% else %}Release what weighs you down{% endif %}</p>
