{% comment %}
  Massage — Women — Belladona Care
  Bilingual section: auto-detects EN/AR via request.locale
  Save as: sections/massage-women.liquid
  Add to page via: Customize → Page → Add section → Massage Women
{% endcomment %}

{% assign current_locale = request.locale.iso_code %}
{% assign is_arabic = false %}
{% if current_locale contains 'ar' %}
  {% assign is_arabic = true %}
{% endif %}

{% assign dir = 'ltr' %}
{% if is_arabic %}
  {% assign dir = 'rtl' %}
{% endif %}



<div class="mw-{{ section.id }}" dir="{{ dir }}">
<style>
  .mw-{{ section.id }} .mw-mini-icon,
.mw-{{ section.id }} .mw-prenatal-icon,
.mw-{{ section.id }} .mw-dur-icon {
  display: none !important;
  font-size: 0 !important;
  line-height: 0 !important;
}
  .mw-{{ section.id }} {
    --bg:        {{ section.settings.bg_color }};
    --bg-dark:   #2f3d4d;
    --bg-light:  #4d6275;
    --gold:      {{ section.settings.gold_color }};
    --gold-dim:  rgba(201,169,110,0.18);
    --gold-line: rgba(201,169,110,0.35);
    --white:     #ffffff;
    --white-60:  rgba(255,255,255,0.6);
    --white-20:  rgba(255,255,255,0.08);
    --white-10:  rgba(255,255,255,0.05);
    --glass:     rgba(255,255,255,0.06);
    --glass-b:   rgba(255,255,255,0.12);
    --serif:  'Cormorant Garamond', Georgia, serif;
    --sans: 'Montserrat', sans-serif;
    --arabic: 'Tajawal', sans-serif;
    --font-main:    {% if is_arabic %}var(--arabic){% else %}var(--sans){% endif %};
    --font-display: {% if is_arabic %}'Cairo', sans-serif{% else %}var(--serif){% endif %};
    background-color: var(--bg);
    color: var(--white);
    font-family: var(--font-main);
    font-weight: 300;
    overflow-x: hidden;
    min-height: 100vh;
  }

  @keyframes mw-fadeUp-{{ section.id }} { to { opacity: 1; transform: translateY(0); } }
  @keyframes mw-ring-{{ section.id }} {
    0%,100% { opacity: 0.4; transform: translate(-50%,-50%) scale(1); }
    50%      { opacity: 0.8; transform: translate(-50%,-50%) scale(1.04); }
  }

  /* ── HERO ── */
  .mw-{{ section.id }} .mw-hero {
    position: relative; min-height: 58vh;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center; padding: 80px 30px 60px; overflow: hidden;
  }
  .mw-{{ section.id }} .mw-hero::before {
    content: ''; position: absolute; width: 600px; height: 600px; border-radius: 50%;
    background: radial-gradient(circle, rgba(201,169,110,0.1) 0%, transparent 70%);
    top: 50%; left: 50%; transform: translate(-50%,-50%); pointer-events: none;
  }
  .mw-{{ section.id }} .mw-hero::after {
    content: ''; position: absolute; width: 380px; height: 380px; border-radius: 50%;
    border: 1px solid var(--gold-line); top: 50%; left: 50%;
    transform: translate(-50%,-50%); pointer-events: none;
    animation: mw-ring-{{ section.id }} 4s ease-in-out infinite;
  }
  .mw-{{ section.id }} .mw-eyebrow {
    font-size: 11px; font-weight: 500;
    letter-spacing: {% if is_arabic %}0.05em{% else %}0.4em{% endif %};
    {% unless is_arabic %}text-transform: uppercase;{% endunless %}
    color: var(--gold); margin-bottom: 20px; position: relative; z-index: 1;
    opacity: 0; transform: translateY(16px);
    animation: mw-fadeUp-{{ section.id }} 0.8s ease 0.2s forwards;
  }
  .mw-{{ section.id }} .mw-title {
    font-family: var(--font-display);
    font-size: clamp(52px, 9vw, 100px);
    font-weight: {% if is_arabic %}400{% else %}300{% endif %};
    font-style: {% if is_arabic %}normal{% else %}italic{% endif %};
    line-height: {% if is_arabic %}1.2{% else %}0.95{% endif %};
    letter-spacing: {% if is_arabic %}0{% else %}-0.01em{% endif %};
    color: var(--white); position: relative; z-index: 1;
    opacity: 0; transform: translateY(20px);
    animation: mw-fadeUp-{{ section.id }} 0.9s ease 0.4s forwards;
  }
  .mw-{{ section.id }} .mw-title span { color: var(--gold); font-style: normal; font-weight: 500; }
  .mw-{{ section.id }} .mw-desc {
    margin-top: 26px; font-size: 13px;
    letter-spacing: {% if is_arabic %}0.05em{% else %}0.12em{% endif %};
    {% unless is_arabic %}text-transform: uppercase;{% endunless %}
    color: var(--white-60); position: relative; z-index: 1;
    opacity: 0; transform: translateY(16px);
    animation: mw-fadeUp-{{ section.id }} 0.9s ease 0.6s forwards;
  }
  .mw-{{ section.id }} .mw-divider {
    margin-top: 40px; width: 1px; height: 60px;
    background: linear-gradient(to bottom, var(--gold), transparent);
    opacity: 0; animation: mw-fadeUp-{{ section.id }} 0.9s ease 0.8s forwards;
  }

  /* ── LAYOUT ── */
  .mw-{{ section.id }} .mw-section { position: relative; z-index: 1; padding: 60px 0 80px; }
  .mw-{{ section.id }} .mw-section + .mw-section { padding-top: 20px; }
  .mw-{{ section.id }} .mw-inner { max-width: 1160px; margin: 0 auto; padding: 0 30px; }

  /* ── SECTION LABEL ── */
  .mw-{{ section.id }} .mw-label {
    display: flex; align-items: center; gap: 18px; margin-bottom: 50px;
    opacity: 0;
    transform: translateX({% if is_arabic %}20px{% else %}-20px{% endif %});
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .mw-{{ section.id }} .mw-label.visible { opacity: 1; transform: translateX(0); }
  .mw-{{ section.id }} .mw-label-line {
    flex: 1; height: 1px;
    background: linear-gradient(to {% if is_arabic %}left{% else %}right{% endif %}, var(--gold-line), transparent);
  }
  .mw-{{ section.id }} .mw-label-text {
    font-size: 10px; font-weight: 500;
    letter-spacing: {% if is_arabic %}0.05em{% else %}0.45em{% endif %};
    {% unless is_arabic %}text-transform: uppercase;{% endunless %}
    color: var(--gold); white-space: nowrap;
  }

  /* ── COUPLE CARDS ── */
  .mw-{{ section.id }} .mw-couples-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 2px; margin-bottom: 2px; }
  .mw-{{ section.id }} .mw-couple-card {
    position: relative; background: var(--glass); border: 1px solid var(--glass-b);
    padding: 44px 36px 40px; overflow: hidden; cursor: default;
    opacity: 0; transform: translateY(30px);
    transition: opacity 0.7s ease, transform 0.7s ease, background 0.4s, border-color 0.4s;
  }
  .mw-{{ section.id }} .mw-couple-card.visible { opacity: 1; transform: translateY(0); }
  .mw-{{ section.id }} .mw-couple-card:hover { background: rgba(255,255,255,0.1); border-color: var(--gold-line); }
  .mw-{{ section.id }} .mw-couple-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(to right, transparent, var(--gold), transparent);
    opacity: 0; transition: opacity 0.4s;
  }
  .mw-{{ section.id }} .mw-couple-card:hover::before { opacity: 1; }
  .mw-{{ section.id }} .mw-card-num {
    font-family: var(--serif); font-size: 72px; font-weight: 300;
    color: rgba(201,169,110,0.1); line-height: 1; position: absolute; top: 20px;
    {% if is_arabic %}left{% else %}right{% endif %}: 24px;
    user-select: none; transition: color 0.4s;
  }
  .mw-{{ section.id }} .mw-couple-card:hover .mw-card-num { color: rgba(201,169,110,0.2); }
  .mw-{{ section.id }} .mw-card-tag {
    font-size: 9px; font-weight: 500;
    letter-spacing: {% if is_arabic %}0.05em{% else %}0.4em{% endif %};
    {% unless is_arabic %}text-transform: uppercase;{% endunless %}
    color: var(--gold); margin-bottom: 14px;
  }
  .mw-{{ section.id }} .mw-card-title { font-family: var(--font-display); font-size: 26px; font-weight: {% if is_arabic %}500{% else %}400{% endif %}; line-height: 1.2; margin-bottom: 8px; color: var(--white); }
  .mw-{{ section.id }} .mw-card-sub { font-family: var(--font-display); font-style: {% if is_arabic %}normal{% else %}italic{% endif %}; font-size: 13px; color: var(--gold); margin-bottom: 16px; opacity: 0.9; }
  .mw-{{ section.id }} .mw-card-desc { font-size: 12.5px; line-height: 1.75; color: var(--white-60); margin-bottom: 28px; }
  .mw-{{ section.id }} .mw-card-footer { display: flex; align-items: flex-end; justify-content: space-between; border-top: 1px solid var(--glass-b); padding-top: 18px; margin-top: auto; }
  .mw-{{ section.id }} .mw-card-price { font-family: var(--serif); font-size: 32px; font-weight: 300; color: var(--white); }
  .mw-{{ section.id }} .mw-card-price sup { font-size: 14px; font-family: var(--sans); font-weight: 300; vertical-align: super; opacity: 0.7; }
  .mw-{{ section.id }} .mw-card-dur { font-size: 11px; letter-spacing: 0.1em; color: var(--white-60); text-align: {% if is_arabic %}start{% else %}right{% endif %}; }
  .mw-{{ section.id }} .mw-dur-icon { display: block; color: var(--gold); font-size: 14px; margin-bottom: 3px; text-align: {% if is_arabic %}start{% else %}right{% endif %}; }

  /* ── LIST CARDS ── */
  .mw-{{ section.id }} .mw-list-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 2px; }
  .mw-{{ section.id }} .mw-list-card {
    position: relative; background: var(--glass); border: 1px solid var(--glass-b);
    padding: 32px 32px 28px; display: flex; gap: 22px; align-items: flex-start;
    overflow: hidden; cursor: default;
    opacity: 0; transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease, background 0.3s, border-color 0.3s;
  }
  .mw-{{ section.id }} .mw-list-card.visible { opacity: 1; transform: translateY(0); }
  .mw-{{ section.id }} .mw-list-card:hover { background: rgba(255,255,255,0.09); border-color: var(--gold-line); }
  .mw-{{ section.id }} .mw-list-num {
    font-family: var(--serif); font-size: 36px; font-weight: 300;
    color: var(--gold); opacity: 0.35; line-height: 1;
    flex-shrink: 0; min-width: 38px; transition: opacity 0.3s;
  }
  .mw-{{ section.id }} .mw-list-card:hover .mw-list-num { opacity: 0.7; }
  .mw-{{ section.id }} .mw-list-body { flex: 1; min-width: 0; }
  .mw-{{ section.id }} .mw-list-title { font-family: var(--font-display); font-size: 20px; font-weight: {% if is_arabic %}500{% else %}400{% endif %}; color: var(--white); margin-bottom: 4px; line-height: 1.2; }
  .mw-{{ section.id }} .mw-list-sub { font-family: var(--font-display); font-style: {% if is_arabic %}normal{% else %}italic{% endif %}; font-size: 12px; color: var(--gold); margin-bottom: 10px; opacity: 0.85; }
  .mw-{{ section.id }} .mw-list-desc { font-size: 12px; line-height: 1.7; color: var(--white-60); margin-bottom: 18px; }
  .mw-{{ section.id }} .mw-list-meta { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
  .mw-{{ section.id }} .mw-list-price { font-family: var(--serif); font-size: 24px; font-weight: 300; color: var(--white); }
  .mw-{{ section.id }} .mw-list-price sup { font-size: 11px; font-family: var(--sans); vertical-align: super; opacity: 0.7; }
  .mw-{{ section.id }} .mw-list-dur { font-size: 10px; letter-spacing: 0.1em; color: var(--white-60); text-align: {% if is_arabic %}start{% else %}right{% endif %}; line-height: 1.5; }
  .mw-{{ section.id }} .mw-dur-dot { display: inline-block; width: 5px; height: 5px; border-radius: 50%; background: var(--gold); opacity: 0.5; margin-{% if is_arabic %}left{% else %}right{% endif %}: 5px; vertical-align: middle; }

  /* ── WIDE CARDS ── */
  .mw-{{ section.id }} .mw-wide-card {
    background: var(--glass); border: 1px solid var(--glass-b);
    padding: 36px 40px; display: grid; grid-template-columns: 1fr 1fr auto;
    gap: 40px; align-items: center;
    opacity: 0; transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease, background 0.3s, border-color 0.3s;
    cursor: default;
  }
  .mw-{{ section.id }} .mw-wide-card + .mw-wide-card { border-top: none; }
  .mw-{{ section.id }} .mw-wide-card.visible { opacity: 1; transform: translateY(0); }
  .mw-{{ section.id }} .mw-wide-card:hover { background: rgba(255,255,255,0.09); border-color: var(--gold-line); }
  .mw-{{ section.id }} .mw-wide-title { font-family: var(--font-display); font-size: 22px; font-weight: {% if is_arabic %}500{% else %}400{% endif %}; color: var(--white); margin-bottom: 4px; }
  .mw-{{ section.id }} .mw-wide-sub { font-family: var(--font-display); font-style: {% if is_arabic %}normal{% else %}italic{% endif %}; font-size: 12px; color: var(--gold); opacity: 0.85; }
  .mw-{{ section.id }} .mw-wide-desc { font-size: 12px; line-height: 1.7; color: var(--white-60); }
  .mw-{{ section.id }} .mw-wide-right { text-align: {% if is_arabic %}start{% else %}right{% endif %}; }
  .mw-{{ section.id }} .mw-wide-price { font-family: var(--serif); font-size: 28px; font-weight: 300; color: var(--white); }
  .mw-{{ section.id }} .mw-wide-price sup { font-size: 12px; font-family: var(--sans); vertical-align: super; opacity: 0.7; }
  .mw-{{ section.id }} .mw-wide-dur { font-size: 10px; color: var(--white-60); margin-top: 4px; letter-spacing: 0.08em; }

  /* ── MINI CARDS ── */
  .mw-{{ section.id }} .mw-mini-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 2px; }
  .mw-{{ section.id }} .mw-mini-card {
    background: var(--glass); border: 1px solid var(--glass-b);
    padding: 30px 26px; text-align: center;
    opacity: 0; transform: translateY(16px);
    transition: opacity 0.6s ease, transform 0.6s ease, background 0.3s, border-color 0.3s;
    cursor: default;
  }
  .mw-{{ section.id }} .mw-mini-card.visible { opacity: 1; transform: translateY(0); }
  .mw-{{ section.id }} .mw-mini-card:hover { background: rgba(255,255,255,0.1); border-color: var(--gold-line); }
  .mw-{{ section.id }} .mw-mini-icon { font-size: 24px; margin-bottom: 12px; display: block; }
  .mw-{{ section.id }} .mw-mini-title { font-family: var(--font-display); font-size: 18px; font-weight: {% if is_arabic %}500{% else %}400{% endif %}; color: var(--white); margin-bottom: 6px; line-height: 1.2; }
  .mw-{{ section.id }} .mw-mini-sub { font-family: var(--font-display); font-style: {% if is_arabic %}normal{% else %}italic{% endif %}; font-size: 11px; color: var(--gold); margin-bottom: 10px; opacity: 0.85; }
  .mw-{{ section.id }} .mw-mini-desc { font-size: 11.5px; line-height: 1.65; color: var(--white-60); margin-bottom: 18px; }
  .mw-{{ section.id }} .mw-mini-price { font-family: var(--serif); font-size: 26px; font-weight: 300; color: var(--white); }
  .mw-{{ section.id }} .mw-mini-price sup { font-size: 11px; font-family: var(--sans); vertical-align: super; opacity: 0.7; }
  .mw-{{ section.id }} .mw-mini-dur { font-size: 10px; color: var(--white-60); margin-top: 5px; letter-spacing: 0.06em; }

  /* ── PRENATAL BANNER ── */
  .mw-{{ section.id }} .mw-prenatal {
    background: linear-gradient(to {% if is_arabic %}left{% else %}right{% endif %}, var(--bg-dark), var(--bg-light), var(--bg-dark));
    border: 1px solid var(--glass-b);
    border-{% if is_arabic %}right{% else %}left{% endif %}: 3px solid var(--gold);
    padding: 36px 40px; display: flex; align-items: center; gap: 30px;
    opacity: 0; transform: translateY(20px);
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .mw-{{ section.id }} .mw-prenatal.visible { opacity: 1; transform: translateY(0); }
  .mw-{{ section.id }} .mw-prenatal-icon { font-size: 40px; flex-shrink: 0; }
  .mw-{{ section.id }} .mw-prenatal-content { flex: 1; }
  .mw-{{ section.id }} .mw-prenatal-title { font-family: var(--font-display); font-size: 24px; font-weight: {% if is_arabic %}500{% else %}400{% endif %}; color: var(--white); margin-bottom: 4px; }
  .mw-{{ section.id }} .mw-prenatal-sub { font-family: var(--font-display); font-style: {% if is_arabic %}normal{% else %}italic{% endif %}; font-size: 12px; color: var(--gold); margin-bottom: 10px; }
  .mw-{{ section.id }} .mw-prenatal-desc { font-size: 12px; line-height: 1.7; color: var(--white-60); }
  .mw-{{ section.id }} .mw-prenatal-right { text-align: {% if is_arabic %}start{% else %}right{% endif %}; flex-shrink: 0; }
  .mw-{{ section.id }} .mw-prenatal-from {
    font-size: 9px; letter-spacing: {% if is_arabic %}0.05em{% else %}0.3em{% endif %};
    {% unless is_arabic %}text-transform: uppercase;{% endunless %}
    color: var(--gold); margin-bottom: 4px;
  }
  .mw-{{ section.id }} .mw-prenatal-price { font-family: var(--serif); font-size: 36px; font-weight: 300; color: var(--white); }
  .mw-{{ section.id }} .mw-prenatal-price sup { font-size: 14px; font-family: var(--sans); vertical-align: super; opacity: 0.7; }
  .mw-{{ section.id }} .mw-prenatal-dur { font-size: 10px; color: var(--white-60); margin-top: 4px; }

  /* ── HIGHLIGHT / PACKAGE ── */
  .mw-{{ section.id }} .mw-highlight {
    position: relative;
    background: linear-gradient(135deg, rgba(201,169,110,0.14) 0%, rgba(201,169,110,0.04) 100%);
    border: 1px solid var(--gold-line);
    padding: 48px 48px 42px; display: grid; grid-template-columns: 1fr auto;
    gap: 30px; align-items: center; overflow: hidden;
    opacity: 0; transform: translateY(24px);
    transition: opacity 0.7s ease, transform 0.7s ease, background 0.4s;
    cursor: default;
  }
  .mw-{{ section.id }} .mw-highlight.visible { opacity: 1; transform: translateY(0); }
  .mw-{{ section.id }} .mw-highlight:hover { background: linear-gradient(135deg, rgba(201,169,110,0.2) 0%, rgba(201,169,110,0.07) 100%); }
  .mw-{{ section.id }} .mw-highlight::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(to right, transparent 10%, var(--gold) 50%, transparent 90%); }
  .mw-{{ section.id }} .mw-highlight-badge {
    position: absolute; top: 18px;
    {% if is_arabic %}left{% else %}right{% endif %}: 18px;
    background: var(--gold); color: var(--bg-dark);
    font-size: 9px; font-weight: 600;
    letter-spacing: {% if is_arabic %}0.05em{% else %}0.3em{% endif %};
    {% unless is_arabic %}text-transform: uppercase;{% endunless %}
    padding: 5px 12px; border-radius: 20px;
  }
  .mw-{{ section.id }} .mw-highlight-title { font-family: var(--font-display); font-size: 34px; font-weight: {% if is_arabic %}500{% else %}400{% endif %}; color: var(--white); line-height: 1.15; margin-bottom: 6px; }
  .mw-{{ section.id }} .mw-highlight-sub { font-family: var(--font-display); font-style: {% if is_arabic %}normal{% else %}italic{% endif %}; font-size: 14px; color: var(--gold); margin-bottom: 14px; }
  .mw-{{ section.id }} .mw-highlight-desc { font-size: 13px; line-height: 1.75; color: var(--white-60); }
  .mw-{{ section.id }} .mw-highlight-right { text-align: {% if is_arabic %}start{% else %}right{% endif %}; flex-shrink: 0; }
  .mw-{{ section.id }} .mw-highlight-label {
    font-size: 9px; letter-spacing: {% if is_arabic %}0.05em{% else %}0.35em{% endif %};
    {% unless is_arabic %}text-transform: uppercase;{% endunless %}
    color: var(--gold); margin-bottom: 6px;
  }
  .mw-{{ section.id }} .mw-highlight-price { font-family: var(--serif); font-size: 52px; font-weight: 300; color: var(--white); line-height: 1; }
  .mw-{{ section.id }} .mw-highlight-price sup { font-size: 18px; font-family: var(--sans); vertical-align: super; opacity: 0.7; }
  .mw-{{ section.id }} .mw-highlight-dur { margin-top: 10px; font-size: 11px; color: var(--white-60); letter-spacing: 0.08em; }

  /* ── BOTTOM ── */
  .mw-{{ section.id }} .mw-bottom { text-align: center; padding: 80px 30px 100px; position: relative; z-index: 1; opacity: 0; transform: translateY(20px); transition: opacity 0.9s ease, transform 0.9s ease; }
  .mw-{{ section.id }} .mw-bottom.visible { opacity: 1; transform: translateY(0); }
  .mw-{{ section.id }} .mw-bottom-line { display: flex; align-items: center; justify-content: center; gap: 20px; margin-bottom: 30px; }
  .mw-{{ section.id }} .mw-bottom-rule { width: 60px; height: 1px; background: var(--gold-line); }
  .mw-{{ section.id }} .mw-bottom-diamond { color: var(--gold); font-size: 10px; }
  .mw-{{ section.id }} .mw-bottom h2 { font-family: var(--font-display); font-size: clamp(30px, 5vw, 56px); font-weight: 300; font-style: {% if is_arabic %}normal{% else %}italic{% endif %}; color: var(--white); line-height: 1.2; margin-bottom: 16px; }
  .mw-{{ section.id }} .mw-bottom p { font-size: 12px; letter-spacing: {% if is_arabic %}0.05em{% else %}0.2em{% endif %}; {% unless is_arabic %}text-transform: uppercase;{% endunless %} color: var(--white-60); }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .mw-{{ section.id }} .mw-couples-grid { grid-template-columns: 1fr; }
    .mw-{{ section.id }} .mw-list-grid    { grid-template-columns: 1fr; }
    .mw-{{ section.id }} .mw-mini-grid    { grid-template-columns: 1fr 1fr; }
    .mw-{{ section.id }} .mw-highlight    { grid-template-columns: 1fr; }
    .mw-{{ section.id }} .mw-highlight-right { text-align: start; }
    .mw-{{ section.id }} .mw-wide-card    { grid-template-columns: 1fr; gap: 16px; }
    .mw-{{ section.id }} .mw-wide-right   { text-align: start; }
    .mw-{{ section.id }} .mw-prenatal     { flex-direction: column; text-align: center; }
    .mw-{{ section.id }} .mw-prenatal-right { text-align: center; }
  }
  @media (max-width: 580px) {
    .mw-{{ section.id }} .mw-mini-grid   { grid-template-columns: 1fr; }
    .mw-{{ section.id }} .mw-couple-card { padding: 32px 24px; }
  }
</style>

<!-- ════════ HERO ════════ -->
<section class="mw-hero">
  <p class="mw-eyebrow">{% if is_arabic %}{{ section.settings.eyebrow_ar }}{% else %}{{ section.settings.eyebrow_en }}{% endif %}</p>
  <h1 class="mw-title">
    {% if is_arabic %}فن<br><span>اللمسة الشافية</span>
    {% else %}The Art of<br><span>Healing Touch</span>
    {% endif %}
  </h1>
  <p class="mw-desc">{% if is_arabic %}علاجات تدليك فاخرة · خدمة منزلية{% else %}Premium Massage Therapies · Home Service{% endif %}</p>
  <div class="mw-divider"></div>
</section>

<!-- ════════ COUPLES MASSAGES ════════ -->
<section class="mw-section"><div class="mw-inner">
  <div class="mw-label" data-mw-reveal>
    <span class="mw-label-text">{% if is_arabic %}للزوجين{% else %}For Two{% endif %}</span>
    <div class="mw-label-line"></div>
  </div>

  <div class="mw-couples-grid">

    <!-- Couple Massage -->
    <div class="mw-couple-card" data-mw-reveal data-delay="0">
      <span class="mw-card-num">01</span>
      <p class="mw-card-tag">{% if is_arabic %}للزوجين · مساج{% else %}Couples · Massage{% endif %}</p>
      <h2 class="mw-card-title">{% if is_arabic %}مساج للزوجين{% else %}Couple Massage{% endif %}</h2>
      <p class="mw-card-sub">{% if is_arabic %}هدوء مشترك، سكينة راقية{% else %}Shared stillness, Elevated serenity{% endif %}</p>
      <p class="mw-card-desc">{% if is_arabic %}تجربة راقية للثنائي تجمع بين الإطالة اللطيفة وتقنيات الضغط لتحرير التوتر واستعادة التوازن. تُؤدَّى جنباً إلى جنب في أجواء هادئة، وتمنح استرخاءً عميقاً ولحظة مشتركة رائعة من العافية.{% else %}A refined experience for two, combining gentle stretching and pressure techniques to release tension and restore balance. Performed side by side in a serene setting, it offers deep relaxation and a beautifully shared moment of well-being.{% endif %}</p>
      <div class="mw-card-footer">
        <div class="mw-card-price"><sup>AED </sup>550</div>
        <div class="mw-card-dur"><span class="mw-dur-icon">◷</span>{% if is_arabic %}ساعتان{% else %}2 Hours{% endif %}</div>
      </div>
    </div>

    <!-- Couple Deep Tissue -->
    <div class="mw-couple-card" data-mw-reveal data-delay="100">
      <span class="mw-card-num">02</span>
      <p class="mw-card-tag">{% if is_arabic %}للزوجين · أنسجة عميقة{% else %}Couples · Deep Tissue{% endif %}</p>
      <h2 class="mw-card-title">{% if is_arabic %}تدليك أنسجة عميقة<br>للزوجين{% else %}Couple Deep Tissue<br>Massage{% endif %}</h2>
      <p class="mw-card-sub">{% if is_arabic %}علاج راقٍ للثنائي{% else %}Elevated therapy for two{% endif %}</p>
      <p class="mw-card-desc">{% if is_arabic %}جنباً إلى جنب، تُحرِّر التقنيات الدقيقة والقوية التوتر العضلي العميق وتُعيد التوازن في أجواء تسودها الأناقة الهادئة.{% else %}Side by side, firm and precise techniques release deep muscle tension and restore balance within an atmosphere of quiet elegance.{% endif %}</p>
      <div class="mw-card-footer">
        <div class="mw-card-price"><sup>AED </sup>550</div>
        <div class="mw-card-dur"><span class="mw-dur-icon">◷</span>{% if is_arabic %}ساعتان{% else %}2 Hours{% endif %}</div>
      </div>
    </div>

    <!-- Couple Swedish -->
    <div class="mw-couple-card" data-mw-reveal data-delay="200">
      <span class="mw-card-num">03</span>
      <p class="mw-card-tag">{% if is_arabic %}للزوجين · سويدي{% else %}Couples · Swedish{% endif %}</p>
      <h2 class="mw-card-title">{% if is_arabic %}تدليك سويدي<br>للزوجين{% else %}Couple Swedish<br>Massage{% endif %}</h2>
      <p class="mw-card-sub">{% if is_arabic %}لحظة أنيقة للثنائي{% else %}An elegant pause for two{% endif %}</p>
      <p class="mw-card-desc">{% if is_arabic %}حركات ناعمة وسلسة تُخفف التوتر وتُعيد التوازن بينما تسترخيان جنباً إلى جنب في راحة راقية — تتركانكما هادئَين ومنتعشَين بلا أدنى جهد.{% else %}Gentle, flowing strokes ease tension and restore balance as you unwind side by side in refined comfort — leaving you both calm, refreshed, and effortlessly at ease.{% endif %}</p>
      <div class="mw-card-footer">
        <div class="mw-card-price"><sup>AED </sup>550</div>
        <div class="mw-card-dur"><span class="mw-dur-icon">◷</span>{% if is_arabic %}ساعتان{% else %}2 Hours{% endif %}</div>
      </div>
    </div>

  </div>
</div></section>

<!-- ════════ SIGNATURE TREATMENTS ════════ -->
<section class="mw-section"><div class="mw-inner">
  <div class="mw-label" data-mw-reveal>
    <span class="mw-label-text">{% if is_arabic %}العلاجات المميزة{% else %}Signature Treatments{% endif %}</span>
    <div class="mw-label-line"></div>
  </div>

  <div class="mw-list-grid">

    <!-- Hot Stone -->
    <div class="mw-list-card" data-mw-reveal data-delay="0">
      <span class="mw-list-num">04</span>
      <div class="mw-list-body">
        <h3 class="mw-list-title">{% if is_arabic %}تدليك الحجارة الساخنة{% else %}Hot Stone Massage{% endif %}</h3>
        <p class="mw-list-sub">{% if is_arabic %}من التوتر الثقيل إلى الهدوء التام{% else %}From heavy tension to weightless calm{% endif %}</p>
        <p class="mw-list-desc">{% if is_arabic %}حجارة ناعمة ساخنة مدمجة مع تقنيات خبيرة لإذابة توتر العضلات بلطف وتعزيز الدورة الدموية في بيئة فاخرة هادئة.{% else %}Smooth, heated stones combined with expert techniques to gently melt muscle tension and enhance circulation in a serene, luxurious setting.{% endif %}</p>
        <div class="mw-list-meta">
          <div class="mw-list-price"><sup>AED </sup>350</div>
          <div class="mw-list-dur"><span class="mw-dur-dot"></span>{% if is_arabic %}ساعة · ساعة و30 دقيقة{% else %}1 hr · 1 hr 30 min{% endif %}</div>
        </div>
      </div>
    </div>

    <!-- Thai -->
