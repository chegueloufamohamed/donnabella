      </div>
    </div>

    <!-- Deep Tissue -->
    <div class="mw-list-card" data-mw-reveal data-delay="0">
      <span class="mw-list-num">08</span>
      <div class="mw-list-body">
        <h3 class="mw-list-title">{% if is_arabic %}تدليك الأنسجة العميقة{% else %}Deep Tissue Massage{% endif %}</h3>
        <p class="mw-list-sub">{% if is_arabic %}مسار أعمق نحو الراحة الحقيقية{% else %}A deeper path to true relief{% endif %}</p>
        <p class="mw-list-desc">{% if is_arabic %}ضغط قوي ومُستهدَف للوصول إلى الطبقات العميقة من العضلات وتحرير التوتر المزمن والعقد الصلبة.{% else %}Firm, targeted pressure to reach the deeper layers of muscle and release chronic tension and tight knots.{% endif %}</p>
        <div class="mw-list-meta">
          <div class="mw-list-price"><sup>AED </sup>294</div>
          <div class="mw-list-dur"><span class="mw-dur-dot"></span>{% if is_arabic %}ساعة · ساعة و30 دقيقة{% else %}1 hr · 1 hr 30 min{% endif %}</div>
        </div>
      </div>
    </div>

    <!-- Lava Shell -->
    <div class="mw-list-card" data-mw-reveal data-delay="100">
      <span class="mw-list-num">09</span>
