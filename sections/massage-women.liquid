          <div class="mw-list-price"><sup>AED </sup>375</div>
          <div class="mw-list-dur"><span class="mw-dur-dot"></span>{% if is_arabic %}ساعة · ساعة و30 دقيقة{% else %}1 hr · 1 hr 30 min{% endif %}</div>
        </div>
      </div>
    </div>

    <!-- Balinese -->
    <div class="mw-list-card" data-mw-reveal data-delay="100">
      <span class="mw-list-num">07</span>
      <div class="mw-list-body">
        <h3 class="mw-list-title">{% if is_arabic %}مساج بالي{% else %}Balinese Massage{% endif %}</h3>
        <p class="mw-list-sub">{% if is_arabic %}حركات انسيابية ناعمة لانسجام عميق{% else %}Smooth, flowing strokes for deep harmony{% endif %}</p>
        <p class="mw-list-desc">{% if is_arabic %}علاج تقليدي يدمج الإطالة اللطيفة والضغط ونقاط الانعكاس لتنشيط الدورة الدموية ومنح الجسم استرخاءً عميقاً.{% else %}A traditional therapy using gentle stretches, acupressure, and aromatherapy oils to boost blood circulation and bring deep relaxation.{% endif %}</p>
        <div class="mw-list-meta">
          <div class="mw-list-price"><sup>AED </sup>294</div>
          <div class="mw-list-dur"><span class="mw-dur-dot"></span>{% if is_arabic %}ساعة · ساعة و30 دقيقة{% else %}1 hr · 1 hr 30 min{% endif %}</div>
