{% assign current_locale = request.locale.iso_code %}
{% assign is_arabic = false %}
{% if current_locale contains 'ar' %}
  {% assign is_arabic = true %}
{% endif %}
{% assign text_dir = 'ltr' %}
{% if is_arabic %}
  {% assign text_dir = 'rtl' %}
{% endif %}

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Jost:wght@200;300;400;500;600;700&family=Cairo:wght@300;400;600;700;900&family=Tajawal:wght@300;400;500;700;800;900&display=swap" rel="stylesheet">

<style>
.pp-wrap *, .pp-wrap *::before, .pp-wrap *::after { box-sizing: border-box; margin: 0; padding: 0; }

.pp-wrap {
  --bg:        #3d5060;
  --bg-dark:   #2f3d4d;
  --bg-darker: #202c38;
  --gold:      #c9a96e;
  --gold-line: rgba(201,169,110,0.35);
  --gold-dim:  rgba(201,169,110,0.10);
  --white:     #ffffff;
  --white-80:  rgba(255,255,255,0.8);
  --white-60:  rgba(255,255,255,0.6);
  --white-40:  rgba(255,255,255,0.4);
  --white-10:  rgba(255,255,255,0.06);
  --serif: 'Cormorant Garamond', Georgia, serif;
  --sans:  'Jost', sans-serif;
  --arabic: 'Cairo', 'Tajawal', sans-serif;
  font-family: {% if is_arabic %}var(--arabic){% else %}var(--sans){% endif %};
  font-weight: 300;
  color: var(--white);
  background-color: var(--bg-darker);
  direction: {{ text_dir }};
  min-height: 100vh;
}

/* ── HERO BANNER ── */
.pp-hero {
  background: linear-gradient(180deg, var(--bg-darker) 0%, var(--bg-dark) 100%);
  border-bottom: 1px solid var(--gold-line);
  padding: 100px 40px 64px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.pp-hero::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 60% 80% at 50% 100%, rgba(201,169,110,0.07) 0%, transparent 70%);
  pointer-events: none;
}
.pp-hero-tag {
  display: inline-flex; align-items: center; gap: 12px;
  font-size: {% if is_arabic %}12px{% else %}10px{% endif %};
  font-weight: 500;
  letter-spacing: {% if is_arabic %}0{% else %}0.45em{% endif %};
  {% unless is_arabic %}text-transform: uppercase;{% endunless %}
  color: var(--gold); margin-bottom: 24px;
}
.pp-hero-tag::before, .pp-hero-tag::after {
  content: ''; display: block; width: 32px; height: 1px; background: var(--gold-line);
}
.pp-hero-title {
  font-family: {% if is_arabic %}var(--arabic){% else %}var(--serif){% endif %};
  font-size: clamp(36px, 6vw, 72px);
  font-weight: {% if is_arabic %}600{% else %}300{% endif %};
  line-height: {% if is_arabic %}1.3{% else %}1.1{% endif %};
  color: var(--white);
  margin-bottom: 16px;
}
.pp-hero-title em { font-style: {% if is_arabic %}normal{% else %}italic{% endif %}; color: var(--gold); }
.pp-hero-date {
  font-size: 11px;
  letter-spacing: {% if is_arabic %}0{% else %}0.3em{% endif %};
  {% unless is_arabic %}text-transform: uppercase;{% endunless %}
  color: var(--white-40);
}

/* ── CONTENT AREA ── */
.pp-inner {
  max-width: 860px; margin: 0 auto;
  padding: 72px 40px 96px;
}

.pp-section { margin-bottom: 56px; }

.pp-section-title {
  font-family: {% if is_arabic %}var(--arabic){% else %}var(--serif){% endif %};
  font-size: {% if is_arabic %}22px{% else %}26px{% endif %};
  font-weight: {% if is_arabic %}600{% else %}400{% endif %};
  color: var(--white);
  margin-bottom: 20px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--gold-line);
  display: flex; align-items: center; gap: 12px;
}
.pp-section-num {
  font-family: var(--serif);
  font-size: 14px; font-weight: 300;
  color: var(--gold); opacity: 0.7;
  flex-shrink: 0;
}

.pp-text {
  font-size: 14px; line-height: 1.9;
  color: var(--white-60); margin-bottom: 16px;
}
.pp-text:last-child { margin-bottom: 0; }

.pp-list {
  list-style: none; display: flex; flex-direction: column; gap: 10px;
  margin-bottom: 16px;
}
.pp-list li {
  font-size: 14px; line-height: 1.8; color: var(--white-60);
  display: flex; align-items: flex-start; gap: 10px;
  {% if is_arabic %}flex-direction: row-reverse;{% endif %}
}
.pp-list li::before {
  content: ''; display: block; width: 4px; height: 4px;
  border-radius: 50%; background: var(--gold);
  margin-top: 10px; flex-shrink: 0;
}

.pp-highlight {
  background: rgba(201,169,110,0.07);
  border: 1px solid var(--gold-line);
  border-{% if is_arabic %}right{% else %}left{% endif %}: 3px solid var(--gold);
  padding: 20px 24px;
  margin-bottom: 20px;
  font-size: 13.5px; line-height: 1.85; color: var(--white-80);
}

.pp-contact-grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px;
  margin-top: 24px;
}
.pp-contact-card {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  padding: 24px 20px; text-align: {% if is_arabic %}right{% else %}left{% endif %};
}
.pp-contact-label {
  font-size: {% if is_arabic %}11px{% else %}9px{% endif %};
  letter-spacing: {% if is_arabic %}0{% else %}0.35em{% endif %};
  {% unless is_arabic %}text-transform: uppercase;{% endunless %}
  color: var(--gold); margin-bottom: 8px;
}
.pp-contact-val {
  font-size: 13px; color: var(--white-60); line-height: 1.6;
}
.pp-contact-val a { color: var(--white-60); text-decoration: none; transition: color 0.3s; }
.pp-contact-val a:hover { color: var(--gold); }

/* ── RESPONSIVE ── */
@media (max-width: 768px) {
  .pp-hero { padding: 80px 24px 48px; }
  .pp-inner { padding: 48px 24px 72px; }
  .pp-contact-grid { grid-template-columns: 1fr; }
}
</style>

<div class="pp-wrap" dir="{{ text_dir }}">

  <!-- Hero -->
  <div class="pp-hero">
    <div class="pp-hero-tag">
      {% if is_arabic %}دونا بيلا لإدارة التسويق{% else %}Donna Bella Marketing Management{% endif %}
    </div>
    <h1 class="pp-hero-title">
      {% if is_arabic %}شروط <em>الخدمة</em>{% else %}<em>Terms</em> of Service{% endif %}
    </h1>
    <div class="pp-hero-date">
      {% if is_arabic %}آخر تحديث: يونيو 2026{% else %}Last updated: June 2026{% endif %}
    </div>
  </div>

  <!-- Content -->
  <div class="pp-inner">

    <!-- Intro -->
    <div class="pp-section">
      <div class="pp-highlight">
        {% if is_arabic %}
          تحكم شروط الخدمة هذه ("الشروط") وصولك واستخدامك للموقع الإلكتروني والخدمات المقدمة من شركة دونا بيلا لإدارة التسويق ذ.م.م. من خلال تصفح موقعنا أو حجز خدماتنا، فإنك توافق على الالتزام بهذه الشروط.
        {% else %}
          These Terms of Service ("Terms") govern your access to and use of the website and services provided by Donna Bella Marketing Management L.L.C. By accessing our website or booking our services, you agree to be bound by these Terms.
        {% endif %}
      </div>
    </div>

    <!-- 1. Agreement to Terms -->
    <div class="pp-section">
      <div class="pp-section-title">
        <span class="pp-section-num">01</span>
        {% if is_arabic %}الموافقة على الشروط{% else %}Agreement to Terms{% endif %}
      </div>
      <p class="pp-text">
        {% if is_arabic %}
          باستخدام خدماتنا أو تصفح موقعنا، فإنك تقر بأن عمرك لا يقل عن 18 عاماً وتوافق على الالتزام بهذه الشروط وجميع القوانين السارية في دولة الإمارات العربية المتحدة. إذا كنت لا توافق على هذه الشروط، يرجى عدم استخدام موقعنا أو حجز خدماتنا.
        {% else %}
          By using our services or accessing our site, you represent that you are at least 18 years old and agree to comply with these Terms and all applicable laws of the United Arab Emirates. If you do not agree to these Terms, please do not use our website or book our services.
        {% endif %}
      </p>
    </div>

    <!-- 2. Services & Bookings -->
    <div class="pp-section">
      <div class="pp-section-title">
        <span class="pp-section-num">02</span>
        {% if is_arabic %}الخدمات والحجوزات{% else %}Services & Bookings{% endif %}
      </div>
      <p class="pp-text">
        {% if is_arabic %}
          نحن نقدم خدمات التجميل والعناية المنزلية. يرجى مراعاة ما يلي:
        {% else %}
          We provide professional home beauty and wellness services. Please note the following:
        {% endif %}
      </p>
      <ul class="pp-list">
        <li>{% if is_arabic %}تخضع جميع طلبات الحجز للتوافر وتأكيد موعد الخدمة النهائي من جانبنا.{% else %}All booking requests are subject to availability and final confirmation of the service slot by us.{% endif %}</li>
        <li>{% if is_arabic %}نحتفظ بالحق في رفض تقديم الخدمة أو إعادة جدولة المواعيد لأسباب طارئة أو قوة قاهرة.{% else %}We reserve the right to refuse service or reschedule appointments due to emergency circumstances or force majeure.{% endif %}</li>
        <li>{% if is_arabic %}يجب تقديم تفاصيل دقيقة حول الموقع والخدمات المطلوبة لضمان جودة الخدمة.{% else %}Accurate details regarding the location and requested services must be provided to ensure service quality.{% endif %}</li>
      </ul>
    </div>

    <!-- 3. Payments & Pricing -->
    <div class="pp-section">
      <div class="pp-section-title">
        <span class="pp-section-num">03</span>
        {% if is_arabic %}الدفع والأسعار{% else %}Payments & Pricing{% endif %}
      </div>
      <p class="pp-text">
        {% if is_arabic %}
          شروط الدفع والتسعير لدينا تشمل:
        {% else %}
          Our payment and pricing terms include the following:
        {% endif %}
      </p>
      <ul class="pp-list">
        <li>{% if is_arabic %}جميع الأسعار المعروضة بالدرهم الإماراتي (AED) وهي عرضة للتغيير دون إشعار مسبق.{% else %}All displayed prices are in UAE Dirhams (AED) and are subject to change without prior notice.{% endif %}</li>
        <li>{% if is_arabic %}يجب إتمام الدفع بالكامل عبر طرق الدفع المعتمدة على موقعنا أو نقداً/بالبطاقة فور إتمام الخدمة كما هو متفق عليه.{% else %}Full payment must be completed via approved online payment methods on our website or by cash/card upon service completion as agreed.{% endif %}</li>
        <li>{% if is_arabic %}الأسعار تشمل ضريبة القيمة المضافة المعمول بها في دولة الإمارات ما لم ينص على خلاف ذلك.{% else %}Prices are inclusive of applicable UAE Value Added Tax (VAT) unless stated otherwise.{% endif %}</li>
      </ul>
    </div>

    <!-- 4. Cancellation & Refund Policy -->
    <div class="pp-section">
      <div class="pp-section-title">
        <span class="pp-section-num">04</span>
        {% if is_arabic %}سياسة الإلغاء والاسترداد{% else %}Cancellation & Refund Policy{% endif %}
      </div>
      <p class="pp-text">
        {% if is_arabic %}
          نحن نقدر وقت عملائنا وموظفينا على حد سواء، لذا يرجى الالتزام بالسياسة التالية:
        {% else %}
          We value the time of both our clients and professional therapists, so please adhere to the following policy:
        {% endif %}
      </p>
      <ul class="pp-list">
        <li>{% if is_arabic %}يجب تقديم طلبات إلغاء أو إعادة جدولة المواعيد قبل 24 ساعة على الأقل من الموعد المحدد.{% else %}Cancellation or rescheduling requests must be submitted at least 24 hours prior to the scheduled appointment.{% endif %}</li>
        <li>{% if is_arabic %}قد يؤدي الإلغاء أو التغيير قبل أقل من 24 ساعة من الموعد إلى فرض رسوم إلغاء أو خسارة العربون.{% else %}Cancellations or changes made less than 24 hours before the appointment may incur a cancellation fee or forfeiture of deposit.{% endif %}</li>
        <li>{% if is_arabic %}يتم تقييم طلبات الاسترداد على أساس كل حالة على حدة وفقاً لظروف الخدمة والسياسات المتبعة لدينا.{% else %}Refund requests are evaluated on a case-by-case basis according to our service conditions and policies.{% endif %}</li>
      </ul>
    </div>

    <!-- 5. Customer Responsibilities -->
    <div class="pp-section">
      <div class="pp-section-title">
        <span class="pp-section-num">05</span>
        {% if is_arabic %}مسؤوليات العميل{% else %}Customer Responsibilities{% endif %}
      </div>
      <p class="pp-text">
        {% if is_arabic %}
          لضمان سلامة تقديم الخدمة وجودتها، يجب على العميل:
        {% else %}
          To ensure the safety and quality of the home service, the customer must:
        {% endif %}
      </p>
      <ul class="pp-list">
        <li>{% if is_arabic %}توفير مساحة آمنة ونظيفة ومناسبة لتقديم الخدمات المنزلية المطلوبة.{% else %}Provide a safe, clean, and suitable space for the requested home services.{% endif %}</li>
        <li>{% if is_arabic %}إبلاغنا بأي حالة صحية أو حساسية جلدية أو متطلبات خاصة قبل بدء تقديم الخدمة.{% else %}Inform us of any medical conditions, skin allergies, or specific requirements before the service begins.{% endif %}</li>
        <li>{% if is_arabic %}معاملة مقدمي الخدمة باحترام ومهنية كاملة.{% else %}Treat our service providers with respect and full professionalism.{% endif %}</li>
      </ul>
    </div>

    <!-- 6. Intellectual Property -->
    <div class="pp-section">
      <div class="pp-section-title">
        <span class="pp-section-num">06</span>
        {% if is_arabic %}الملكية الفكرية{% else %}Intellectual Property{% endif %}
      </div>
      <p class="pp-text">
        {% if is_arabic %}
          جميع المحتويات الموجودة على هذا الموقع، بما في ذلك النصوص، الرسومات، الشعارات، الصور، والبرمجيات، هي ملك لشركة دونا بيلا لإدارة التسويق ذ.م.م ومحمية بموجب قوانين حقوق النشر وحماية الملكية الفكرية المعمول بها في دولة الإمارات العربية المتحدة.
        {% else %}
          All content on this website, including text, graphics, logos, images, and software, is the property of Donna Bella Marketing Management L.L.C and is protected by copyright and intellectual property laws in the United Arab Emirates.
        {% endif %}
      </p>
    </div>

    <!-- 7. Limitation of Liability -->
    <div class="pp-section">
      <div class="pp-section-title">
        <span class="pp-section-num">07</span>
        {% if is_arabic %}تحديد المسؤولية{% else %}Limitation of Liability{% endif %}
      </div>
      <p class="pp-text">
        {% if is_arabic %}
          لا تتحمل شركة دونا بيلا المسؤولية عن أي أضرار غير مباشرة أو عرضية أو تبعية تنشأ عن استخدام خدماتنا أو موقعنا الإلكتروني. تقتصر مسؤوليتنا الكاملة تجاه أي مطالبة على المبلغ الذي قمت بدفعه مقابل الخدمة المعنية، وذلك إلى أقصى حد يسمح به قانون دولة الإمارات.
        {% else %}
          Donna Bella shall not be liable for any indirect, incidental, or consequential damages arising from the use of our services or website. Our total liability for any claim is limited to the amount paid by you for the specific service in question, to the maximum extent permitted by UAE law.
        {% endif %}
      </p>
    </div>

    <!-- 8. Governing Law -->
    <div class="pp-section">
      <div class="pp-section-title">
        <span class="pp-section-num">08</span>
        {% if is_arabic %}القانون الواجب التطبيق{% else %}Governing Law{% endif %}
      </div>
      <p class="pp-text">
        {% if is_arabic %}
          تخضع شروط الخدمة هذه وتُفسر وفقاً لقوانين إمارة دبي والقوانين الاتحادية لدولة الإمارات العربية المتحدة. وتخضع أي نزاعات تنشأ عن هذه الشروط للاختصاص القضائي الحصري لمحاكم دبي.
        {% else %}
          These Terms of Service shall be governed by and construed in accordance with the laws of the Emirate of Dubai and the federal laws of the United Arab Emirates. Any disputes arising from these Terms shall be subject to the exclusive jurisdiction of the Dubai courts.
        {% endif %}
      </p>
    </div>

    <!-- 9. Contact Us -->
    <div class="pp-section">
      <div class="pp-section-title">
        <span class="pp-section-num">09</span>
        {% if is_arabic %}تواصل معنا{% else %}Contact Us{% endif %}
      </div>
      <p class="pp-text">
        {% if is_arabic %}
          إذا كان لديك أي أسئلة أو استفسارات تتعلق بشروط الخدمة هذه، يرجى التواصل معنا:
        {% else %}
          If you have any questions or concerns regarding these Terms of Service, please reach out:
        {% endif %}
      </p>
      <div class="pp-contact-grid">
        <div class="pp-contact-card">
          <div class="pp-contact-label">{% if is_arabic %}الشركة{% else %}Company{% endif %}</div>
          <div class="pp-contact-val">{% if is_arabic %}شركة دونا بيلا لإدارة التسويق ذ.م.م{% else %}Donna Bella Marketing Management L.L.C{% endif %}</div>
        </div>
        <div class="pp-contact-card">
          <div class="pp-contact-label">{% if is_arabic %}البريد الإلكتروني{% else %}Email{% endif %}</div>
          <div class="pp-contact-val"><a href="mailto:donnabella.home.services@gmail.com">donnabella.home.services@gmail.com</a></div>
        </div>
        <div class="pp-contact-card">
          <div class="pp-contact-label">{% if is_arabic %}الموقع{% else %}Location{% endif %}</div>
          <div class="pp-contact-val">
            <a href="https://maps.app.goo.gl/o6YjCpTT2aJHJTZS9" target="_blank" rel="noopener">
              {% if is_arabic %}مكتب 1102، برشا 1، دبي، الإمارات{% else %}Office 1102, Barsha 1, Dubai, UAE{% endif %}
            </a>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Marketing Agency Policy",
  "presets": [{ "name": "Marketing Agency Policy" }]
}
{% endschema %}
