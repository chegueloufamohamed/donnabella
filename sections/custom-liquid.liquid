      <span class="nls-bar-label">{% if is_arabic %}عرض الطلب{% else %}View selection{% endif %}</span>
      <span class="nls-bar-total" id="nlsBarTotal-{{ section.id }}">{% if is_arabic %}د.إ 0{% else %}AED 0{% endif %}</span>
      <span class="nls-bar-chev">▴</span>
    </button>
    <div class="nls-cart-panel">
      <div class="nls-cart-tag">{% if is_arabic %}حجزك{% else %}Your Booking{% endif %}</div>
      <div class="nls-cart-head">{% if is_arabic %}الخدمات المختارة{% else %}Your Selection{% endif %}</div>
      <div class="nls-cart-empty" id="nlsEmpty-{{ section.id }}">{% if is_arabic %}لم تختر أي خدمة بعد{% else %}No services selected yet{% endif %}</div>
      <div class="nls-cart-items" id="nlsItems-{{ section.id }}" style="display:none;"></div>
      <div class="nls-cart-total"><span class="label">{% if is_arabic %}الإجمالي{% else %}Total{% endif %}</span><span class="val" id="nlsTotal-{{ section.id }}">{% if is_arabic %}د.إ 0{% else %}AED 0{% endif %}</span></div>
      <button type="button" class="nls-cart-btn is-disabled" id="nlsBook-{{ section.id }}">{% if is_arabic %}احجز عبر واتساب{% else %}Book via WhatsApp{% endif %}</button>
    </div>
  </div>
