{% comment %}
  Section: Skin Care (Bilingual) — Belladona Care
  - Auto switches EN/AR using request.locale.iso_code
  - Scoped CSS/JS to section.id (no global body/html edits)
  - Preserves your layout, styling, and reveal animations
{% endcomment %}

{%- liquid
  assign locale_code = request.locale.iso_code | downcase
  assign is_ar = false
  if locale_code contains 'ar'
    assign is_ar = true
  endif
-%}

<section
  id="skincare-{{ section.id }}"
  class="sc-page"
  {% if is_ar %}dir="rtl" lang="ar"{% else %}dir="ltr" lang="en"{% endif %}
  data-sc-root
>
  <style>
    #skincare-{{ section.id }} .mini-icon,
#skincare-{{ section.id }} .trio-dur .dicon,
#skincare-{{ section.id }} .dur-tag,
#skincare-{{ section.id }} .tagline-diamond,
#skincare-{{ section.id }} .dur-dot {
  display: none !important;
}

#skincare-{{ section.id }} {
  font-variant-emoji: text;
}
    @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Jost:wght@200;300;400;500;600&display=swap');

    /* Scoped Reset */
    #skincare-{{ section.id }} *, 
    #skincare-{{ section.id }} *::before, 
    #skincare-{{ section.id }} *::after { box-sizing: border-box; margin: 0; padding: 0; }

    #skincare-{{ section.id }} {
      --bg:        #405264;
      --bg-dark:   #2f3d4d;
      --bg-light:  #4d6275;
      --bg-deeper: #354656;
      --gold:      #c9a96e;
      --gold-dim:  rgba(201,169,110,0.18);
      --gold-line: rgba(201,169,110,0.35);
      --rose:      #d4a5a5;
      --rose-dim:  rgba(212,165,165,0.12);
      --white:     #ffffff;
      --white-60:  rgba(255,255,255,0.6);
      --white-20:  rgba(255,255,255,0.08);
      --glass:     rgba(255,255,255,0.06);
      --glass-b:   rgba(255,255,255,0.11);
      --serif: 'Cormorant Garamond', Georgia, serif;
      --sans:  'Jost', sans-serif;

      background-color: var(--bg);
      color: var(--white);
      font-family: var(--sans);
      font-weight: 300;
      overflow-x: hidden;
      position: relative;
      min-height: 1px;
    }

    /* Noise texture */
    #skincare-{{ section.id }}::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
      pointer-events: none;
      z-index: 0;
      opacity: 0.6;
    }

    @keyframes scRingPulse {
      0%,100% { opacity: 0.35; transform: translate(-50%,-50%) scale(1); }
      50%      { opacity: 0.75; transform: translate(-50%,-50%) scale(1.05); }
    }
    @keyframes scFadeUp { to { opacity: 1; transform: translateY(0); } }

    /* ── HERO ── */
    #skincare-{{ section.id }} .hero {
      position: relative;
      min-height: 56vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 80px 30px 50px;
      overflow: hidden;
      z-index: 1;
    }
    #skincare-{{ section.id }} .hero::before {
      content: '';
      position: absolute;
      width: 640px; height: 640px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(212,165,165,0.09) 0%, transparent 70%);
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      pointer-events: none;
    }
    #skincare-{{ section.id }} .hero::after {
      content: '';
      position: absolute;
      width: 360px; height: 360px;
      border-radius: 50%;
      border: 1px solid rgba(212,165,165,0.3);
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      pointer-events: none;
      animation: scRingPulse 4.5s ease-in-out infinite;
    }

    #skincare-{{ section.id }} .hero-eyebrow {
      font-size: 11px; font-weight: 500;
      letter-spacing: 0.42em; text-transform: uppercase;
      color: var(--rose); margin-bottom: 20px;
      position: relative; z-index: 1;
      opacity: 0; transform: translateY(16px);
      animation: scFadeUp 0.8s ease 0.2s forwards;
    }
    #skincare-{{ section.id }} .hero-title {
      font-family: var(--serif);
      font-size: clamp(50px, 9vw, 96px);
      font-weight: 300; font-style: italic;
      line-height: 0.95; letter-spacing: -0.01em;
      color: var(--white);
      position: relative; z-index: 1;
      opacity: 0; transform: translateY(20px);
      animation: scFadeUp 0.9s ease 0.4s forwards;
    }
    #skincare-{{ section.id }} .hero-title span { color: var(--gold); font-style: normal; font-weight: 500; }
    #skincare-{{ section.id }} .hero-desc {
      margin-top: 26px;
      font-size: 13px; letter-spacing: 0.14em;
      color: var(--white-60); text-transform: uppercase;
      position: relative; z-index: 1;
      opacity: 0; transform: translateY(16px);
      animation: scFadeUp 0.9s ease 0.6s forwards;
    }
    #skincare-{{ section.id }} .hero-divider {
      margin-top: 40px;
      width: 1px; height: 60px;
      background: linear-gradient(to bottom, var(--gold), transparent);
      opacity: 0;
      animation: scFadeUp 0.9s ease 0.8s forwards;
    }

    /* ── SECTION WRAPPER ── */
    #skincare-{{ section.id }} .section { position: relative; z-index: 1; padding: 60px 0 70px; }
    #skincare-{{ section.id }} .section-inner { max-width: 1160px; margin: 0 auto; padding: 0 30px; }

    #skincare-{{ section.id }} .section-label {
      display: flex; align-items: center; gap: 18px;
      margin-bottom: 48px;
      opacity: 0; transform: translateX(-20px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }
    #skincare-{{ section.id }} .section-label.visible { opacity: 1; transform: translateX(0); }
    #skincare-{{ section.id }} .section-label-line {
      flex: 1; height: 1px;
      background: linear-gradient(to right, var(--gold-line), transparent);
    }
    #skincare-{{ section.id }} .section-label-text {
      font-size: 10px; font-weight: 500;
      letter-spacing: 0.45em; text-transform: uppercase;
      color: var(--gold); white-space: nowrap;
    }

    /* RTL adjustments */
    #skincare-{{ section.id }}[dir="rtl"] .section-label { transform: translateX(20px); }
    #skincare-{{ section.id }}[dir="rtl"] .section-label.visible { transform: translateX(0); }
    #skincare-{{ section.id }}[dir="rtl"] .section-label-line { background: linear-gradient(to left, var(--gold-line), transparent); }

    /* ── HERO TREATMENT CARD ── */
    #skincare-{{ section.id }} .hero-card {
      position: relative;
      background: linear-gradient(135deg, rgba(201,169,110,0.12) 0%, rgba(201,169,110,0.03) 100%);
      border: 1px solid var(--gold-line);
      padding: 52px 52px 46px;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 40px;
      align-items: center;
      overflow: hidden;
      opacity: 0; transform: translateY(28px);
      transition: opacity 0.8s ease, transform 0.8s ease, background 0.4s ease;
      cursor: default;
      margin-bottom: 2px;
    }
    #skincare-{{ section.id }} .hero-card.visible { opacity: 1; transform: translateY(0); }
    #skincare-{{ section.id }} .hero-card:hover {
      background: linear-gradient(135deg, rgba(201,169,110,0.18) 0%, rgba(201,169,110,0.06) 100%);
    }
    #skincare-{{ section.id }} .hero-card::before {
      content: '';
      position: absolute; top: 0; left: 0; right: 0; height: 2px;
      background: linear-gradient(to right, transparent 5%, var(--gold) 50%, transparent 95%);
    }
    #skincare-{{ section.id }} .hero-card-num {
      position: absolute; bottom: 24px; right: 36px;
      font-family: var(--serif); font-size: 120px; font-weight: 300;
      color: rgba(201,169,110,0.07); line-height: 1;
      user-select: none; pointer-events: none;
    }
    #skincare-{{ section.id }}[dir="rtl"] .hero-card-num { right: auto; left: 36px; }

    #skincare-{{ section.id }} .hero-card-tag {
      font-size: 9px; font-weight: 500;
      letter-spacing: 0.42em; text-transform: uppercase;
      color: var(--gold); margin-bottom: 14px;
    }
    #skincare-{{ section.id }} .hero-card-title {
      font-family: var(--serif);
      font-size: 42px; font-weight: 400;
      color: var(--white); line-height: 1.1;
      margin-bottom: 8px;
    }
    #skincare-{{ section.id }} .hero-card-subtitle {
      font-family: var(--serif);
      font-size: 15px; font-style: italic;
      color: var(--gold); margin-bottom: 16px; opacity: 0.9;
    }
    #skincare-{{ section.id }} .hero-card-desc {
      font-size: 13px; line-height: 1.78;
      color: var(--white-60); max-width: 520px;
    }
    #skincare-{{ section.id }} .hero-card-right { text-align: right; flex-shrink: 0; }
    #skincare-{{ section.id }}[dir="rtl"] .hero-card-right { text-align: left; }

    #skincare-{{ section.id }} .price-label {
      font-size: 9px; letter-spacing: 0.38em;
      text-transform: uppercase; color: var(--gold); margin-bottom: 6px;
    }
    #skincare-{{ section.id }} .price-big {
      font-family: var(--serif); font-size: 58px;
      font-weight: 300; color: var(--white); line-height: 1;
    }
    #skincare-{{ section.id }} .price-big sup {
      font-size: 18px; font-family: var(--sans);
      font-weight: 300; vertical-align: super; opacity: 0.7;
    }
    #skincare-{{ section.id }} .dur-tag {
      margin-top: 10px; font-size: 11px;
      color: var(--white-60); letter-spacing: 0.1em;
    }

    /* ── 3-COLUMN CARD GRID ── */
    #skincare-{{ section.id }} .trio-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2px;
      margin-bottom: 2px;
    }
    #skincare-{{ section.id }} .trio-card {
      position: relative;
      background: var(--glass);
      border: 1px solid var(--glass-b);
      padding: 40px 32px 36px;
      overflow: hidden;
      opacity: 0; transform: translateY(28px);
      transition: opacity 0.7s ease, transform 0.7s ease, background 0.35s ease, border-color 0.35s ease;
      cursor: default;
      display: flex; flex-direction: column;
    }
    #skincare-{{ section.id }} .trio-card.visible { opacity: 1; transform: translateY(0); }
    #skincare-{{ section.id }} .trio-card:hover { background: rgba(255,255,255,0.1); border-color: var(--gold-line); }
    #skincare-{{ section.id }} .trio-card::before {
      content: '';
      position: absolute; top: 0; left: 0; right: 0; height: 2px;
      background: linear-gradient(to right, transparent, var(--gold), transparent);
      opacity: 0; transition: opacity 0.4s ease;
    }
    #skincare-{{ section.id }} .trio-card:hover::before { opacity: 1; }
    #skincare-{{ section.id }} .trio-num {
      font-family: var(--serif); font-size: 64px;
      font-weight: 300; color: rgba(201,169,110,0.1);
      position: absolute; top: 14px; right: 20px;
      line-height: 1; user-select: none;
      transition: color 0.35s ease;
    }
    #skincare-{{ section.id }}[dir="rtl"] .trio-num { right: auto; left: 20px; }
    #skincare-{{ section.id }} .trio-card:hover .trio-num { color: rgba(201,169,110,0.22); }
    #skincare-{{ section.id }} .trio-tag {
      font-size: 9px; font-weight: 500;
      letter-spacing: 0.4em; text-transform: uppercase;
      color: var(--gold); margin-bottom: 12px;
    }
    #skincare-{{ section.id }} .trio-title {
      font-family: var(--serif); font-size: 24px;
      font-weight: 400; color: var(--white);
      line-height: 1.15; margin-bottom: 6px;
    }
    #skincare-{{ section.id }} .trio-subtitle {
      font-family: var(--serif); font-size: 12px;
      font-style: italic; color: var(--gold);
      margin-bottom: 14px; opacity: 0.88;
    }
    #skincare-{{ section.id }} .trio-desc {
      font-size: 12.5px; line-height: 1.74;
      color: var(--white-60); margin-bottom: 28px; flex: 1;
    }
    #skincare-{{ section.id }} .trio-footer {
      display: flex; align-items: flex-end;
      justify-content: space-between;
      border-top: 1px solid var(--glass-b);
      padding-top: 16px; margin-top: auto;
    }
    #skincare-{{ section.id }} .trio-price {
      font-family: var(--serif); font-size: 30px;
      font-weight: 300; color: var(--white);
    }
    #skincare-{{ section.id }} .trio-price sup {
      font-size: 13px; font-family: var(--sans);
      vertical-align: super; opacity: 0.7;
    }
    #skincare-{{ section.id }} .trio-dur {
      font-size: 10.5px; color: var(--white-60);
      text-align: right; letter-spacing: 0.06em; line-height: 1.5;
    }
    #skincare-{{ section.id }}[dir="rtl"] .trio-dur { text-align: left; }
    #skincare-{{ section.id }} .trio-dur .dicon { display: block; color: var(--gold); font-size: 13px; margin-bottom: 3px; }

    /* ── 2-COLUMN LIST CARD ── */
    #skincare-{{ section.id }} .list-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2px;
    }
    #skincare-{{ section.id }} .list-card {
      position: relative;
      background: var(--glass);
      border: 1px solid var(--glass-b);
      padding: 32px 30px 28px;
      display: flex; gap: 20px; align-items: flex-start;
      overflow: hidden;
      opacity: 0; transform: translateY(20px);
      transition: opacity 0.65s ease, transform 0.65s ease, background 0.3s ease, border-color 0.3s ease;
      cursor: default;
    }
    #skincare-{{ section.id }} .list-card.visible { opacity: 1; transform: translateY(0); }
    #skincare-{{ section.id }} .list-card:hover { background: rgba(255,255,255,0.09); border-color: var(--gold-line); }
    #skincare-{{ section.id }} .list-num {
      font-family: var(--serif); font-size: 34px;
      font-weight: 300; color: var(--gold);
      opacity: 0.3; line-height: 1; flex-shrink: 0;
      min-width: 36px; transition: opacity 0.3s ease;
    }
    #skincare-{{ section.id }} .list-card:hover .list-num { opacity: 0.65; }
    #skincare-{{ section.id }} .list-body { flex: 1; min-width: 0; }
    #skincare-{{ section.id }} .list-title {
      font-family: var(--serif); font-size: 20px;
      font-weight: 400; color: var(--white);
      margin-bottom: 4px; line-height: 1.2;
    }
    #skincare-{{ section.id }} .list-subtitle {
      font-family: var(--serif); font-size: 12px;
      font-style: italic; color: var(--gold);
      margin-bottom: 10px; opacity: 0.85;
    }
    #skincare-{{ section.id }} .list-desc {
      font-size: 12px; line-height: 1.72;
      color: var(--white-60); margin-bottom: 18px;
    }
    #skincare-{{ section.id }} .list-meta {
      display: flex; align-items: center;
      justify-content: space-between;
    }
    #skincare-{{ section.id }} .list-price {
      font-family: var(--serif); font-size: 26px;
      font-weight: 300; color: var(--white);
    }
    #skincare-{{ section.id }} .list-price sup {
      font-size: 11px; font-family: var(--sans);
      vertical-align: super; opacity: 0.7;
    }
    #skincare-{{ section.id }} .list-dur {
      font-size: 10px; color: var(--white-60);
      text-align: right; letter-spacing: 0.08em; line-height: 1.5;
    }
    #skincare-{{ section.id }}[dir="rtl"] .list-dur { text-align: left; }
    #skincare-{{ section.id }} .dur-dot {
      display: inline-block; width: 5px; height: 5px;
      border-radius: 50%; background: var(--gold);
      opacity: 0.5; margin-right: 5px; vertical-align: middle;
    }
    #skincare-{{ section.id }}[dir="rtl"] .dur-dot { margin-right: 0; margin-left: 5px; }

    /* ── DERMALOGICA BANNER ── */
    #skincare-{{ section.id }} .pro-banner {
      position: relative;
      background: linear-gradient(to right, var(--bg-dark), var(--bg-deeper), var(--bg-dark));
      border: 1px solid var(--glass-b);
      border-top: 2px solid var(--gold);
      padding: 44px 48px;
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 36px;
      align-items: center;
      overflow: hidden;
      opacity: 0; transform: translateY(24px);
      transition: opacity 0.8s ease, transform 0.8s ease;
      cursor: default;
    }
    #skincare-{{ section.id }} .pro-banner.visible { opacity: 1; transform: translateY(0); }
    #skincare-{{ section.id }} .pro-banner:hover { border-color: rgba(255,255,255,0.18); }

    #skincare-{{ section.id }} .pro-logo-mark {
      width: 60px; height: 60px; border-radius: 50%;
      border: 1px solid var(--gold-line);
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    #skincare-{{ section.id }} .pro-logo-mark span { font-family: var(--serif); font-size: 22px; color: var(--gold); }

    #skincare-{{ section.id }} .pro-tag {
      font-size: 9px; font-weight: 500;
      letter-spacing: 0.42em; text-transform: uppercase;
      color: var(--gold); margin-bottom: 8px;
    }
    #skincare-{{ section.id }} .pro-title {
      font-family: var(--serif); font-size: 28px;
      font-weight: 400; color: var(--white); margin-bottom: 6px;
    }
    #skincare-{{ section.id }} .pro-subtitle {
      font-family: var(--serif); font-style: italic;
      font-size: 13px; color: var(--gold); margin-bottom: 10px;
    }
    #skincare-{{ section.id }} .pro-desc { font-size: 12.5px; line-height: 1.74; color: var(--white-60); }

    #skincare-{{ section.id }} .pro-right { text-align: right; flex-shrink: 0; }
    #skincare-{{ section.id }}[dir="rtl"] .pro-right { text-align: left; }
    #skincare-{{ section.id }} .pro-price {
      font-family: var(--serif); font-size: 42px;
      font-weight: 300; color: var(--white); line-height: 1;
    }
    #skincare-{{ section.id }} .pro-price sup {
      font-size: 15px; font-family: var(--sans);
      vertical-align: super; opacity: 0.7;
    }
    #skincare-{{ section.id }} .pro-dur { font-size: 10px; color: var(--white-60); margin-top: 8px; letter-spacing: 0.08em; }

    /* ── MINI PAIR ── */
    #skincare-{{ section.id }} .mini-pair {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2px;
    }
    #skincare-{{ section.id }} .mini-card {
      background: var(--glass);
      border: 1px solid var(--glass-b);
      padding: 34px 30px;
      opacity: 0; transform: translateY(18px);
      transition: opacity 0.65s ease, transform 0.65s ease, background 0.3s ease, border-color 0.3s ease;
      cursor: default;
      display: flex; flex-direction: column;
    }
    #skincare-{{ section.id }} .mini-card.visible { opacity: 1; transform: translateY(0); }
    #skincare-{{ section.id }} .mini-card:hover { background: rgba(255,255,255,0.1); border-color: var(--gold-line); }

    #skincare-{{ section.id }} .mini-icon { font-size: 22px; margin-bottom: 14px; display: block; }
    #skincare-{{ section.id }} .mini-title {
      font-family: var(--serif); font-size: 21px;
      font-weight: 400; color: var(--white); margin-bottom: 5px;
    }
    #skincare-{{ section.id }} .mini-subtitle {
      font-family: var(--serif); font-style: italic;
      font-size: 12px; color: var(--gold);
      margin-bottom: 12px; opacity: 0.85;
    }
    #skincare-{{ section.id }} .mini-desc {
      font-size: 12px; line-height: 1.7;
      color: var(--white-60); margin-bottom: 22px; flex: 1;
    }
    #skincare-{{ section.id }} .mini-bottom {
      display: flex; align-items: flex-end;
      justify-content: space-between;
      border-top: 1px solid var(--glass-b); padding-top: 16px;
    }
    #skincare-{{ section.id }} .mini-price {
      font-family: var(--serif); font-size: 28px;
      font-weight: 300; color: var(--white);
    }
    #skincare-{{ section.id }} .mini-price sup {
      font-size: 12px; font-family: var(--sans);
      vertical-align: super; opacity: 0.7;
    }
    #skincare-{{ section.id }} .mini-dur { font-size: 10px; color: var(--white-60); letter-spacing: 0.08em; }

    /* ── ACNE CARD ── */
    #skincare-{{ section.id }} .acne-card {
      position: relative;
      background: linear-gradient(135deg, rgba(212,165,165,0.1) 0%, rgba(212,165,165,0.02) 100%);
      border: 1px solid rgba(212,165,165,0.25);
      padding: 48px 52px;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 40px;
      align-items: center;
      overflow: hidden;
      margin-bottom: 2px;
      opacity: 0; transform: translateY(24px);
      transition: opacity 0.8s ease, transform 0.8s ease, background 0.4s ease;
      cursor: default;
    }
    #skincare-{{ section.id }} .acne-card.visible { opacity: 1; transform: translateY(0); }
    #skincare-{{ section.id }} .acne-card:hover {
      background: linear-gradient(135deg, rgba(212,165,165,0.16) 0%, rgba(212,165,165,0.05) 100%);
      border-color: rgba(212,165,165,0.4);
    }
    #skincare-{{ section.id }} .acne-card::before {
      content: '';
      position: absolute; top: 0; left: 0; right: 0; height: 2px;
      background: linear-gradient(to right, transparent 10%, var(--rose) 50%, transparent 90%);
    }
    #skincare-{{ section.id }} .acne-tag {
      font-size: 9px; font-weight: 500;
      letter-spacing: 0.42em; text-transform: uppercase;
      color: var(--rose); margin-bottom: 12px;
    }
    #skincare-{{ section.id }} .acne-title {
      font-family: var(--serif); font-size: 38px;
      font-weight: 400; color: var(--white);
      line-height: 1.1; margin-bottom: 8px;
    }
