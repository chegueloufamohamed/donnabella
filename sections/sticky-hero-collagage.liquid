      "default": 12,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "photo_shadow_y",
      "label": "Shadow Y offset",
      "min": 0,
      "max": 30,
      "step": 1,
      "default": 14,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "photo_shadow_blur",
      "label": "Shadow blur",
      "min": 10,
      "max": 90,
      "step": 2,
      "default": 44,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "photo_shadow_spread",
      "label": "Shadow spread",
      "min": -10,
      "max": 10,
      "step": 1,
      "default": -8,
      "unit": "px"
    },

    { "type": "header", "content": "Styling" },
    {
      "type": "range",
      "id": "radius",
      "label": "Corner radius",
      "min": 0,
      "max": 34,
      "step": 1,
      "default": 22,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "text_max_width",
      "label": "Text max width",
      "min": 320,
      "max": 900,
      "step": 10,
      "default": 720,
      "unit": "px"
    },

    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#ffffff" },
    { "type": "color", "id": "button_primary_bg", "label": "Primary button background", "default": "#ffffff" },
    { "type": "color", "id": "button_primary_text", "label": "Primary button text", "default": "#111111" },
    {
      "type": "range",
      "id": "button_radius",
      "label": "Button radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "default": 14,
      "unit": "px"
    }
  ],
  "presets": [
    { 
      "name": "Sticky Hero Collage"
    }
  ]
}
{% endschema %}