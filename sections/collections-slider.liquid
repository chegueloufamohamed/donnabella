      "type": "select", "id": "description_font_fallback", "label": "Font fallback", "default": "sans-serif",
      "options": [
        { "value": "serif",      "label": "Serif" },
        { "value": "sans-serif", "label": "Sans-serif" }
      ]
    },
    { "type": "range", "id": "description_size",        "label": "Size",           "min": 12, "max": 28,   "step": 1,  "unit": "px", "default": 16 },
    { "type": "range", "id": "description_max_width",   "label": "Max width",      "min": 400,"max": 1200, "step": 50, "unit": "px", "default": 700 },
    {
      "type": "select", "id": "description_weight", "label": "Weight", "default": "400",
      "options": [
        { "value": "300", "label": "Light" }, { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semi Bold" }
      ]
    },
    { "type": "color", "id": "description_color",       "label": "Color",          "default": "#555555" },
    { "type": "range", "id": "description_line_height", "label": "Line height",    "min": 10, "max": 20, "step": 1, "default": 16 },
    { "type": "range", "id": "description_gap",         "label": "Gap title→desc", "min": 0,  "max": 40, "step": 4, "unit": "px", "default": 12 },

    { "type": "header", "content": "Card Settings" },
    { "type": "range", "id": "cards_per_row", "label": "Cards per row",      "min": 2, "max": 5,   "step": 1,   "default": 4 },
    { "type": "range", "id": "card_gap",      "label": "Gap between cards",  "min": 10,"max": 50,  "step": 5,   "unit": "px", "default": 20 },
