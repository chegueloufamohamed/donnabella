{% liquid
  assign id = section.id
  assign desktop_video = section.settings.desktop_video
  assign desktop_thumb = section.settings.desktop_thumbnail
  assign mobile_video = section.settings.mobile_video
  assign mobile_thumb = section.settings.mobile_thumbnail
%}

<style>
  #shopify-section-{{ id }} {
    display: block;
    width: 100%;
    margin: 0;
    padding: 0;
    background: transparent;
  }

  #vs-{{ id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: transparent;
    aspect-ratio: 16 / 9;
  }

  #vs-{{ id }} .vs-thumb {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 10;
    opacity: 1;
    transition: opacity 0.6s ease;
  }

  #vs-{{ id }} .vs-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #vs-{{ id }} .vs-thumb.hidden {
    opacity: 0;
    pointer-events: none;
  }

  #vs-{{ id }} video.vs-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
    object-fit: cover;
    display: block;
    background: transparent;
  }

  @media (max-width: 768px) {
    #vs-{{ id }} {
      aspect-ratio: unset;
      width: 100vw;
      height: 100svh;
    }
  }
</style>

<div id="vs-{{ id }}">

  {% comment %} DESKTOP {% endcomment %}
  <div class="vs-desktop" style="position:absolute;inset:0;width:100%;height:100%;">

    {% if desktop_thumb != blank %}
      <div class="vs-thumb" id="vs-dthumb-{{ id }}">
        {{ desktop_thumb | image_url: width: 1600 | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          widths: '800, 1200, 1600',
          sizes: '100vw'
        }}
      </div>
    {% endif %}

    {% if desktop_video != blank %}
      <video
        class="vs-video"
        id="vs-dvid-{{ id }}"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        webkit-playsinline
      >
        <source src="{{ desktop_video }}" type="video/mp4">
      </video>
    {% endif %}

  </div>

  {% comment %} MOBILE {% endcomment %}
  <div class="vs-mobile" style="position:absolute;inset:0;width:100%;height:100%;display:none;">

    {% if mobile_thumb != blank %}
      <div class="vs-thumb" id="vs-mthumb-{{ id }}">
        {{ mobile_thumb | image_url: width: 800 | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          widths: '400, 600, 800',
          sizes: '100vw'
        }}
      </div>
    {% elsif desktop_thumb != blank %}
      <div class="vs-thumb" id="vs-mthumb-{{ id }}">
        {{ desktop_thumb | image_url: width: 800 | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          widths: '400, 600, 800',
          sizes: '100vw'
        }}
      </div>
    {% endif %}

    {% if mobile_video != blank %}
      <video
        class="vs-video"
        id="vs-mvid-{{ id }}"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        webkit-playsinline
      >
        <source src="{{ mobile_video }}" type="video/mp4">
      </video>
    {% elsif desktop_video != blank %}
      <video
        class="vs-video"
        id="vs-mvid-{{ id }}"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        webkit-playsinline
      >
        <source src="{{ desktop_video }}" type="video/mp4">
      </video>
    {% endif %}

  </div>

</div>

<script>
(function () {
  var isMobile = window.innerWidth <= 768;
  var id       = '{{ id }}';
  var wrapper  = document.getElementById('vs-' + id);
  if (!wrapper) return;

  var desktop = wrapper.querySelector('.vs-desktop');
  var mobile  = wrapper.querySelector('.vs-mobile');

  if (isMobile) {
    desktop.style.display = 'none';
    mobile.style.display  = 'block';
  } else {
    desktop.style.display = 'block';
    mobile.style.display  = 'none';
  }

  var thumbId = isMobile ? 'vs-mthumb-' + id : 'vs-dthumb-' + id;
  var vidId   = isMobile ? 'vs-mvid-'   + id : 'vs-dvid-'  + id;
  var thumb   = document.getElementById(thumbId);
  var video   = document.getElementById(vidId);

  if (!video) return;

  var faded = false;

  function fadeThumb() {
    if (faded || !thumb) return;
    faded = true;
    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        thumb.classList.add('hidden');
      });
    });
  }

  video.addEventListener('timeupdate', function () {
    if (video.currentTime > 0) fadeThumb();
  });

  video.addEventListener('playing', function () {
    setTimeout(fadeThumb, 200);
  });

  video.muted = true;
  video.play().catch(function () {});

  if (isMobile) {
    ['touchstart', 'touchend', 'click'].forEach(function (evt) {
      document.addEventListener(evt, function () {
        video.muted = true;
        video.play().catch(function () {});
      }, { once: true, passive: true });
    });
  }

})();
</script>

{% schema %}
{
  "name": "Video Section",
  "class": "shopify-section--video under-menu",
  "settings": [
    {
      "type": "header",
      "content": "Desktop"
    },
    {
      "type": "text",
      "id": "desktop_video",
      "label": "Desktop video URL",
      "info": "Go to Shopify Admin → Content → Files, upload your MP4, then copy and paste the file URL here."
    },
    {
      "type": "image_picker",
      "id": "desktop_thumbnail",
      "label": "Desktop thumbnail",
      "info": "Shown instantly on load, fades out when video starts. 1600x900px recommended."
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "text",
      "id": "mobile_video",
      "label": "Mobile video URL",
      "info": "Optional. Go to Shopify Admin → Content → Files and copy the URL of your mobile video. Falls back to desktop video if empty."
    },
    {
      "type": "image_picker",
      "id": "mobile_thumbnail",
      "label": "Mobile thumbnail",
      "info": "Optional. Falls back to desktop thumbnail if empty."
    }
  ],
  "presets": [
    {
      "name": "Video Section",
      "category": "Video"
    }
  ],
  "disabled_on": {
    "groups": ["*"]
  }
}
{% endschema %}