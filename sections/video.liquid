{% liquid
  assign id = section.id
  assign desktop_video = section.settings.desktop_video
  assign desktop_thumb = section.settings.desktop_thumbnail
  assign mobile_video = section.settings.mobile_video
  assign mobile_thumb = section.settings.mobile_thumbnail
%}

<style>
  #shopify-section-{{ id }} {
    display: block;
    width: 100%;
    margin: 0;
    padding: 0;
    background: transparent;
  }

  #vs-{{ id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: transparent;
    aspect-ratio: 16 / 9;
  }

  #vs-{{ id }} .vs-thumb {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 10;
    opacity: 1;
    transition: opacity 0.6s ease;
  }

  #vs-{{ id }} .vs-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #vs-{{ id }} .vs-thumb.hidden {
    opacity: 0;
    pointer-events: none;
  }

  #vs-{{ id }} video.vs-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 2;
    object-fit: cover;
    display: block;
    background: transparent;
  }

  @media (max-width: 768px) {
    #vs-{{ id }} {
      aspect-ratio: unset;
      width: 100vw;
      height: 100svh;
    }
  }
</style>

<div id="vs-{{ id }}">
  {% comment %}
    We only render the active viewport's thumbnail instantly in HTML.
    This prevents loading double thumbnails and ensures fast LCP.
  {% endcomment %}
  <div class="vs-desktop-thumb-wrap">
    {% if desktop_thumb != blank %}
      <div class="vs-thumb vs-desktop-only-thumb" id="vs-dthumb-{{ id }}">
        {{ desktop_thumb | image_url: width: 1600 | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          widths: '800, 1200, 1600',
          sizes: '100vw',
          alt: 'Desktop Video Thumbnail'
        }}
      </div>
    {% endif %}
  </div>

  <div class="vs-mobile-thumb-wrap" style="display:none;">
    {% if mobile_thumb != blank %}
      <div class="vs-thumb vs-mobile-only-thumb" id="vs-mthumb-{{ id }}">
        {{ mobile_thumb | image_url: width: 800 | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          widths: '400, 600, 800',
          sizes: '100vw',
          alt: 'Mobile Video Thumbnail'
        }}
      </div>
    {% elsif desktop_thumb != blank %}
      <div class="vs-thumb vs-mobile-only-thumb" id="vs-mthumb-{{ id }}">
        {{ desktop_thumb | image_url: width: 800 | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          widths: '400, 600, 800',
          sizes: '100vw',
          alt: 'Mobile Video Thumbnail'
        }}
      </div>
    {% endif %}
  </div>
</div>

<style>
  @media (max-width: 768px) {
    .vs-desktop-only-thumb { display: none !important; }
    .vs-mobile-thumb-wrap { display: block !important; }
  }
</style>

<script>
(function () {
  var isMobile = window.innerWidth <= 768;
  var id       = '{{ id }}';
  var wrapper  = document.getElementById('vs-' + id);
  if (!wrapper) return;

  var videoUrl = isMobile ? '{{ mobile_video | default: desktop_video }}' : '{{ desktop_video }}';
  var thumbId  = isMobile ? 'vs-mthumb-' + id : 'vs-dthumb-' + id;
  var thumb    = document.getElementById(thumbId);

  if (!videoUrl) return;

  var video = document.createElement('video');
  video.className = 'vs-video';
  video.id = isMobile ? 'vs-mvid-' + id : 'vs-dvid-' + id;
  video.autoplay = true;
  video.muted = true;
  video.loop = true;
  video.setAttribute('playsinline', '');
  video.setAttribute('webkit-playsinline', '');
  video.setAttribute('preload', 'auto');

  var source = document.createElement('source');
  source.src = videoUrl;
  source.type = 'video/mp4';
  video.appendChild(source);

  wrapper.appendChild(video);

  var faded = false;
  function fadeThumb() {
    if (faded || !thumb) return;
    faded = true;
    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        thumb.classList.add('hidden');
      });
    });
  }

  video.addEventListener('timeupdate', function () {
    if (video.currentTime > 0) fadeThumb();
  });

  video.addEventListener('playing', function () {
    setTimeout(fadeThumb, 200);
  });

  video.muted = true;
  video.play().catch(function () {});

  if (isMobile) {
    ['touchstart', 'touchend', 'click'].forEach(function (evt) {
      document.addEventListener(evt, function () {
        video.muted = true;
        video.play().catch(function () {});
      }, { once: true, passive: true });
    });
  }
})();
</script>

{% schema %}
{
  "name": "Video Section",
  "class": "shopify-section--video under-menu",
  "settings": [
    {
      "type": "header",
      "content": "Desktop"
    },
    {
      "type": "text",
      "id": "desktop_video",
      "label": "Desktop video URL",
      "info": "Go to Shopify Admin → Content → Files, upload your MP4, then copy and paste the file URL here."
    },
    {
      "type": "image_picker",
      "id": "desktop_thumbnail",
      "label": "Desktop thumbnail",
      "info": "Shown instantly on load, fades out when video starts. 1600x900px recommended."
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "text",
      "id": "mobile_video",
      "label": "Mobile video URL",
      "info": "Optional. Go to Shopify Admin → Content → Files and copy the URL of your mobile video. Falls back to desktop video if empty."
    },
    {
      "type": "image_picker",
      "id": "mobile_thumbnail",
      "label": "Mobile thumbnail",
      "info": "Optional. Falls back to desktop thumbnail if empty."
    }
  ],
  "presets": [
    {
      "name": "Video Section",
      "category": "Video"
    }
  ],
  "disabled_on": {
    "groups": ["*"]
  }
}
{% endschema %}