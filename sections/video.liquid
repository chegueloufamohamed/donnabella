<style>
/* FIX #1: Keep Plyr transparent (prevents Plyr's black background) */
.plyr, 
.plyr--full-ui, 
.plyr--video,
.plyr--html5,
.plyr__video-wrapper,
.plyr__video-embed {
  background: transparent !important;
  background-color: transparent !important;
}

/* FIX #2: Video wrapper needs DARK background (prevents white body showing) */
#shopify-section-{{ section.id }} .video-wrapper,
#shopify-section-{{ section.id }} .video-section {
  background: #000 !important;
  background-color: #000 !important;
}

/* FIX #3: Poster images stay on TOP with dark fallback */
#shopify-section-{{ section.id }} .video-wrapper__image {
  background: #000 !important;
  z-index: 10 !important;
}

/* FIX #4: Video elements stay BELOW poster */
#shopify-section-{{ section.id }} video,
#shopify-section-{{ section.id }} iframe,
#shopify-section-{{ section.id }} .plyr__video-embed {
  z-index: 2 !important;
}

/* FIX #5: Light controls (not black) */
#shopify-section-{{ section.id }} .plyr__controls {
  background: rgba(255, 255, 255, 0.3) !important;
}

/* FIX #6: Keep poster visible during buffering */
#shopify-section-{{ section.id }} .plyr--buffering .video-wrapper__image {
  opacity: 1 !important;
  z-index: 10 !important;
}

/* FIX #7: Performance optimization */
#shopify-section-{{ section.id }} .plyr,
#shopify-section-{{ section.id }} .video-wrapper,
#shopify-section-{{ section.id }} .video-wrapper__image {
  will-change: auto;
  contain: layout style paint;
}

/* FIX #8: Make control icons (especially the sound icon) white */
#shopify-section-{{ section.id }} .plyr {
  --plyr-video-control-color: #ffffff !important;
  --plyr-video-control-color-hover: #ffffff !important;
  --plyr-color-main: #ffffff !important;
}

#shopify-section-{{ section.id }} .plyr__controls,
#shopify-section-{{ section.id }} .plyr__controls .plyr__control,
#shopify-section-{{ section.id }} .plyr__controls svg,
#shopify-section-{{ section.id }} .plyr__controls button svg,
#shopify-section-{{ section.id }} .plyr__control[data-plyr="mute"] svg {
  color: #ffffff !important;
  fill: #ffffff !important;
  stroke: #ffffff !important;
}
</style>