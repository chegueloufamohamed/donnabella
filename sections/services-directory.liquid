{% comment %}
  Services Directory — Donna Bella
  Bilingual page index listing all services: Massage, Nails, Hair Care, Skin Care, Waxing, Eyelashes & Brows.
  Organized with Women first, Couples second, Men third.
  Save as: sections/services-directory.liquid
{% endcomment %}

{% assign current_locale = request.locale.iso_code %}
{% assign is_arabic = false %}
{% if current_locale contains 'ar' %}
  {% assign is_arabic = true %}
{% endif %}

{% assign dir = 'ltr' %}
{% if is_arabic %}
  {% assign dir = 'rtl' %}
{% endif %}

<div class="sd-{{ section.id }}" dir="{{ dir }}">
<style>
  .sd-{{ section.id }} {
    --serif:   'Cormorant Garamond', Georgia, serif;
    --sans:    'Montserrat', sans-serif;
    --arabic:  'Tajawal', sans-serif;

    --font-main:    {% if is_arabic %}var(--arabic){% else %}var(--sans){% endif %};
    --font-display: {% if is_arabic %}'Cairo', sans-serif{% else %}var(--serif){% endif %};

    /* Colour palette — matches the Women/Him/Couples service pages */
    --bg:          #405264;
    --bg-dark:     #2f3d4d;
    --bg-deeper:   #354656;
    --gold:        #c9a96e;
    --gold-line:   rgba(201, 169, 110, 0.35);
    --blush:       #c9a0a0;
    --blush-line:  rgba(201, 160, 160, 0.3);
    --bg-card:     rgba(255, 255, 255, 0.06);
    --border:      rgba(255, 255, 255, 0.11);
    --accent-her:     var(--blush);
    --accent-him:     rgba(160, 190, 220, 0.9);
    --accent-couples: rgba(201, 169, 110, 0.9);
    --white:      #ffffff;
    --white-60:   rgba(255, 255, 255, 0.6);
    --white-30:   rgba(255, 255, 255, 0.3);
    --white-10:   rgba(255, 255, 255, 0.1);

    background-color: var(--bg);
    color: var(--white);
    font-family: var(--font-main);
    padding: 80px 20px 120px;
    min-height: 100vh;
  }

  .sd-{{ section.id }} .sd-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* ── Header ─────────────────────────────────────────────────── */
  .sd-{{ section.id }} .sd-header {
    text-align: center;
    margin-bottom: 70px;
    position: relative;
  }

  .sd-{{ section.id }} .sd-header::after {
    content: '';
    display: block;
    width: 60px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    margin: 24px auto 0;
  }

  .sd-{{ section.id }} .sd-title {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 64px);
    font-weight: 300;
    {% unless is_arabic %}font-style: italic;{% endunless %}
    color: var(--white);
    margin: 0 0 16px;
    letter-spacing: -0.01em;
    text-shadow: 0 0 60px rgba(255,255,255,0.1);
  }

  .sd-{{ section.id }} .sd-title span {
    color: var(--gold);
    {% unless is_arabic %}font-style: normal; font-weight: 500;{% endunless %}
  }

  .sd-{{ section.id }} .sd-subtitle {
    font-size: 11px;
    font-weight: 600;
    color: var(--white-60);
    letter-spacing: {% if is_arabic %}0{% else %}5px{% endif %};
    text-transform: uppercase;
    margin: 0;
  }

  /* ── Grid ────────────────────────────────────────────────────── */
  .sd-{{ section.id }} .sd-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  @media (max-width: 991px) {
    .sd-{{ section.id }} .sd-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .sd-{{ section.id }} .sd-grid { grid-template-columns: 1fr; }
    .sd-{{ section.id }} { padding: 60px 16px 80px; }
  }

  /* ── Cards ───────────────────────────────────────────────────── */
  .sd-{{ section.id }} .sd-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    padding: 36px 30px 32px;
    border-radius: 24px;
    backdrop-filter: blur(30px);
    -webkit-backdrop-filter: blur(30px);
    transition: transform 0.4s cubic-bezier(0.23,1,0.32,1), box-shadow 0.4s ease, border-color 0.3s;
    position: relative;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(0,0,0,0.2), inset 0 1px 0 rgba(255,255,255,0.12);
  }

  /* Top shimmer line */
  .sd-{{ section.id }} .sd-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.55) 50%, transparent 100%);
    opacity: 0.5;
    transition: opacity 0.3s;
  }

  /* Radial glass sheen */
  .sd-{{ section.id }} .sd-card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 24px;
    background: radial-gradient(ellipse 80% 50% at 50% 0%, rgba(255,255,255,0.05) 0%, transparent 60%);
    pointer-events: none;
  }

  /* Accent top bar on hover — colour per card */
  .sd-{{ section.id }} .sd-card .sd-card-accent {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    opacity: 0;
    transition: opacity 0.3s;
    border-radius: 24px 24px 0 0;
  }

  .sd-{{ section.id }} .sd-card:hover { transform: translateY(-6px); border-color: var(--gold-line); box-shadow: 0 12px 40px rgba(0,0,0,0.25); }
  .sd-{{ section.id }} .sd-card:hover::before { opacity: 1; }
  .sd-{{ section.id }} .sd-card:hover .sd-card-accent { opacity: 1; }

  /* ── Card Title ──────────────────────────────────────────────── */
  .sd-{{ section.id }} .sd-card-title {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 400;
    color: var(--white);
    margin: 0 0 25px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--white-10);
    display: flex;
    align-items: center;
    justify-content: space-between;
    text-shadow: 0 0 20px rgba(255,255,255,0.15);
    position: relative;
    z-index: 1;
  }

  .sd-{{ section.id }} .sd-card-title .sd-card-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 14px;
    font-weight: 300;
    font-style: italic;
    opacity: 0.4;
    letter-spacing: 1px;
  }

  /* ── Group labels (Women / Couples / Men) ────────────────────── */
  .sd-{{ section.id }} .sd-group {
    margin-bottom: 22px;
    position: relative;
    z-index: 1;
  }
  .sd-{{ section.id }} .sd-group:last-child { margin-bottom: 0; }

  .sd-{{ section.id }} .sd-group-title {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: {% if is_arabic %}0{% else %}4px{% endif %};
    text-transform: uppercase;
    margin: 0 0 12px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .sd-{{ section.id }} .sd-group-title::after {
    content: '';
    flex: 1;
    height: 1px;
  }

  /* Her group */
  .sd-{{ section.id }} .sd-group--her .sd-group-title { color: var(--blush); }
  .sd-{{ section.id }} .sd-group--her .sd-group-title::after { background: var(--blush-line); }
  /* Couples group */
  .sd-{{ section.id }} .sd-group--couples .sd-group-title { color: var(--gold); }
  .sd-{{ section.id }} .sd-group--couples .sd-group-title::after { background: var(--gold-line); }
  /* Him group */
  .sd-{{ section.id }} .sd-group--him .sd-group-title { color: rgba(160,190,220,0.9); }
  .sd-{{ section.id }} .sd-group--him .sd-group-title::after { background: rgba(160,190,220,0.2); }

  /* ── Service links ───────────────────────────────────────────── */
  .sd-{{ section.id }} .sd-list { list-style: none; padding: 0; margin: 0; }
  .sd-{{ section.id }} .sd-item { margin-bottom: 8px; }
  .sd-{{ section.id }} .sd-item:last-child { margin-bottom: 0; }

  .sd-{{ section.id }} .sd-link {
    font-family: var(--font-main);
    font-size: 13px;
    font-weight: 300;
    color: var(--white-60);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    transition: color 0.25s, transform 0.25s;
    letter-spacing: {% if is_arabic %}0{% else %}0.3px{% endif %};
  }

  .sd-{{ section.id }} .sd-link::before {
    content: '';
    display: block;
    width: 4px; height: 4px;
    border-radius: 50%;
    flex-shrink: 0;
    transition: opacity 0.25s;
    opacity: 0.5;
  }

  /* Dot colour per group */
  .sd-{{ section.id }} .sd-group--her     .sd-link::before { background: var(--blush); opacity: 0.7; }
  .sd-{{ section.id }} .sd-group--couples .sd-link::before { background: var(--gold); opacity: 0.7; }
  .sd-{{ section.id }} .sd-group--him     .sd-link::before { background: rgba(160,190,220,0.9); }

  .sd-{{ section.id }} .sd-link:hover { color: var(--white); }
  .sd-{{ section.id }} .sd-link:hover::before { opacity: 1; }

  .sd-{{ section.id }}[dir="ltr"] .sd-link:hover { transform: translateX(4px); }
  .sd-{{ section.id }}[dir="rtl"] .sd-link:hover { transform: translateX(-4px); }

  .sd-{{ section.id }} .sd-empty {
    font-size: 12px;
    color: var(--white-30);
    font-style: italic;
    margin: 0;
  }
</style>

