    { "type": "image_picker", "id": "avatar_3", "label": "Avatar 3" },
    { "type": "image_picker", "id": "avatar_4", "label": "Avatar 4" },

    { "type": "header", "content": "🇬🇧 Support Info — English" },
    { "type": "text", "id": "support_title",  "label": "Support title (EN)",  "default": "Our team is available:" },
    { "type": "text", "id": "support_hours",  "label": "Support hours (EN)",  "default": "Saturday to Thursday: 9am – 10pm" },
    { "type": "text", "id": "response_time",  "label": "Response time (EN)",  "default": "Average response time: under 1 hour" },

    { "type": "header", "content": "🇸🇦 معلومات الدعم — العربية" },
    { "type": "text", "id": "support_title_ar", "label": "عنوان الدعم (AR)",   "default": "فريقنا متاح:" },
    { "type": "text", "id": "support_hours_ar", "label": "ساعات العمل (AR)",   "default": "السبت إلى الخميس: ٩ص – ١٠م" },
