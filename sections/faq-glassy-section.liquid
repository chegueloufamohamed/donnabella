        { "type": "header",   "content": "🇬🇧 Question & Answer — English" },
        { "type": "text",     "id": "question",    "label": "Question (EN)", "default": "How do I book a home beauty service?" },
        { "type": "richtext", "id": "answer",      "label": "Answer (EN)",   "default": "<p>Simply choose your service, pick a date and time, and our specialist will come straight to your door.</p>" },
        { "type": "header",   "content": "🇸🇦 السؤال والجواب — العربية" },
        { "type": "text",     "id": "question_ar", "label": "السؤال (AR)",   "default": "كيف أحجز خدمة تجميل منزلية؟" },
        { "type": "richtext", "id": "answer_ar",   "label": "الإجابة (AR)",  "default": "<p>اختاري خدمتكِ، حددي الموعد المناسب، وستصل المختصة إلى باب منزلكِ.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ - Glassy",
      "category": "FAQ",
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "question": "How do I book a home beauty service?",
