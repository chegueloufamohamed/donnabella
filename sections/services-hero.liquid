{% comment %}
  Section: Service Hero (Bilingual EN/AR)
  - Desktop/Mobile images
  - Overlay color + opacity
  - Bilingual title/subtitle fields in schema (EN + AR)
  - Auto-switch based on Shopify language (localization.language.iso_code)
  - RTL support for Arabic (direction + alignment override option)
{% endcomment %}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@300;400;500;600;700;800;900&family=Montserrat:wght@300;400;500;600;700;800;900&family=Merriweather:wght@300;400;700;900&family=Cormorant+Garamond:wght@300;400;500;600;700&family=Lato:wght@300;400;700;900&family=Raleway:wght@300;400;500;600;700;800;900&family=Poppins:wght@300;400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700;800;900&family=EB+Garamond:wght@400;500;600;700;800&family=Cinzel:wght@400;500;600;700;800;900&family=Crimson+Text:wght@400;600;700&family=Roboto:wght@300;400;500;700;900&family=Open+Sans:wght@300;400;600;700;800&family=Nunito:wght@300;400;600;700;800;900&family=Work+Sans:wght@300;400;500;600;700;800;900&family=Oswald:wght@300;400;500;600;700&display=swap');

  {%- liquid
    assign is_ar = false
    if localization.language.iso_code == 'ar'
      assign is_ar = true
    endif

    # Pull bilingual fields
    assign hero_title = section.settings.title_en
    assign hero_subtitle = section.settings.subtitle_en

    if is_ar
      if section.settings.title_ar != blank
        assign hero_title = section.settings.title_ar
      endif
      if section.settings.subtitle_ar != blank
        assign hero_subtitle = section.settings.subtitle_ar
      endif
    endif

    # Text align override for Arabic
    assign final_text_align = section.settings.text_align
    if is_ar and section.settings.force_rtl_text_align
      assign final_text_align = 'right'
    endif
  -%}

  #service-hero-{{ section.id }} {
    position: relative;
    width: 100%;
    height: {{ section.settings.hero_height_desktop }}vh;
    min-height: {{ section.settings.min_height_desktop }}px;
    overflow: hidden;
    display: flex;
    align-items: {{ section.settings.content_vertical_align }};
    justify-content: {{ section.settings.content_horizontal_align }};
  }

  /* Optional RTL direction for Arabic */
  #service-hero-{{ section.id }}.is-rtl {
    direction: rtl;
  }

  /* Desktop Image */
  #service-hero-{{ section.id }} .hero-image-desktop {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.image_fit }};
    object-position: {{ section.settings.image_position }};
    display: block;
  }

  /* Mobile Image - Hidden by default */
  #service-hero-{{ section.id }} .hero-image-mobile {
    display: none;
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.image_fit_mobile }};
    object-position: {{ section.settings.image_position_mobile }};
  }

  /* Placeholder when no image */
  #service-hero-{{ section.id }} .hero-placeholder {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.5);
    font-size: 18px;
    z-index: 0;
  }

  /* Color Overlay */
  #service-hero-{{ section.id }} .hero-overlay {
    position: absolute;
    inset: 0;
    {% assign overlay_color = section.settings.overlay_color %}
    {% assign overlay_r = overlay_color | color_extract: 'red' %}
    {% assign overlay_g = overlay_color | color_extract: 'green' %}
    {% assign overlay_b = overlay_color | color_extract: 'blue' %}
    background: rgba({{ overlay_r }}, {{ overlay_g }}, {{ overlay_b }}, {{ section.settings.overlay_opacity | divided_by: 100.0 }});
    z-index: 1;
  }

  /* Content Container */
  #service-hero-{{ section.id }} .hero-content {
    position: relative;
    z-index: 2;
    text-align: {{ final_text_align }};
    padding: {{ section.settings.content_padding }}px;
    max-width: {{ section.settings.content_max_width }}px;
    width: 100%;
  }

  /* Title */
  #service-hero-{{ section.id }} .hero-title {
    font-family: '{{ section.settings.title_font_family }}', serif;
    font-size: {{ section.settings.title_size_desktop }}px;
    font-weight: {{ section.settings.title_font_weight }};
    letter-spacing: {{ section.settings.title_letter_spacing }}px;
    line-height: {{ section.settings.title_line_height }};
    color: {{ section.settings.title_color }};
    margin: 0;
    text-transform: {{ section.settings.title_text_transform }};
    {% if section.settings.enable_text_shadow %}
    text-shadow: {{ section.settings.text_shadow_x }}px {{ section.settings.text_shadow_y }}px {{ section.settings.text_shadow_blur }}px rgba(0, 0, 0, {{ section.settings.text_shadow_opacity | divided_by: 100.0 }});
    {% endif %}
    {% if section.settings.enable_title_animation %}
    opacity: 0;
    transform: translateY(30px);
    animation: fadeInUp 1s ease forwards;
    animation-delay: 0.3s;
    {% endif %}
  }

  /* Subtitle */
  #service-hero-{{ section.id }} .hero-subtitle {
    font-family: '{{ section.settings.subtitle_font_family }}', sans-serif;
    font-size: {{ section.settings.subtitle_size_desktop }}px;
    font-weight: {{ section.settings.subtitle_font_weight }};
    letter-spacing: {{ section.settings.subtitle_letter_spacing }}px;
    line-height: {{ section.settings.subtitle_line_height }};
    color: {{ section.settings.subtitle_color }};
    margin: {{ section.settings.subtitle_margin_top }}px 0 0;
    {% if section.settings.enable_text_shadow %}
    text-shadow: {{ section.settings.text_shadow_x }}px {{ section.settings.text_shadow_y }}px {{ section.settings.text_shadow_blur }}px rgba(0, 0, 0, {{ section.settings.text_shadow_opacity | divided_by: 100.0 }});
    {% endif %}
    {% if section.settings.enable_title_animation %}
    opacity: 0;
    transform: translateY(30px);
    animation: fadeInUp 1s ease forwards;
    animation-delay: 0.5s;
    {% endif %}
  }

  @keyframes fadeInUp {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Mobile Styles */
  @media (max-width: 768px) {
    #service-hero-{{ section.id }} {
      height: {{ section.settings.hero_height_mobile }}vh;
      min-height: {{ section.settings.min_height_mobile }}px;
    }

    {% if section.settings.mobile_image != blank %}
    #service-hero-{{ section.id }} .hero-image-desktop { display: none; }
    #service-hero-{{ section.id }} .hero-image-mobile { display: block; }
    {% endif %}

    #service-hero-{{ section.id }} .hero-content {
      padding: {{ section.settings.content_padding_mobile }}px;
    }

    #service-hero-{{ section.id }} .hero-title {
      font-size: {{ section.settings.title_size_mobile }}px;
    }

    #service-hero-{{ section.id }} .hero-subtitle {
      font-size: {{ section.settings.subtitle_size_mobile }}px;
      margin-top: {{ section.settings.subtitle_margin_top | divided_by: 2 }}px;
    }
  }
</style>

{%- liquid
  assign section_classes = ''
  if is_ar and section.settings.enable_rtl_on_arabic
    assign section_classes = 'is-rtl'
  endif
-%}

<section id="service-hero-{{ section.id }}" class="{{ section_classes }}">
  <!-- Desktop Image -->
  {% if section.settings.desktop_image %}
    <img
      src="{{ section.settings.desktop_image | image_url: width: 1920 }}"
      srcset="
        {{ section.settings.desktop_image | image_url: width: 1024 }} 1024w,
        {{ section.settings.desktop_image | image_url: width: 1440 }} 1440w,
        {{ section.settings.desktop_image | image_url: width: 1920 }} 1920w
      "
      sizes="100vw"
      alt="{{ section.settings.desktop_image.alt | default: hero_title }}"
      class="hero-image-desktop"
      loading="eager"
    >
  {% else %}
    <div class="hero-placeholder">Add desktop image in settings</div>
  {% endif %}

  <!-- Mobile Image -->
  {% if section.settings.mobile_image %}
    <img
      src="{{ section.settings.mobile_image | image_url: width: 768 }}"
      srcset="
        {{ section.settings.mobile_image | image_url: width: 480 }} 480w,
        {{ section.settings.mobile_image | image_url: width: 768 }} 768w
      "
      sizes="100vw"
      alt="{{ section.settings.mobile_image.alt | default: hero_title }}"
      class="hero-image-mobile"
      loading="eager"
    >
  {% endif %}

  <!-- Color Overlay -->
  <div class="hero-overlay"></div>

  <!-- Content -->
  <div class="hero-content">
    {% if hero_title != blank %}
      <h1 class="hero-title">{{ hero_title }}</h1>
    {% endif %}

    {% if hero_subtitle != blank %}
      <p class="hero-subtitle">{{ hero_subtitle }}</p>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Service Hero (EN/AR)",
  "settings": [
    {
      "type": "header",
      "content": "🌐 Language"
    },
    {
      "type": "checkbox",
      "id": "enable_rtl_on_arabic",
      "label": "Enable RTL direction on Arabic",
      "default": true
