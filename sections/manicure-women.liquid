{% comment %}
  Nail Treatment & Extensions — Belladona Care
  Bilingual section: auto-detects EN/AR via request.locale
  Save as: sections/nails.liquid
  Add to page via: Customize → Page → Add section → Nails
{% endcomment %}

{% assign current_locale = request.locale.iso_code %}
{% assign is_arabic = false %}
{% if current_locale contains 'ar' %}
  {% assign is_arabic = true %}
{% endif %}

{% assign dir = 'ltr' %}
{% if is_arabic %}
  {% assign dir = 'rtl' %}
{% endif %}

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Jost:wght@200;300;400;500;600&family=Cairo:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<div class="nls-{{ section.id }}" dir="{{ dir }}">
<style>
  .nls-{{ section.id }} .nls-icon {
  font-size: 0 !important;
  line-height: 0 !important;
  margin-bottom: 0 !important;
  display: none !important;
}
  .nls-{{ section.id }} {
    --bg: {{ section.settings.bg_color }};
    --bg-dark: #2f3d4d; --bg-deeper: #354656;
    --gold: {{ section.settings.gold_color }};
    --gold-line: rgba(201,169,110,0.35);
    --blush: {{ section.settings.blush_color }};
    --blush-dim: rgba(201,160,160,0.1); --blush-line: rgba(201,160,160,0.3);
    --white: #ffffff; --white-60: rgba(255,255,255,0.6);
    --glass: rgba(255,255,255,0.06); --glass-b: rgba(255,255,255,0.11);
    --serif: 'Cormorant Garamond', Georgia, serif;
    --sans: 'Jost', sans-serif;
    --arabic: 'Cairo', sans-serif;
    --font-main: {% if is_arabic %}var(--arabic){% else %}var(--sans){% endif %};
    --font-display: {% if is_arabic %}var(--arabic){% else %}var(--serif){% endif %};
    background-color: var(--bg);
    color: var(--white);
    font-family: var(--font-main);
    font-weight: 300;
    overflow-x: hidden;
  }

  @keyframes nls-fadeUp-{{ section.id }} { to { opacity: 1; transform: translateY(0); } }
  @keyframes nls-ring-{{ section.id }} {
    0%,100% { opacity: 0.35; transform: translate(-50%,-50%) scale(1); }
    50%      { opacity: 0.8;  transform: translate(-50%,-50%) scale(1.05); }
  }

  /* ── HERO ── */
  .nls-{{ section.id }} .nls-hero {
    position: relative; min-height: 54vh;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center; padding: 80px 30px 50px; overflow: hidden;
  }
  .nls-{{ section.id }} .nls-hero::before {
    content: ''; position: absolute; width: 600px; height: 600px; border-radius: 50%;
    background: radial-gradient(circle, rgba(201,160,160,0.09) 0%, transparent 70%);
    top: 50%; left: 50%; transform: translate(-50%,-50%); pointer-events: none;
  }
  .nls-{{ section.id }} .nls-hero::after {
    content: ''; position: absolute; width: 360px; height: 360px; border-radius: 50%;
    border: 1px solid var(--blush-line); top: 50%; left: 50%;
    transform: translate(-50%,-50%); pointer-events: none;
    animation: nls-ring-{{ section.id }} 4s ease-in-out infinite;
  }
  .nls-{{ section.id }} .nls-eyebrow {
    font-size: 11px; font-weight: 500;
    letter-spacing: {% if is_arabic %}0.05em{% else %}0.42em{% endif %};
    {% unless is_arabic %}text-transform: uppercase;{% endunless %}
    color: var(--blush); margin-bottom: 20px; position: relative; z-index: 1;
    opacity: 0; transform: translateY(16px);
    animation: nls-fadeUp-{{ section.id }} 0.8s ease 0.2s forwards;
  }
  .nls-{{ section.id }} .nls-title {
    font-family: var(--font-display);
    font-size: clamp(48px, 9vw, 94px);
    font-weight: {% if is_arabic %}400{% else %}300{% endif %};
    font-style: {% if is_arabic %}normal{% else %}italic{% endif %};
    line-height: {% if is_arabic %}1.2{% else %}0.95{% endif %};
    color: var(--white); position: relative; z-index: 1;
    opacity: 0; transform: translateY(20px);
    animation: nls-fadeUp-{{ section.id }} 0.9s ease 0.4s forwards;
  }
  .nls-{{ section.id }} .nls-title span { color: var(--gold); font-style: normal; font-weight: 500; }
  .nls-{{ section.id }} .nls-desc {
    margin-top: 26px; font-size: 13px;
    letter-spacing: {% if is_arabic %}0.05em{% else %}0.14em{% endif %};
    {% unless is_arabic %}text-transform: uppercase;{% endunless %}
    color: var(--white-60); position: relative; z-index: 1;
    opacity: 0; transform: translateY(16px);
    animation: nls-fadeUp-{{ section.id }} 0.9s ease 0.6s forwards;
  }
  .nls-{{ section.id }} .nls-divider {
    margin-top: 40px; width: 1px; height: 60px;
    background: linear-gradient(to bottom, var(--gold), transparent);
    opacity: 0; animation: nls-fadeUp-{{ section.id }} 0.9s ease 0.8s forwards;
  }

  /* ── LAYOUT ── */
  .nls-{{ section.id }} .nls-section { position: relative; z-index: 1; padding: 52px 0 62px; }
  .nls-{{ section.id }} .nls-section + .nls-section { padding-top: 0; }
  .nls-{{ section.id }} .nls-inner { max-width: 1160px; margin: 0 auto; padding: 0 30px; }

  /* ── SECTION LABEL ── */
  .nls-{{ section.id }} .nls-label {
    display: flex; align-items: center; gap: 18px; margin-bottom: 42px;
    opacity: 0;
    transform: translateX({% if is_arabic %}20px{% else %}-20px{% endif %});
    transition: opacity 0.7s ease, transform 0.7s ease;
  }
  .nls-{{ section.id }} .nls-label.visible { opacity: 1; transform: translateX(0); }
  .nls-{{ section.id }} .nls-label-line {
    flex: 1; height: 1px;
    background: linear-gradient(to {% if is_arabic %}left{% else %}right{% endif %}, var(--gold-line), transparent);
  }
  .nls-{{ section.id }} .nls-label-text {
    font-size: 10px; font-weight: 500;
    letter-spacing: {% if is_arabic %}0.05em{% else %}0.45em{% endif %};
    {% unless is_arabic %}text-transform: uppercase;{% endunless %}
    color: var(--gold); white-space: nowrap;
  }

  /* ── HERO TRIO ── */
  .nls-{{ section.id }} .nls-trio { display: grid; grid-template-columns: 1fr 1fr 2fr; gap: 2px; margin-bottom: 2px; }
  .nls-{{ section.id }} .nls-classic {
    background: var(--glass); border: 1px solid var(--glass-b);
    padding: 34px 28px; cursor: default; display: flex; flex-direction: column;
    opacity: 0; transform: translateY(22px);
    transition: opacity 0.65s ease, transform 0.65s ease, background 0.3s, border-color 0.3s;
  }
  .nls-{{ section.id }} .nls-classic.visible { opacity: 1; transform: translateY(0); }
  .nls-{{ section.id }} .nls-classic:hover { background: rgba(255,255,255,0.1); border-color: var(--gold-line); }

  .nls-{{ section.id }} .nls-combo {
    position: relative;
    background: linear-gradient(135deg, rgba(201,169,110,0.13) 0%, rgba(201,169,110,0.03) 100%);
    border: 1px solid var(--gold-line); padding: 38px 38px 34px;
    cursor: default; display: flex; flex-direction: column; overflow: hidden;
    opacity: 0; transform: translateY(22px);
    transition: opacity 0.65s ease, transform 0.65s ease, background 0.4s;
  }
  .nls-{{ section.id }} .nls-combo.visible { opacity: 1; transform: translateY(0); }
  .nls-{{ section.id }} .nls-combo:hover { background: linear-gradient(135deg, rgba(201,169,110,0.2) 0%, rgba(201,169,110,0.06) 100%); }
  .nls-{{ section.id }} .nls-combo::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(to right, transparent 10%, var(--gold) 50%, transparent 90%); }
  .nls-{{ section.id }} .nls-combo-bg {
    position: absolute; bottom: 10px;
    {% if is_arabic %}left{% else %}right{% endif %}: 20px;
    font-family: var(--serif); font-size: 100px; font-weight: 300;
    color: rgba(201,169,110,0.07); line-height: 1; user-select: none;
  }

  /* ── CARD PARTS ── */
  .nls-{{ section.id }} .nls-icon { font-size: 20px; margin-bottom: 14px; display: block; }
  .nls-{{ section.id }} .nls-ctag {
    font-size: 9px; font-weight: 500;
    letter-spacing: {% if is_arabic %}0.05em{% else %}0.42em{% endif %};
    {% unless is_arabic %}text-transform: uppercase;{% endunless %}
    color: var(--gold); margin-bottom: 10px;
  }
  .nls-{{ section.id }} .nls-ctag.blush { color: var(--blush); }
  .nls-{{ section.id }} .nls-ctitle {
    font-family: var(--font-display); font-size: 22px;
    font-weight: {% if is_arabic %}500{% else %}400{% endif %};
    color: var(--white); margin-bottom: 4px; line-height: 1.3;
  }
  .nls-{{ section.id }} .nls-combo .nls-ctitle { font-size: 30px; }
  .nls-{{ section.id }} .nls-csub {
    font-family: var(--font-display);
    font-style: {% if is_arabic %}normal{% else %}italic{% endif %};
    font-size: 12px; color: var(--gold); margin-bottom: 10px; opacity: 0.9;
  }
  .nls-{{ section.id }} .nls-cdesc { font-size: 11.5px; line-height: 1.72; color: var(--white-60); margin-bottom: 20px; flex: 1; }
  .nls-{{ section.id }} .nls-cfoot { display: flex; align-items: flex-end; justify-content: space-between; border-top: 1px solid var(--glass-b); padding-top: 14px; margin-top: auto; }
  .nls-{{ section.id }} .nls-cprice { font-family: var(--serif); font-size: 28px; font-weight: 300; color: var(--white); }
  .nls-{{ section.id }} .nls-cprice sup { font-size: 11px; font-family: var(--sans); vertical-align: super; opacity: 0.7; }
  .nls-{{ section.id }} .nls-combo .nls-cprice { font-size: 42px; }
  .nls-{{ section.id }} .nls-cdur { font-size: 10px; color: var(--white-60); letter-spacing: 0.06em; text-align: {% if is_arabic %}start{% else %}right{% endif %}; line-height: 1.5; }
  .nls-{{ section.id }} .nls-cdur span { display: block; color: var(--gold); font-size: 13px; margin-bottom: 2px; }

  /* ── GRIDS ── */
  .nls-{{ section.id }} .nls-3grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; }
  .nls-{{ section.id }} .nls-2grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2px; }

  /* ── TILE ── */
  .nls-{{ section.id }} .nls-tile {
    background: var(--glass); border: 1px solid var(--glass-b);
    padding: 30px 26px 26px; cursor: default; display: flex; flex-direction: column;
    opacity: 0; transform: translateY(20px);
    transition: opacity 0.65s ease, transform 0.65s ease, background 0.3s, border-color 0.3s;
  }
  .nls-{{ section.id }} .nls-tile.visible { opacity: 1; transform: translateY(0); }
  .nls-{{ section.id }} .nls-tile:hover { background: rgba(255,255,255,0.1); border-color: var(--gold-line); }
  .nls-{{ section.id }} .nls-tile.blush-bg { background: linear-gradient(135deg, var(--blush-dim) 0%, rgba(201,160,160,0.02) 100%); border-color: var(--blush-line); }
  .nls-{{ section.id }} .nls-tile.blush-bg:hover { background: linear-gradient(135deg, rgba(201,160,160,0.16) 0%, rgba(201,160,160,0.04) 100%); }
  .nls-{{ section.id }} .nls-tile.gold-bg { background: linear-gradient(135deg, rgba(201,169,110,0.12) 0%, rgba(201,169,110,0.03) 100%); border-color: var(--gold-line); position: relative; }
  .nls-{{ section.id }} .nls-tile.gold-bg::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(to right, transparent 10%, var(--gold) 50%, transparent 90%); }
  .nls-{{ section.id }} .nls-ttag {
    font-size: 9px; font-weight: 500;
    letter-spacing: {% if is_arabic %}0.05em{% else %}0.4em{% endif %};
    {% unless is_arabic %}text-transform: uppercase;{% endunless %}
    color: var(--gold); margin-bottom: 8px;
  }
  .nls-{{ section.id }} .nls-ttag.blush { color: var(--blush); }
  .nls-{{ section.id }} .nls-ttitle { font-family: var(--font-display); font-size: 20px; font-weight: {% if is_arabic %}500{% else %}400{% endif %}; color: var(--white); margin-bottom: 4px; line-height: 1.3; }
  .nls-{{ section.id }} .nls-tsub { font-family: var(--font-display); font-style: {% if is_arabic %}normal{% else %}italic{% endif %}; font-size: 11px; color: var(--gold); margin-bottom: 10px; opacity: 0.85; }
  .nls-{{ section.id }} .nls-tsub.blush { color: var(--blush); }
  .nls-{{ section.id }} .nls-tdesc { font-size: 11.5px; line-height: 1.7; color: var(--white-60); margin-bottom: 18px; flex: 1; }
  .nls-{{ section.id }} .nls-tfoot { display: flex; align-items: flex-end; justify-content: space-between; border-top: 1px solid var(--glass-b); padding-top: 12px; margin-top: auto; }
  .nls-{{ section.id }} .nls-tprice { font-family: var(--serif); font-size: 26px; font-weight: 300; color: var(--white); }
  .nls-{{ section.id }} .nls-tprice sup { font-size: 11px; font-family: var(--sans); vertical-align: super; opacity: 0.7; }
  .nls-{{ section.id }} .nls-tdur { font-size: 10px; color: var(--white-60); letter-spacing: 0.06em; }

  /* ── FEATURE CARD ── */
  .nls-{{ section.id }} .nls-feat {
    position: relative; background: var(--glass); border: 1px solid var(--glass-b);
    padding: 40px 44px; display: grid; grid-template-columns: 1fr auto;
    gap: 40px; align-items: center; overflow: hidden; margin-bottom: 2px;
    cursor: default; opacity: 0; transform: translateY(24px);
    transition: opacity 0.75s ease, transform 0.75s ease, background 0.35s, border-color 0.35s;
  }
  .nls-{{ section.id }} .nls-feat.visible { opacity: 1; transform: translateY(0); }
  .nls-{{ section.id }} .nls-feat:hover { background: rgba(255,255,255,0.09); border-color: var(--gold-line); }
  .nls-{{ section.id }} .nls-feat.gold-bg { background: linear-gradient(135deg, rgba(201,169,110,0.12) 0%, rgba(201,169,110,0.03) 100%); border-color: var(--gold-line); }
  .nls-{{ section.id }} .nls-feat.gold-bg::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(to right, transparent 10%, var(--gold) 50%, transparent 90%); }
  .nls-{{ section.id }} .nls-ftag { font-size: 9px; font-weight: 500; letter-spacing: {% if is_arabic %}0.05em{% else %}0.42em{% endif %}; {% unless is_arabic %}text-transform: uppercase;{% endunless %} color: var(--gold); margin-bottom: 10px; }
  .nls-{{ section.id }} .nls-ftitle { font-family: var(--font-display); font-size: 30px; font-weight: {% if is_arabic %}500{% else %}400{% endif %}; color: var(--white); line-height: 1.15; margin-bottom: 6px; }
  .nls-{{ section.id }} .nls-fsub { font-family: var(--font-display); font-style: {% if is_arabic %}normal{% else %}italic{% endif %}; font-size: 13px; color: var(--gold); margin-bottom: 12px; opacity: 0.9; }
  .nls-{{ section.id }} .nls-fdesc { font-size: 12.5px; line-height: 1.75; color: var(--white-60); max-width: 460px; }
  .nls-{{ section.id }} .nls-fright { text-align: {% if is_arabic %}start{% else %}right{% endif %}; flex-shrink: 0; }
  .nls-{{ section.id }} .nls-flabel { font-size: 9px; letter-spacing: {% if is_arabic %}0.05em{% else %}0.35em{% endif %}; {% unless is_arabic %}text-transform: uppercase;{% endunless %} color: var(--gold); margin-bottom: 5px; }
  .nls-{{ section.id }} .nls-fprice { font-family: var(--serif); font-size: 44px; font-weight: 300; color: var(--white); line-height: 1; }
  .nls-{{ section.id }} .nls-fprice sup { font-size: 15px; font-family: var(--sans); vertical-align: super; opacity: 0.7; }
  .nls-{{ section.id }} .nls-fdur { font-size: 10px; color: var(--white-60); margin-top: 8px; letter-spacing: 0.06em; }

  /* ── PRICE TABLE ── */
  .nls-{{ section.id }} .nls-table { border: 1px solid var(--glass-b); overflow: hidden; opacity: 0; transform: translateY(20px); transition: opacity 0.7s ease, transform 0.7s ease; }
  .nls-{{ section.id }} .nls-table.visible { opacity: 1; transform: translateY(0); }
  .nls-{{ section.id }} .nls-thead { background: rgba(201,169,110,0.1); border-bottom: 1px solid var(--gold-line); padding: 14px 28px; display: grid; grid-template-columns: 1fr auto auto; gap: 24px; font-size: 9px; font-weight: 500; letter-spacing: {% if is_arabic %}0.05em{% else %}0.4em{% endif %}; {% unless is_arabic %}text-transform: uppercase;{% endunless %} color: var(--gold); }
  .nls-{{ section.id }} .nls-thead span:last-child { text-align: {% if is_arabic %}start{% else %}right{% endif %}; }
  .nls-{{ section.id }} .nls-trow { display: grid; grid-template-columns: 1fr auto auto; gap: 24px; padding: 16px 28px; border-bottom: 1px solid rgba(255,255,255,0.04); align-items: center; transition: background 0.25s; cursor: default; }
  .nls-{{ section.id }} .nls-trow:last-child { border-bottom: none; }
  .nls-{{ section.id }} .nls-trow:hover { background: rgba(255,255,255,0.05); }
  .nls-{{ section.id }} .nls-trow.gel  { border-{% if is_arabic %}right{% else %}left{% endif %}: 2px solid var(--blush); }
  .nls-{{ section.id }} .nls-trow.french { border-{% if is_arabic %}right{% else %}left{% endif %}: 2px solid rgba(201,169,110,0.6); }
  .nls-{{ section.id }} .nls-tname { font-family: var(--font-display); font-size: 17px; font-weight: 400; color: var(--white); line-height: 1.3; }
  .nls-{{ section.id }} .nls-tname small { display: block; font-family: var(--font-main); font-size: 10px; color: var(--white-60); margin-top: 2px; }
  .nls-{{ section.id }} .nls-tname small.blush { color: var(--blush); }
  .nls-{{ section.id }} .nls-tname small.gold  { color: var(--gold); }
  .nls-{{ section.id }} .nls-rowdur { font-size: 10px; color: var(--white-60); white-space: nowrap; letter-spacing: 0.06em; text-align: {% if is_arabic %}start{% else %}right{% endif %}; }
  .nls-{{ section.id }} .nls-rowprice { font-family: var(--serif); font-size: 22px; font-weight: 300; color: var(--white); text-align: {% if is_arabic %}start{% else %}right{% endif %}; white-space: nowrap; min-width: 72px; }
  .nls-{{ section.id }} .nls-rowprice sup { font-size: 10px; font-family: var(--sans); vertical-align: super; opacity: 0.7; }
  .nls-{{ section.id }} .nls-legend { display: flex; align-items: center; gap: 20px; margin-top: 13px; padding-{% if is_arabic %}right{% else %}left{% endif %}: 4px; flex-wrap: wrap; }
  .nls-{{ section.id }} .nls-legend-item { display: flex; align-items: center; gap: 8px; }
  .nls-{{ section.id }} .nls-legend-dot { width: 10px; height: 10px; border-radius: 2px; flex-shrink: 0; }
  .nls-{{ section.id }} .nls-legend-text { font-size: 10px; letter-spacing: 0.1em; color: rgba(255,255,255,0.4); }

  /* ── CHAPTER BANNER ── */
  .nls-{{ section.id }} .nls-chapter {
    position: relative; z-index: 1;
    background: linear-gradient(to right, var(--bg-dark), var(--bg-deeper), var(--bg-dark));
    border-top: 1px solid var(--glass-b); border-bottom: 1px solid var(--glass-b);
    padding: 60px 30px; text-align: center; overflow: hidden; margin-top: 60px;
    opacity: 0; transform: translateY(20px); transition: opacity 0.8s ease, transform 0.8s ease;
  }
  .nls-{{ section.id }} .nls-chapter.visible { opacity: 1; transform: translateY(0); }
  .nls-{{ section.id }} .nls-chapter::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at center, rgba(201,160,160,0.06) 0%, transparent 70%); }
  .nls-{{ section.id }} .nls-chapter-eye { font-size: 10px; font-weight: 500; letter-spacing: {% if is_arabic %}0.05em{% else %}0.5em{% endif %}; {% unless is_arabic %}text-transform: uppercase;{% endunless %} color: var(--blush); margin-bottom: 16px; position: relative; }
  .nls-{{ section.id }} .nls-chapter-title { font-family: var(--font-display); font-size: clamp(36px, 6vw, 62px); font-weight: {% if is_arabic %}400{% else %}300{% endif %}; font-style: {% if is_arabic %}normal{% else %}italic{% endif %}; color: var(--white); line-height: 1.1; position: relative; }
  .nls-{{ section.id }} .nls-chapter-title span { color: var(--gold); font-style: normal; }
  .nls-{{ section.id }} .nls-chapter-sub { margin-top: 14px; font-size: 12px; letter-spacing: {% if is_arabic %}0.05em{% else %}0.18em{% endif %}; {% unless is_arabic %}text-transform: uppercase;{% endunless %} color: var(--white-60); position: relative; }

  /* ── BOTTOM ── */
  .nls-{{ section.id }} .nls-bottom { text-align: center; padding: 80px 30px 100px; position: relative; z-index: 1; opacity: 0; transform: translateY(20px); transition: opacity 0.9s ease, transform 0.9s ease; }
  .nls-{{ section.id }} .nls-bottom.visible { opacity: 1; transform: translateY(0); }
  .nls-{{ section.id }} .nls-bottom-line { display: flex; align-items: center; justify-content: center; gap: 20px; margin-bottom: 30px; }
  .nls-{{ section.id }} .nls-bottom-rule { width: 60px; height: 1px; background: var(--gold-line); }
  .nls-{{ section.id }} .nls-bottom-diamond { color: var(--gold); font-size: 10px; }
  .nls-{{ section.id }} .nls-bottom h2 { font-family: var(--font-display); font-size: clamp(28px, 5vw, 52px); font-weight: 300; font-style: {% if is_arabic %}normal{% else %}italic{% endif %}; color: var(--white); line-height: 1.3; margin-bottom: 16px; }
  .nls-{{ section.id }} .nls-bottom p { font-size: 12px; letter-spacing: {% if is_arabic %}0.05em{% else %}0.2em{% endif %}; {% unless is_arabic %}text-transform: uppercase;{% endunless %} color: var(--white-60); }

  /* ── RESPONSIVE ── */
  @media (max-width: 960px) {
    .nls-{{ section.id }} .nls-trio { grid-template-columns: 1fr 1fr; }
    .nls-{{ section.id }} .nls-trio > *:last-child { grid-column: 1 / -1; }
