</div>

</div>

<script>
(function(){
  var root = document.querySelector('.nls-{{ section.id }}');
  if(!root) return;

  var obs = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if(e.isIntersecting){
        var el=e.target, delay=parseInt(el.dataset.delay||0);
        setTimeout(function(){ el.classList.add('visible'); }, delay);
        obs.unobserve(el);
      }
    });
  }, { threshold:0.1, rootMargin:'0px 0px -40px 0px' });
  root.querySelectorAll('[data-nls-reveal]').forEach(function(el){ obs.observe(el); });

  /* fixed cart reveal */
  var trigger = root.querySelector('#nlsTrigger-{{ section.id }}');
  var mainEl = root.querySelector('.nls-main');
  var cartEl = root.querySelector('.nls-cart');
  function syncPin(){
    if(window.innerWidth <= 900){ root.classList.remove('cart-pinned'); return; }
    var t  = trigger ? trigger.getBoundingClientRect().top : 9999;
    var rb = mainEl ? mainEl.getBoundingClientRect().bottom : 9999;
    var cartHeight = cartEl ? cartEl.offsetHeight : 450;
    var nlsTopVal = window.getComputedStyle(root).getPropertyValue('--nls-top').trim();
    var cartTop = parseFloat(nlsTopVal) || 150;
    var threshold = cartTop + cartHeight;
    root.classList.toggle('cart-pinned', (t <= cartTop) && (rb > threshold));
  }
  window.addEventListener('scroll', syncPin, { passive:true });
  window.addEventListener('resize', syncPin);
  syncPin();

  /* ===== Selection summary ===== */
  var IS_AR = {{ is_arabic | json }};
  var WHATSAPP_NUMBER = "9715XXXXXXXX"; /* ←←← REPLACE with your number, intl format, no + */
  var CUR = IS_AR ? 'د.إ' : 'AED';
  var L = IS_AR
    ? { add:'أضف', added:'✓ مضافة', intro:'مرحباً! أود حجز الخدمات التالية:', total:'الإجمالي', from:'يبدأ من' }
    : { add:'Add', added:'✓ Added', intro:"Hi! I'd like to book:", total:'Total', from:'from' };

  var cart = [];
  try {
    var saved = localStorage.getItem('donnabella_cart');
    if (saved) { cart = JSON.parse(saved); }
  } catch (e) {}

  function saveCart() {
    try {
      localStorage.setItem('donnabella_cart', JSON.stringify(cart));
    } catch (e) {}
  }
  var addBtns  = root.querySelectorAll('.nls-add');
  var itemsEl  = root.querySelector('#nlsItems-{{ section.id }}');
  var emptyEl  = root.querySelector('#nlsEmpty-{{ section.id }}');
  var totalEl  = root.querySelector('#nlsTotal-{{ section.id }}');
  var barTotEl = root.querySelector('#nlsBarTotal-{{ section.id }}');
  var countEl  = root.querySelector('#nlsCount-{{ section.id }}');
  var bookEl   = root.querySelector('#nlsBook-{{ section.id }}');
  var noteEl   = root.querySelector('#nlsNote-{{ section.id }}');
  var cartEl   = root.querySelector('#nlsCart-{{ section.id }}');
  var barEl    = root.querySelector('#nlsBar-{{ section.id }}');

  /* nail-art stepper */
  var artCount = 0;
  var artBox = root.querySelector('[data-art-qty]');
  var artSpan = root.querySelector('[data-art-count]');
  if(artBox){
    artBox.querySelector('[data-art-inc]').addEventListener('click', function(){ artCount++; artSpan.textContent = artCount; syncArtBtn(); });
    artBox.querySelector('[data-art-dec]').addEventListener('click', function(){ if(artCount>0){ artCount--; artSpan.textContent = artCount; syncArtBtn(); } });
  }
  function syncArtBtn(){
    var b = root.querySelector('[data-svc-id="w-nailart"]');
    var i = cart.find(function(x){ return x.id==='w-nailart'; });
    if(i){
      i.qty = artCount;
      i.price = artCount * 10;
      if(artCount===0){ cart = cart.filter(function(x){return x.id!=='w-nailart';}); }
      saveCart();
      render();
    }
  }

  /* blow-dry +50 curls extra */
  var blowExtra = root.querySelector('[data-blow-extra]');
  if(blowExtra){ blowExtra.addEventListener('change', applyBlowExtra); }
  function blowInCart(){ return cart.some(function(x){ return x.id.indexOf('w-blow-')===0; }); }
  function applyBlowExtra(){
    var want = blowExtra && blowExtra.checked && blowInCart();
    var has = cart.some(function(x){ return x.id==='w-curls'; });
    if(want && !has){ cart.push({ id:'w-curls', name:(IS_AR?'تجعيد / موجات':'Curls / Beach Waves'), price:50 }); }
    else if(!want && has){ cart = cart.filter(function(x){ return x.id!=='w-curls'; }); }
    saveCart();
    render();
  }

  // Restore states from loaded cart
  var artItem = cart.find(function(x){ return x.id==='w-nailart'; });
  if (artItem) {
    artCount = artItem.qty || 0;
    if (artSpan) artSpan.textContent = artCount;
  }
  if (blowExtra) {
    blowExtra.checked = cart.some(function(x){ return x.id==='w-curls'; });
  }

  function fmt(n){ return CUR + ' ' + n; }

  function render(){
    addBtns.forEach(function(b){
      var on = cart.some(function(i){ return i.id === b.dataset.svcId; });
      b.classList.toggle('is-added', on);
      b.textContent = on ? L.added : L.add;
    });
    itemsEl.innerHTML = '';
    var hasFrom = false;
    cart.forEach(function(i){
      if(i.from) hasFrom = true;
      var label = i.name + (i.qty ? ' ×' + i.qty : '') + (i.from ? ' ('+L.from+')' : '');
      var row = document.createElement('div');
      row.className = 'nls-citem';
      row.innerHTML =
        '<span class="nls-citem-name"></span>' +
        '<span class="nls-citem-end"><span class="nls-citem-price">' + fmt(i.price) + '</span>' +
        '<button type="button" class="nls-citem-x" data-rm="' + i.id + '">×</button></span>';
      row.querySelector('.nls-citem-name').textContent = label;
      itemsEl.appendChild(row);
    });
    var total = cart.reduce(function(s,i){ return s + i.price; }, 0);
    totalEl.textContent = fmt(total);
    if(barTotEl) barTotEl.textContent = fmt(total);
    if(countEl)  countEl.textContent = cart.length;
    emptyEl.style.display = cart.length ? 'none' : 'block';
    itemsEl.style.display = cart.length ? 'block' : 'none';
    if(noteEl) noteEl.style.display = hasFrom ? 'block' : 'none';
    root.classList.toggle('has-items', cart.length > 0);
    bookEl.classList.toggle('is-disabled', cart.length === 0);
  }

  addBtns.forEach(function(b){
    b.addEventListener('click', function(){
      var id = b.dataset.svcId;
      var idx = cart.findIndex(function(i){ return i.id === id; });
      if(idx > -1){ cart.splice(idx, 1); }
      else {
        if(b.dataset.svcQtysource === 'art'){
          if(artCount === 0){ return; }
          cart.push({ id:id, name:b.dataset.svcName, qty:artCount, price:artCount * parseInt(b.dataset.svcUnit,10) });
        } else {
          cart.push({ id:id, name:b.dataset.svcName, price:parseInt(b.dataset.svcPrice,10), from:(b.dataset.svcFrom==='1') });
        }
      }
      applyBlowExtra();
      saveCart();
      render();
    });
  });

  itemsEl.addEventListener('click', function(e){
    var rm = e.target.getAttribute('data-rm');
    if(rm){
      cart = cart.filter(function(i){ return i.id !== rm; });
      if(rm.indexOf('w-blow-')===0){ applyBlowExtra(); }
      saveCart();
      render();
    }
  });

  var clearBtn = root.querySelector('#nlsClearAll-{{ section.id }}');
  if(clearBtn) {
    clearBtn.addEventListener('click', function(){
      cart = [];
      artCount = 0;
      if (artSpan) artSpan.textContent = '0';
      if (blowExtra) blowExtra.checked = false;
      saveCart();
      render();
    });
  }

  if(barEl){
    barEl.addEventListener('click', function(){
      var isOpen = cartEl.classList.toggle('is-open');
      if (isOpen && window.innerWidth <= 900) {
        var panelEl = cartEl.querySelector('.nls-cart-panel');
        if (panelEl) {
          setTimeout(function() {
            panelEl.scrollTop = panelEl.scrollHeight;
          }, 50);
        }
      }
    });
  }

  bookEl.addEventListener('click', function(){
    if(!cart.length) return;
    var dest = (window.location.hostname.indexOf('donnabella.ae') > -1 || window.location.hostname.indexOf('myshopify.com') > -1) 
      ? '/pages/checkout' 
      : 'pages_checkout.html';
    window.location.href = dest;
  });

  render();
})();
</script>

