{% comment %}
  Women's Care — Belladona Care · Add-to-selection + FIXED sticky summary
  Pedi/Mani · Hair · Hair Treatment · Blow Dry · Skin Care · Waxing · Nails · Massage
  >>> Set WHATSAPP_NUMBER in the script · tune cart position with --nls-top <
{% endcomment %}

{% assign current_locale = request.locale.iso_code %}
{% assign is_arabic = false %}
{% if current_locale contains 'ar' %}{% assign is_arabic = true %}{% endif %}
{% assign dir = 'ltr' %}
{% if is_arabic %}{% assign dir = 'rtl' %}{% endif %}



<div class="nls-{{ section.id }}" dir="{{ dir }}">
<style>
  .nls-{{ section.id }} {
    --bg: #405264; --bg-dark: #2f3d4d; --bg-deeper: #354656;
    --gold: #c9a96e; --gold-line: rgba(201,169,110,0.35);
    --blush: #c9a0a0; --blush-line: rgba(201,160,160,0.3);
    --white: #ffffff; --white-60: rgba(255,255,255,0.6);
    --glass: rgba(255,255,255,0.06); --glass-b: rgba(255,255,255,0.11);
    --serif: 'Cormorant Garamond', Georgia, serif;
    --sans: 'Montserrat', sans-serif; --arabic: 'Tajawal', sans-serif;
    --font-main: {% if is_arabic %}var(--arabic){% else %}var(--sans){% endif %};
    --font-display: {% if is_arabic %}'Cairo', sans-serif{% else %}var(--serif){% endif %};
    --nls-top: 150px; /* ← cart vertical position; increase to push down */
    background-color: var(--bg); color: var(--white);
    font-family: var(--font-main); font-weight: 300;
  }

  @keyframes nls-fadeUp-{{ section.id }} { to { opacity: 1; transform: translateY(0); } }
  @keyframes nls-ring-{{ section.id }} {
    0%,100% { opacity: 0.35; transform: translate(-50%,-50%) scale(1); }
    50% { opacity: 0.8; transform: translate(-50%,-50%) scale(1.05); }
  }

  /* ── HERO ── */
  .nls-{{ section.id }} .nls-hero { position: relative; min-height: 54vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 80px 30px 50px; overflow: hidden; }
  .nls-{{ section.id }} .nls-hero::before { content: ''; position: absolute; width: 600px; height: 600px; border-radius: 50%; background: radial-gradient(circle, rgba(201,160,160,0.10) 0%, transparent 70%); top: 50%; left: 50%; transform: translate(-50%,-50%); pointer-events: none; }
  .nls-{{ section.id }} .nls-hero::after { content: ''; position: absolute; width: 360px; height: 360px; border-radius: 50%; border: 1px solid var(--blush-line); top: 50%; left: 50%; transform: translate(-50%,-50%); pointer-events: none; animation: nls-ring-{{ section.id }} 4s ease-in-out infinite; }
  .nls-{{ section.id }} .nls-eyebrow { font-size: 11px; font-weight: 500; letter-spacing: {% if is_arabic %}0.05em{% else %}0.42em{% endif %}; {% unless is_arabic %}text-transform: uppercase;{% endunless %} color: var(--blush); margin-bottom: 20px; position: relative; z-index: 1; opacity: 0; transform: translateY(16px); animation: nls-fadeUp-{{ section.id }} 0.8s ease 0.2s forwards; }
  .nls-{{ section.id }} .nls-title { font-family: var(--font-display); font-size: clamp(48px, 9vw, 94px); font-weight: {% if is_arabic %}400{% else %}300{% endif %}; font-style: {% if is_arabic %}normal{% else %}italic{% endif %}; line-height: {% if is_arabic %}1.2{% else %}0.95{% endif %}; color: var(--white); position: relative; z-index: 1; opacity: 0; transform: translateY(20px); animation: nls-fadeUp-{{ section.id }} 0.9s ease 0.4s forwards; }
  .nls-{{ section.id }} .nls-title span { color: var(--gold); font-style: normal; font-weight: 500; }
  .nls-{{ section.id }} .nls-desc { margin-top: 26px; font-size: 13px; letter-spacing: {% if is_arabic %}0.05em{% else %}0.14em{% endif %}; {% unless is_arabic %}text-transform: uppercase;{% endunless %} color: var(--white-60); position: relative; z-index: 1; opacity: 0; transform: translateY(16px); animation: nls-fadeUp-{{ section.id }} 0.9s ease 0.6s forwards; }
  .nls-{{ section.id }} .nls-divider { margin-top: 40px; width: 1px; height: 60px; background: linear-gradient(to bottom, var(--gold), transparent); opacity: 0; animation: nls-fadeUp-{{ section.id }} 0.9s ease 0.8s forwards; }

  /* ── SHELL ── */
  .nls-{{ section.id }} .nls-shell { max-width: 1320px; margin: 0 auto; padding: 0 30px; display: grid; grid-template-columns: minmax(0,1fr) 330px; gap: 60px; align-items: start; }
  .nls-{{ section.id }} .nls-main { min-width: 0; }
  .nls-{{ section.id }} .nls-section { position: relative; z-index: 1; padding: 52px 0 62px; }
  .nls-{{ section.id }} .nls-section + .nls-section { padding-top: 0; }

  /* ── LABEL ── */
  .nls-{{ section.id }} .nls-label { display: flex; align-items: center; gap: 18px; margin-bottom: 36px; opacity: 0; transform: translateX({% if is_arabic %}20px{% else %}-20px{% endif %}); transition: opacity 0.7s ease, transform 0.7s ease; }
  .nls-{{ section.id }} .nls-label.visible { opacity: 1; transform: translateX(0); }
  .nls-{{ section.id }} .nls-label-line { flex: 1; height: 1px; background: linear-gradient(to {% if is_arabic %}left{% else %}right{% endif %}, var(--gold-line), transparent); }
  .nls-{{ section.id }} .nls-label-text { font-size: 10px; font-weight: 500; letter-spacing: {% if is_arabic %}0.05em{% else %}0.45em{% endif %}; {% unless is_arabic %}text-transform: uppercase;{% endunless %} color: var(--gold); white-space: nowrap; }

  /* ── SHOWCASE CARD ── */
  .nls-{{ section.id }} .nls-show { position: relative; display: grid; grid-template-columns: 1.05fr 1fr; background: var(--glass); border: 1px solid var(--glass-b); overflow: hidden; margin-bottom: 2px; opacity: 0; transform: translateY(24px); transition: opacity .75s ease, transform .75s ease, border-color .35s; }
  .nls-{{ section.id }} .nls-show.visible { opacity: 1; transform: translateY(0); }
  .nls-{{ section.id }} .nls-show:hover { border-color: var(--gold-line); }
  .nls-{{ section.id }} .nls-show::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(to right, transparent 10%, var(--gold) 50%, transparent 90%); z-index: 4; }
  .nls-{{ section.id }} .nls-show-media { position: relative; min-height: 380px; overflow: hidden; }
  .nls-{{ section.id }} .nls-show-media img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; transition: transform .8s ease; }
  .nls-{{ section.id }} .nls-show:hover .nls-show-media img { transform: scale(1.05); }
  .nls-{{ section.id }} .nls-show-media::before { content: ''; position: absolute; inset: 0; z-index: 1; background: linear-gradient(180deg, rgba(47,61,77,0.12), rgba(47,61,77,0.32)); pointer-events: none; }
  .nls-{{ section.id }} .nls-show-media::after { content: ''; position: absolute; inset: 0; z-index: 2; background: linear-gradient(90deg, rgba(64,82,100,0) 55%, rgba(64,82,100,0.55) 100%); pointer-events: none; }
  .nls-{{ section.id }} .nls-show.rev .nls-show-media { order: 2; }
  .nls-{{ section.id }} .nls-show.rev .nls-show-body { order: 1; }
  .nls-{{ section.id }} .nls-show.rev .nls-show-media::after { background: linear-gradient(270deg, rgba(64,82,100,0) 55%, rgba(64,82,100,0.55) 100%); }
  .nls-{{ section.id }} .nls-show-body { padding: 40px 44px; display: flex; flex-direction: column; justify-content: center; }
  .nls-{{ section.id }} .nls-stag { font-size: 9px; font-weight: 500; letter-spacing: {% if is_arabic %}0.05em{% else %}0.42em{% endif %}; {% unless is_arabic %}text-transform: uppercase;{% endunless %} color: var(--gold); margin-bottom: 10px; }
  .nls-{{ section.id }} .nls-stitle { font-family: var(--font-display); font-size: 30px; font-weight: {% if is_arabic %}500{% else %}400{% endif %}; color: var(--white); line-height: 1.15; margin-bottom: 6px; }
  .nls-{{ section.id }} .nls-ssub { font-family: var(--font-display); font-style: {% if is_arabic %}normal{% else %}italic{% endif %}; font-size: 13px; color: var(--gold); margin-bottom: 14px; opacity: 0.9; }
  .nls-{{ section.id }} .nls-sdesc { font-size: 12.5px; line-height: 1.75; color: var(--white-60); margin-bottom: 18px; }

  /* ── OPTION ROWS ── */
  .nls-{{ section.id }} .nls-opts { border-top: 1px solid var(--glass-b); margin-top: 4px; }
  .nls-{{ section.id }} .nls-opt { display: flex; align-items: center; justify-content: space-between; gap: 14px; padding: 15px 0; border-bottom: 1px solid rgba(255,255,255,0.06); }
  .nls-{{ section.id }} .nls-opt:last-child { border-bottom: none; }
  .nls-{{ section.id }} .nls-opt-name { font-family: var(--font-display); font-size: 19px; font-weight: {% if is_arabic %}500{% else %}400{% endif %}; color: var(--white); }
  .nls-{{ section.id }} .nls-opt-name small { display: block; font-family: var(--font-main); font-size: 10px; letter-spacing: 0.04em; color: var(--gold); margin-top: 3px; opacity: 0.85; }
  .nls-{{ section.id }} .nls-opt-end { display: flex; align-items: center; gap: 12px; white-space: nowrap; }
  .nls-{{ section.id }} .nls-opt-price { font-family: var(--serif); font-size: 24px; font-weight: 300; color: var(--white); }
  .nls-{{ section.id }} .nls-opt-price sup { font-size: 10px; font-family: var(--sans); vertical-align: super; opacity: 0.7; }
  .nls-{{ section.id }} .nls-opt-price .from { font-family: var(--sans); font-size: 8px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gold); display: block; margin-bottom: 1px; }
  .nls-{{ section.id }} .nls-show-dur { margin-top: 16px; font-size: 10px; letter-spacing: 0.06em; color: var(--white-60); }
  .nls-{{ section.id }} .nls-show-dur span { color: var(--gold); }

  /* single price footer */
  .nls-{{ section.id }} .nls-sfoot { display: flex; align-items: flex-end; justify-content: space-between; gap: 16px; border-top: 1px solid var(--glass-b); padding-top: 16px; margin-top: 8px; }
  .nls-{{ section.id }} .nls-sfoot-left { display: flex; flex-direction: column; gap: 6px; }
  .nls-{{ section.id }} .nls-sprice { font-family: var(--serif); font-size: 38px; font-weight: 300; color: var(--white); line-height: 1; }
  .nls-{{ section.id }} .nls-sprice sup { font-size: 13px; font-family: var(--sans); vertical-align: super; opacity: 0.7; }
  .nls-{{ section.id }} .nls-sprice .from { font-family: var(--sans); font-size: 8px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--gold); display: block; margin-bottom: 2px; }

  /* ── ADD BUTTON ── */
  .nls-{{ section.id }} .nls-add { border: 1px solid var(--gold-line); background: transparent; color: var(--gold); font-family: var(--font-main); font-size: 10px; letter-spacing: {% if is_arabic %}0.03em{% else %}0.18em{% endif %}; {% unless is_arabic %}text-transform: uppercase;{% endunless %} padding: 10px 18px; cursor: pointer; transition: .25s; white-space: nowrap; }
  .nls-{{ section.id }} .nls-add:hover { background: rgba(201,169,110,0.12); border-color: var(--gold); }
  .nls-{{ section.id }} .nls-add.is-added { background: var(--gold); color: #2f3d4d; border-color: var(--gold); }

  /* ── EXTRA CHECKBOX (curls) ── */
  .nls-{{ section.id }} .nls-extra { display: flex; align-items: center; gap: 10px; padding: 14px 0 2px; font-size: 12px; color: var(--white-60); cursor: pointer; }
  .nls-{{ section.id }} .nls-extra input { accent-color: var(--gold); width: 15px; height: 15px; cursor: pointer; }
  .nls-{{ section.id }} .nls-extra b { color: var(--gold); font-weight: 500; }

  /* ── QTY STEPPER (nail art) ── */
  .nls-{{ section.id }} .nls-qty { display: flex; align-items: center; border: 1px solid var(--gold-line); }
  .nls-{{ section.id }} .nls-qty button { width: 30px; height: 30px; background: transparent; border: none; color: var(--gold); font-size: 16px; cursor: pointer; line-height: 1; }
  .nls-{{ section.id }} .nls-qty button:hover { background: rgba(201,169,110,0.12); }
  .nls-{{ section.id }} .nls-qty span { min-width: 30px; text-align: center; font-family: var(--serif); font-size: 16px; color: var(--white); }

  /* ── SUMMARY ── */
  .nls-{{ section.id }} .nls-cart-head-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
  .nls-{{ section.id }} .nls-cart-head { margin-bottom: 0 !important; }
  .nls-{{ section.id }} .nls-cart-clear { background: none; border: none; color: var(--gold); font-family: var(--font-main); font-size: 10px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer; padding: 4px 0; opacity: 0.7; transition: opacity 0.25s; }
  .nls-{{ section.id }} .nls-cart-clear:hover { opacity: 1; }

  .nls-{{ section.id }} .nls-cart,
  .nls-{{ section.id }} .nls-cart-panel {
    scrollbar-width: thin;
    scrollbar-color: var(--gold-line) transparent;
  }
  .nls-{{ section.id }} .nls-cart {
    position: relative; background: rgba(255,255,255,0.05); border: 1px solid var(--glass-b);
  }
  .nls-{{ section.id }} .nls-cart::-webkit-scrollbar,
  .nls-{{ section.id }} .nls-cart-panel::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }
  .nls-{{ section.id }} .nls-cart::-webkit-scrollbar-track,
  .nls-{{ section.id }} .nls-cart-panel::-webkit-scrollbar-track {
    background: transparent;
  }
  .nls-{{ section.id }} .nls-cart::-webkit-scrollbar-thumb,
  .nls-{{ section.id }} .nls-cart-panel::-webkit-scrollbar-thumb {
    background: var(--gold-line);
    border-radius: 4px;
  }
  .nls-{{ section.id }} .nls-cart::-webkit-scrollbar-thumb:hover,
  .nls-{{ section.id }} .nls-cart-panel::-webkit-scrollbar-thumb:hover {
    background: var(--gold);
  }
  .nls-{{ section.id }} .nls-cart::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(to right, transparent 10%, var(--gold) 50%, transparent 90%); }
  .nls-{{ section.id }} .nls-cart-bar { display: none; }
  .nls-{{ section.id }} .nls-cart-panel { padding: 26px 24px 24px; }
  .nls-{{ section.id }} .nls-cart-tag { font-size: 9px; letter-spacing: {% if is_arabic %}0.05em{% else %}0.4em{% endif %}; {% unless is_arabic %}text-transform: uppercase;{% endunless %} color: var(--gold); margin-bottom: 8px; }
  .nls-{{ section.id }} .nls-cart-head { font-family: var(--font-display); font-size: 22px; font-weight: {% if is_arabic %}500{% else %}400{% endif %}; color: var(--white); margin-bottom: 14px; }
  .nls-{{ section.id }} .nls-cart-empty { color: var(--white-60); font-size: 12px; padding: 12px 0 16px; }
  .nls-{{ section.id }} .nls-citem { display: flex; align-items: center; justify-content: space-between; gap: 10px; padding: 11px 0; border-bottom: 1px solid rgba(255,255,255,0.06); }
  .nls-{{ section.id }} .nls-citem-name { font-size: 12.5px; color: var(--white); line-height: 1.35; }
  .nls-{{ section.id }} .nls-citem-end { display: flex; align-items: center; gap: 10px; white-space: nowrap; }
  .nls-{{ section.id }} .nls-citem-price { font-family: var(--serif); font-size: 17px; color: var(--white-60); }
  .nls-{{ section.id }} .nls-citem-x { background: none; border: none; color: var(--gold); font-size: 18px; line-height: 1; cursor: pointer; padding: 0 2px; opacity: .65; }
  .nls-{{ section.id }} .nls-citem-x:hover { opacity: 1; }
  .nls-{{ section.id }} .nls-cart-total { display: flex; align-items: baseline; justify-content: space-between; border-top: 1px solid var(--gold-line); padding-top: 16px; margin-top: 12px; }
  .nls-{{ section.id }} .nls-cart-total .label { font-size: 11px; letter-spacing: {% if is_arabic %}0.05em{% else %}0.25em{% endif %}; {% unless is_arabic %}text-transform: uppercase;{% endunless %} color: var(--gold); }
  .nls-{{ section.id }} .nls-cart-total .val { font-family: var(--serif); font-size: 30px; font-weight: 300; color: var(--white); }
  .nls-{{ section.id }} .nls-cart-note { font-size: 9.5px; color: var(--white-60); margin-top: 6px; letter-spacing: 0.04em; }
  .nls-{{ section.id }} .nls-cart-btn { display: block; width: 100%; margin-top: 18px; padding: 15px; border: none; background: var(--gold); color: #2f3d4d; font-family: var(--font-main); font-size: 11px; font-weight: 600; letter-spacing: {% if is_arabic %}0.03em{% else %}0.2em{% endif %}; {% unless is_arabic %}text-transform: uppercase;{% endunless %} cursor: pointer; transition: opacity .25s; }
  .nls-{{ section.id }} .nls-cart-btn:hover { opacity: .88; }
  .nls-{{ section.id }} .nls-cart-btn.is-disabled { opacity: .35; pointer-events: none; }

  /* ── BOTTOM ── */
  .nls-{{ section.id }} .nls-bottom { text-align: center; padding: 80px 30px 100px; position: relative; z-index: 1; opacity: 0; transform: translateY(20px); transition: opacity 0.9s ease, transform 0.9s ease; }
  .nls-{{ section.id }} .nls-bottom.visible { opacity: 1; transform: translateY(0); }
  .nls-{{ section.id }} .nls-bottom-line { display: flex; align-items: center; justify-content: center; gap: 20px; margin-bottom: 30px; }
  .nls-{{ section.id }} .nls-bottom-rule { width: 60px; height: 1px; background: var(--gold-line); }
  .nls-{{ section.id }} .nls-bottom-diamond { color: var(--gold); font-size: 10px; }
  .nls-{{ section.id }} .nls-bottom h2 { font-family: var(--font-display); font-size: clamp(28px, 5vw, 52px); font-weight: 300; font-style: {% if is_arabic %}normal{% else %}italic{% endif %}; color: var(--white); line-height: 1.3; margin-bottom: 16px; }
  .nls-{{ section.id }} .nls-bottom p { font-size: 12px; letter-spacing: {% if is_arabic %}0.05em{% else %}0.2em{% endif %}; {% unless is_arabic %}text-transform: uppercase;{% endunless %} color: var(--white-60); }

  /* ── DESKTOP FIXED CART ── */
  @media (min-width: 901px) {
    .nls-{{ section.id }} .nls-cart {
      position: fixed; top: var(--nls-top);
      {% if is_arabic %}left{% else %}right{% endif %}: max(30px, (100vw - 1320px) / 2 + 30px);
      width: 330px; box-sizing: border-box;
      max-height: calc(100vh - var(--nls-top) - 30px); overflow-y: auto;
      opacity: 0; visibility: hidden; transform: translateY(10px);
      transition: opacity .45s ease, transform .45s ease, visibility .45s; z-index: 40;
    }
    .nls-{{ section.id }}.cart-pinned .nls-cart { opacity: 1; visibility: visible; transform: none; }
  }

  /* ── MOBILE BAR ── */
  @media (max-width: 900px) {
    .nls-{{ section.id }} .nls-shell { grid-template-columns: 1fr; gap: 0; }
    .nls-{{ section.id }} .nls-aside { position: fixed; left: 0; right: 0; bottom: 0; top: auto; z-index: 1000; display: none; }
    .nls-{{ section.id }}.has-items .nls-aside { display: block; }
    .nls-{{ section.id }} .nls-cart { background: #354656; box-shadow: 0 -12px 30px rgba(0,0,0,0.35); }
    .nls-{{ section.id }} .nls-cart-bar { display: flex; align-items: center; gap: 12px; width: 100%; padding: 14px 20px; background: transparent; border: none; cursor: pointer; }
    .nls-{{ section.id }} .nls-bar-count { min-width: 22px; height: 22px; border-radius: 50%; background: var(--gold); color: #2f3d4d; font-size: 11px; font-weight: 700; display: flex; align-items: center; justify-content: center; }
    .nls-{{ section.id }} .nls-bar-label { font-size: 11px; letter-spacing: {% if is_arabic %}0.03em{% else %}0.15em{% endif %}; {% unless is_arabic %}text-transform: uppercase;{% endunless %} color: var(--white-60); flex: 1; text-align: start; }
    .nls-{{ section.id }} .nls-bar-total { font-family: var(--serif); font-size: 20px; color: var(--white); }
    .nls-{{ section.id }} .nls-bar-chev { color: var(--gold); font-size: 12px; transition: transform .3s; }
    .nls-{{ section.id }} .nls-cart.is-open .nls-bar-chev { transform: rotate(180deg); }
    .nls-{{ section.id }} .nls-cart-panel { display: none; max-height: 60vh; overflow: auto; }
    .nls-{{ section.id }} .nls-cart.is-open .nls-cart-panel { display: block; }
    .nls-{{ section.id }} .nls-bottom { padding-bottom: 130px; }
  }
  @media (max-width: 760px) {
    .nls-{{ section.id }} .nls-show { grid-template-columns: 1fr; }
    .nls-{{ section.id }} .nls-show.rev .nls-show-media,
    .nls-{{ section.id }} .nls-show.rev .nls-show-body { order: 0; }
    .nls-{{ section.id }} .nls-show-media { min-height: 240px; }
    .nls-{{ section.id }} .nls-show-body { padding: 30px 26px; }
    .nls-{{ section.id }} .nls-show-media::after,
    .nls-{{ section.id }} .nls-show.rev .nls-show-media::after { background: linear-gradient(to bottom, rgba(64,82,100,0) 60%, rgba(64,82,100,0.55) 100%); }
  }
</style>

<!-- ════════ HERO ════════ -->
<section class="nls-hero">
  <p class="nls-eyebrow">{% if is_arabic %}لها · رفاهية في المنزل{% else %}For Her · At-Home Luxury{% endif %}</p>
  <h1 class="nls-title">{% if is_arabic %}الجمال <span>والعناية</span>{% else %}Beauty &amp;<br><span>Care</span>{% endif %}</h1>
  <p class="nls-desc">{% if is_arabic %}أظافر · شعر · بشرة · مساج · خدمة منزلية{% else %}Nails · Hair · Skin · Massage · Home Service{% endif %}</p>
  <div class="nls-divider"></div>
</section>

<div id="nlsTrigger-{{ section.id }}" aria-hidden="true" style="width:1px;height:1px;"></div>

<div class="nls-shell">
<div class="nls-main">

  <!-- ════════ PEDI / MANI ════════ -->
  <section class="nls-section" id="nails">
