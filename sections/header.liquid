{% comment %}
  Belladona Header - With Full-Width Services Mega Menu
  Arabic / English bilingual — auto-switches via request.locale
{% endcomment %}

{% comment %} ============================================================
  LANGUAGE DETECTION
================================================================ {% endcomment %}
{% assign current_locale = request.locale.iso_code %}
{% assign is_arabic = false %}
{% if current_locale contains 'ar' %}
  {% assign is_arabic = true %}
{% endif %}
{% assign text_dir = 'ltr' %}
{% if is_arabic %}
  {% assign text_dir = 'rtl' %}
{% endif %}

{% comment %} Localised UI strings {% endcomment %}
{% if is_arabic %}
  {% assign label_explore   = "استكشفي" %}
  {% assign label_book_now  = section.settings.button_text_ar | default: section.settings.button_text %}
  {% assign label_aria_menu = "فتح القائمة" %}
{% else %}
  {% assign label_explore   = "Explore" %}
  {% assign label_book_now  = section.settings.button_text %}
  {% assign label_aria_menu = "Toggle Menu" %}
{% endif %}

<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800;900&family=Montserrat:wght@300;400;500;600;700;800;900&family=Roboto:wght@300;400;500;700;900&family=Open+Sans:wght@300;400;600;700;800&family=Lato:wght@300;400;700;900&family=Raleway:wght@300;400;500;600;700;800;900&family=Poppins:wght@300;400;500;600;700;800;900&family=Oswald:wght@300;400;500;600;700&family=Merriweather:wght@300;400;700;900&family=Inter:wght@300;400;500;600;700;800;900&family=Bebas+Neue&family=Dancing+Script:wght@400;500;600;700&family=Pacifico&family=Abril+Fatface&family=Righteous&family=Cinzel:wght@400;500;600;700;800;900&family=Cormorant+Garamond:wght@300;400;500;600;700&family=Crimson+Text:wght@400;600;700&family=EB+Garamond:wght@400;500;600;700;800&family=Quicksand:wght@300;400;500;600;700&family=Nunito:wght@300;400;600;700;800;900&family=Work+Sans:wght@300;400;500;600;700;800;900&family=Cairo:wght@300;400;600;700;900&family=Tajawal:wght@300;400;500;700;800;900&family=Almarai:wght@300;400;700;800&family=Noto+Kufi+Arabic:wght@300;400;600;700;900&family=Amiri:wght@400;700&family=Lateef:wght@400;700&family=Reem+Kufi:wght@400;600;700&family=Scheherazade+New:wght@400;500;600;700&display=swap');

  /* CSS Reset */
  .custom-header-belladona,
  .custom-header-belladona *,
  .custom-header-belladona *::before,
  .custom-header-belladona *::after {
    all: unset !important;
    box-sizing: border-box !important;
  }

  .custom-header-belladona * {
    margin: 0 !important;
    padding: 0 !important;
    border: 0 !important;
    font-size: 100% !important;
    font: inherit !important;
    line-height: normal !important;
    text-decoration: none !important;
    list-style: none !important;
  }

  /* CSS Variables */
  :root {
    --header-text: {{ section.settings.text_color }};
    --header-hover: {{ section.settings.hover_color }};
    --header-font-family: '{{ section.settings.menu_font_family }}', sans-serif;
    --header-font-size: {{ section.settings.font_size }}px;
    --button-text: {{ section.settings.button_text_color }};
    --button-font-family: '{{ section.settings.button_font_family }}', sans-serif;
    --glow-color: {{ section.settings.glow_color }};
    --switcher-active-bg: {{ section.settings.switcher_active_bg }};
    --switcher-active-text: {{ section.settings.switcher_active_text }};
    --switcher-inactive-text: {{ section.settings.switcher_inactive_text }};
    --switcher-border: {{ section.settings.switcher_border_color }};
  }

  /* Main Header */
  .custom-header-belladona {
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    width: 100% !important;
    z-index: 9999 !important;
    {% assign bg_color = section.settings.background_color %}
    {% assign r = bg_color | remove: '#' | slice: 0, 2 | times: 1 %}
    {% assign g = bg_color | remove: '#' | slice: 2, 2 | times: 1 %}
    {% assign b = bg_color | remove: '#' | slice: 4, 2 | times: 1 %}
    {% assign r_dec = r | divided_by: 255.0 | times: 255 | round %}
    {% assign g_dec = g | divided_by: 255.0 | times: 255 | round %}
    {% assign b_dec = b | divided_by: 255.0 | times: 255 | round %}
    background: rgba({{ r_dec }}, {{ g_dec }}, {{ b_dec }}, {{ section.settings.background_opacity | divided_by: 100.0 }}) !important;
    {% if section.settings.enable_backdrop_blur %}
    backdrop-filter: blur({{ section.settings.backdrop_blur_amount }}px) !important;
    -webkit-backdrop-filter: blur({{ section.settings.backdrop_blur_amount }}px) !important;
    {% endif %}
    {% if section.settings.enable_shadow %}
    box-shadow: 0 4px 20px rgba(0, 0, 0, {{ section.settings.shadow_opacity | divided_by: 100.0 }}) !important;
    {% endif %}
    border-bottom-left-radius: {{ section.settings.bottom_radius }}px !important;
    border-bottom-right-radius: {{ section.settings.bottom_radius }}px !important;
    overflow: visible !important;
    margin: 0 !important;
    padding: 0 !important;
    will-change: auto !important;
  }

  /* Glowing Border */
  {% if section.settings.enable_glow %}
  .custom-header-belladona::before {
    content: '' !important;
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    right: 0 !important;
    bottom: 0 !important;
    border-radius: inherit !important;
    padding: 2px !important;
    background: linear-gradient(90deg, transparent 0%, var(--glow-color) 50%, transparent 100%) !important;
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0) !important;
    -webkit-mask-composite: xor !important;
    mask-composite: exclude !important;
    animation: borderGlow {{ section.settings.glow_speed }}s linear infinite !important;
    pointer-events: none !important;
    opacity: {{ section.settings.glow_opacity | divided_by: 100.0 }} !important;
    z-index: 1 !important;
  }

  @keyframes borderGlow {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }
  {% endif %}

  /* Sparkle Effect */
  {% if section.settings.enable_sparkle %}
  .custom-header-belladona::after {
    content: '' !important;
    position: absolute !important;
    width: 6px !important;
    height: 6px !important;
    background: white !important;
    border-radius: 50% !important;
    box-shadow: 0 0 10px 2px rgba(255, 255, 255, 0.8), 0 0 20px 4px var(--glow-color) !important;
    animation: sparkleMove {{ section.settings.sparkle_speed }}s linear infinite !important;
    pointer-events: none !important;
    z-index: 10 !important;
  }

  @keyframes sparkleMove {
    0% { top: 0; left: 0; opacity: 0; }
    5% { opacity: 1; }
    25% { top: 0; left: 100%; opacity: 1; }
    26% { opacity: 0; }
    50% { top: 100%; left: 100%; opacity: 0; }
    51% { opacity: 1; }
    75% { top: 100%; left: 0; opacity: 1; }
    76% { opacity: 0; }
    100% { top: 0; left: 0; opacity: 0; }
  }
  {% endif %}

  /* Container */
  .header-container {
    max-width: {{ section.settings.max_width }}px !important;
    margin: 0 auto !important;
    padding: {{ section.settings.padding_vertical }}px {{ section.settings.padding_horizontal }}px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
    position: relative !important;
    z-index: 2 !important;
    width: 100% !important;
    gap: 16px !important;
  }

  /* ============================================
     LANGUAGE SWITCHER
  ============================================ */

  .lang-switcher {
    display: flex !important;
    align-items: center !important;
    flex: 0 0 auto !important;
    gap: 0 !important;
    background: transparent !important;
    border: 1.5px solid var(--switcher-border) !important;
    border-radius: {{ section.settings.switcher_radius }}px !important;
    overflow: hidden !important;
    height: 32px !important;
  }

  .lang-switcher form {
    display: flex !important;
    height: 100% !important;
  }

  .lang-switcher__btn {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    padding: 0 10px !important;
    font-family: var(--header-font-family) !important;
    font-size: {{ section.settings.switcher_font_size }}px !important;
    font-weight: {{ section.settings.switcher_font_weight }} !important;
    letter-spacing: 0.5px !important;
    cursor: pointer !important;
    transition: background 0.25s ease, color 0.25s ease !important;
    background: transparent !important;
    color: var(--switcher-inactive-text) !important;
    border: none !important;
    white-space: nowrap !important;
    line-height: 1 !important;
    height: 100% !important;
    text-transform: none !important;
  }

  .lang-switcher__btn:hover {
    color: var(--switcher-active-text) !important;
    background: rgba(0,0,0,0.06) !important;
  }

  .lang-switcher__btn--active {
    background: var(--switcher-active-bg) !important;
    color: var(--switcher-active-text) !important;
    cursor: default !important;
  }

  .lang-switcher__divider {
    display: flex !important;
    align-items: center !important;
    color: var(--switcher-border) !important;
    font-size: 12px !important;
    pointer-events: none !important;
    line-height: 1 !important;
  }

  /* ─── RTL Header Layout ─── */
  {% if is_arabic %}
  .header-container {
    direction: rtl !important;
  }

  .header-nav {
    direction: rtl !important;
  }

  .header-nav a,
  .header-nav ul li {
    direction: rtl !important;
  }

  /* Flip mega menu arrow for RTL */
  .mega-menu-card-arrow {
    flex-direction: row-reverse !important;
  }

  /* Mobile menu slides from left in RTL */
  .header-nav {
    right: auto !important;
    left: -100% !important;
  }

  .header-nav.active {
    left: 0 !important;
    right: auto !important;
  }
  {% endif %}

  /* Logo */
  .header-logo {
    display: flex !important;
    align-items: center !important;
    flex: 0 0 auto !important;
  }

  .header-logo a {
    display: block !important;
    transition: transform 0.3s ease !important;
  }

  .header-logo a:hover {
    transform: scale({{ section.settings.logo_hover_scale | divided_by: 100.0 }}) !important;
  }

  .header-logo img {
    max-width: {{ section.settings.logo_width }}px !important;
    height: auto !important;
    display: block !important;
  }

  .header-logo-text {
    font-size: {{ section.settings.logo_text_size }}px !important;
    font-weight: {{ section.settings.logo_font_weight }} !important;
    color: var(--header-text) !important;
    font-family: var(--header-font-family) !important;
    line-height: 1.2 !important;
  }

  /* Navigation */
  .header-nav {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    flex: 1 1 auto !important;
    gap: {{ section.settings.menu_spacing }}px !important;
  }

  .header-nav ul {
    display: flex !important;
    list-style: none !important;
    gap: {{ section.settings.menu_spacing }}px !important;
    align-items: center !important;
  }

  .header-nav > ul > li {
    position: static !important;
    list-style: none !important;
  }

  .header-nav a {
    color: var(--header-text) !important;
    text-decoration: none !important;
    font-family: var(--header-font-family) !important;
    font-size: var(--header-font-size) !important;
    font-weight: {{ section.settings.menu_font_weight }} !important;
    padding: {{ section.settings.menu_item_padding }}px !important;
    display: block !important;
    transition: all 0.3s ease !important;
    position: relative !important;
    text-transform: {{ section.settings.text_transform }} !important;
    letter-spacing: {{ section.settings.letter_spacing }}px !important;
    line-height: 1.5 !important;
    cursor: pointer !important;
  }

  /* Hover Effects */
  {% if section.settings.hover_effect == 'underline' %}
  .header-nav > ul > li > a::after {
    content: '' !important;
    position: absolute !important;
    bottom: 0 !important;
    left: 50% !important;
    width: 0 !important;
    height: 2px !important;
    background: var(--header-hover) !important;
    transition: all 0.3s ease !important;
    transform: translateX(-50%) !important;
    box-shadow: 0 0 8px var(--header-hover) !important;
  }
  .header-nav > ul > li:hover > a::after,
  .header-nav > ul > li > a:hover::after {
    width: 100% !important;
  }
  .has-mega-menu > a::after,
  .has-mega-menu:hover > a::after {
    display: none !important;
    width: 0 !important;
    height: 0 !important;
    background: none !important;
    box-shadow: none !important;
  }
  {% elsif section.settings.hover_effect == 'background' %}
  .header-nav > ul > li > a {
    border-radius: {{ section.settings.menu_hover_radius }}px !important;
  }
  .header-nav > ul > li:hover > a,
  .header-nav > ul > li > a:hover {
    background: var(--header-hover) !important;
    color: {{ section.settings.hover_text_color }} !important;
  }
  {% elsif section.settings.hover_effect == 'glow' %}
  .header-nav > ul > li:hover > a,
  .header-nav > ul > li > a:hover {
    color: var(--header-hover) !important;
    text-shadow: 0 0 10px var(--header-hover) !important;
  }
  {% elsif section.settings.hover_effect == 'scale' %}
  .header-nav > ul > li:hover > a,
  .header-nav > ul > li > a:hover {
    transform: scale(1.1) !important;
    color: var(--header-hover) !important;
  }
  {% endif %}

  /* ============================================
     MEGA MENU
  ============================================ */

  .has-mega-menu {
    position: static !important;
  }

  .mega-menu-trigger-link {
    display: flex !important;
    align-items: center !important;
    gap: 6px !important;
  }

  .mega-menu-panel {
    position: absolute !important;
    top: 100% !important;
    left: 50% !important;
    transform: translateX(-50%) translateY(-10px) !important;
    width: 100vw !important;
    z-index: 9998 !important;
    margin-top: 4px !important;
    opacity: 0 !important;
    visibility: hidden !important;
    transition: opacity 0.25s ease, transform 0.25s ease, visibility 0.25s ease !important;
    pointer-events: none !important;
    background: rgba({{ r_dec }}, {{ g_dec }}, {{ b_dec }}, {{ section.settings.background_opacity | divided_by: 100.0 }}) !important;
    {% if section.settings.enable_backdrop_blur %}
    backdrop-filter: blur({{ section.settings.backdrop_blur_amount }}px) !important;
    -webkit-backdrop-filter: blur({{ section.settings.backdrop_blur_amount }}px) !important;
    {% endif %}
    {% if section.settings.enable_shadow %}
    box-shadow: 0 20px 60px rgba(0, 0, 0, {{ section.settings.shadow_opacity | divided_by: 100.0 }}) !important;
    {% endif %}
    border-radius: {{ section.settings.bottom_radius }}px !important;
    border: 1px solid rgba({{ r_dec }}, {{ g_dec }}, {{ b_dec }}, 0.15) !important;
  }

  .has-mega-menu:hover .mega-menu-panel,
  .has-mega-menu.mega-open .mega-menu-panel {
    opacity: 1 !important;
    visibility: visible !important;
    transform: translateX(-50%) translateY(0) !important;
    pointer-events: all !important;
  }

  .mega-menu-inner {
    max-width: 100% !important;
    margin: 0 !important;
    padding: {{ section.settings.mega_menu_padding }}px {{ section.settings.padding_horizontal }}px !important;
  }

  .mega-menu-heading {
    font-family: var(--header-font-family) !important;
    font-size: {{ section.settings.mega_menu_heading_size }}px !important;
    font-weight: 600 !important;
    color: #ffffff !important;
    text-transform: uppercase !important;
    letter-spacing: 2px !important;
    display: block !important;
    margin-bottom: {{ section.settings.mega_menu_padding | divided_by: 2 }}px !important;
    opacity: 0.6 !important;
    {% unless section.settings.show_mega_menu_heading %}
    display: none !important;
    {% endunless %}
  }

  .mega-menu-grid {
    display: grid !important;
    grid-template-columns: repeat({{ section.settings.mega_menu_columns }}, 1fr) !important;
    gap: {{ section.settings.mega_menu_gap }}px !important;
  }

  .mega-menu-card {
    display: block !important;
    position: relative !important;
    overflow: hidden !important;
    border-radius: {{ section.settings.mega_card_radius }}px !important;
    cursor: pointer !important;
    text-decoration: none !important;
    aspect-ratio: {{ section.settings.mega_card_aspect_ratio }} !important;
    background: rgba(0,0,0,0.08) !important;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94) !important;
  }

  .mega-menu-card:hover {
    transform: scale(1.03) !important;
    z-index: 1 !important;
  }

  .mega-menu-card-image {
    position: absolute !important;
    inset: 0 !important;
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    object-position: center !important;
    display: block !important;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94) !important;
  }

  .mega-menu-card:hover .mega-menu-card-image {
    transform: scale(1.08) !important;
  }

  .mega-menu-card-placeholder {
    position: absolute !important;
    inset: 0 !important;
    background: linear-gradient(135deg, rgba({{ r_dec }}, {{ g_dec }}, {{ b_dec }}, 0.3) 0%, rgba({{ r_dec }}, {{ g_dec }}, {{ b_dec }}, 0.1) 100%) !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
  }

  .mega-menu-card-overlay {
    position: absolute !important;
    inset: 0 !important;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, {{ section.settings.mega_card_overlay_strength | divided_by: 100.0 }}) 0%,
      rgba(0, 0, 0, 0.1) 50%,
      transparent 100%
    ) !important;
    transition: background 0.3s ease !important;
  }

  .mega-menu-card:hover .mega-menu-card-overlay {
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, {{ section.settings.mega_card_overlay_strength | divided_by: 100.0 | plus: 0.1 }}) 0%,
      rgba(0, 0, 0, 0.15) 50%,
      transparent 100%
    ) !important;
  }

  .mega-menu-card::before {
    content: '' !important;
    position: absolute !important;
    inset: 0 !important;
    background: var(--header-hover) !important;
    opacity: 0 !important;
    transition: opacity 0.3s ease !important;
    z-index: 2 !important;
    mix-blend-mode: multiply !important;
    pointer-events: none !important;
  }

  .mega-menu-card:hover::before {
    opacity: 0.2 !important;
  }

  .mega-menu-card-label {
    position: absolute !important;
    bottom: 0 !important;
    left: 0 !important;
    right: 0 !important;
    padding: {{ section.settings.mega_card_label_padding }}px !important;
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-end !important;
    z-index: 3 !important;
    {% if is_arabic %}
    align-items: flex-end !important;
    {% endif %}
  }

  .mega-menu-card-title {
    font-family: var(--header-font-family) !important;
    font-size: {{ section.settings.mega_card_font_size }}px !important;
    font-weight: {{ section.settings.mega_card_font_weight }} !important;
    color: {{ section.settings.mega_card_text_color }} !important;
    display: block !important;
    text-transform: {{ section.settings.text_transform }} !important;
    letter-spacing: {{ section.settings.letter_spacing }}px !important;
    line-height: 1.3 !important;
    text-shadow: 0 1px 6px rgba(0,0,0,0.5) !important;
    transform: translateY(4px) !important;
    transition: transform 0.3s ease !important;
    {% if is_arabic %}
    text-align: right !important;
    letter-spacing: 0 !important;
    text-transform: none !important;
    {% endif %}
  }

  .mega-menu-card:hover .mega-menu-card-title {
    transform: translateY(0) !important;
  }

  .mega-menu-card-arrow {
    display: flex !important;
    align-items: center !important;
    gap: 6px !important;
    margin-top: 4px !important;
    opacity: 0 !important;
    transform: translateY(6px) !important;
    transition: opacity 0.3s ease 0.05s, transform 0.3s ease 0.05s !important;
    {% if is_arabic %}
    flex-direction: row-reverse !important;
    {% endif %}
  }

  .mega-menu-card:hover .mega-menu-card-arrow {
    opacity: 1 !important;
    transform: translateY(0) !important;
  }

  .mega-menu-card-arrow span {
    font-family: var(--header-font-family) !important;
    font-size: {{ section.settings.mega_card_font_size | minus: 2 }}px !important;
    color: {{ section.settings.mega_card_text_color }} !important;
    display: block !important;
    opacity: 0.85 !important;
    letter-spacing: {% if is_arabic %}0{% else %}1px{% endif %} !important;
    text-transform: {% if is_arabic %}none{% else %}uppercase{% endif %} !important;
    font-weight: 500 !important;
  }

  .mega-menu-card-arrow-icon {
    width: 18px !important;
    height: 18px !important;
    border: 1.5px solid {{ section.settings.mega_card_text_color }} !important;
    border-radius: 50% !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    flex-shrink: 0 !important;
    transition: background 0.2s ease, border-color 0.2s ease !important;
  }

  .mega-menu-card:hover .mega-menu-card-arrow-icon {
    background: {{ section.settings.mega_card_text_color }} !important;
  }

  .mega-menu-card-arrow-icon svg {
    width: 8px !important;
    height: 8px !important;
    fill: none !important;
    stroke: {{ section.settings.mega_card_text_color }} !important;
    stroke-width: 2 !important;
    display: block !important;
    transition: stroke 0.2s ease !important;
    {% if is_arabic %}transform: scaleX(-1) !important;{% endif %}
  }

  {% assign bg_r = section.settings.background_color | remove: '#' | slice: 0, 2 | times: 1 %}
  {% assign bg_g = section.settings.background_color | remove: '#' | slice: 2, 2 | times: 1 %}
  {% assign bg_b = section.settings.background_color | remove: '#' | slice: 4, 2 | times: 1 %}
  .mega-menu-card:hover .mega-menu-card-arrow-icon svg {
    stroke: rgba({{ bg_r }}, {{ bg_g }}, {{ bg_b }}, 1) !important;
  }

  /* ============================================
     Button
  ============================================ */

  .header-cta {
    flex: 0 0 auto !important;
  }

  .book-now-btn {
    {% assign btn_bg = section.settings.button_background %}
    {% assign btn_r = btn_bg | remove: '#' | slice: 0, 2 | times: 1 %}
    {% assign btn_g = btn_bg | remove: '#' | slice: 2, 2 | times: 1 %}
    {% assign btn_b = btn_bg | remove: '#' | slice: 4, 2 | times: 1 %}
    {% assign btn_r_dec = btn_r | divided_by: 255.0 | times: 255 | round %}
    {% assign btn_g_dec = btn_g | divided_by: 255.0 | times: 255 | round %}
    {% assign btn_b_dec = btn_b | divided_by: 255.0 | times: 255 | round %}
    background: rgba({{ btn_r_dec }}, {{ btn_g_dec }}, {{ btn_b_dec }}, {{ section.settings.button_opacity | divided_by: 100.0 }}) !important;
    {% if section.settings.button_backdrop_blur %}
    backdrop-filter: blur({{ section.settings.button_blur_amount }}px) !important;
    -webkit-backdrop-filter: blur({{ section.settings.button_blur_amount }}px) !important;
    {% endif %}
    color: var(--button-text) !important;
    padding: {{ section.settings.button_padding_vertical }}px {{ section.settings.button_padding_horizontal }}px !important;
    border-radius: {{ section.settings.button_radius }}px !important;
    font-family: var(--button-font-family) !important;
    font-size: {{ section.settings.button_font_size }}px !important;
    font-weight: {{ section.settings.button_font_weight }} !important;
    border: {{ section.settings.button_border_width }}px solid {{ section.settings.button_border_color }} !important;
    transition: all 0.3s ease !important;
    display: inline-block !important;
    text-transform: {{ section.settings.button_text_transform }} !important;
    letter-spacing: {{ section.settings.button_letter_spacing }}px !important;
    {% if section.settings.button_shadow %}
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2) !important;
    {% endif %}
    cursor: pointer !important;
    line-height: 1.5 !important;
    text-align: center !important;
    white-space: nowrap !important;
    text-decoration: none !important;
    {% if is_arabic %}
    letter-spacing: 0 !important;
    text-transform: none !important;
    {% endif %}
  }

  .book-now-btn:hover {
    {% assign btn_hover_bg = section.settings.button_hover_background %}
    {% assign btn_hr = btn_hover_bg | remove: '#' | slice: 0, 2 | times: 1 %}
    {% assign btn_hg = btn_hover_bg | remove: '#' | slice: 2, 2 | times: 1 %}
    {% assign btn_hb = btn_hover_bg | remove: '#' | slice: 4, 2 | times: 1 %}
    {% assign btn_hr_dec = btn_hr | divided_by: 255.0 | times: 255 | round %}
    {% assign btn_hg_dec = btn_hg | divided_by: 255.0 | times: 255 | round %}
    {% assign btn_hb_dec = btn_hb | divided_by: 255.0 | times: 255 | round %}
    background: rgba({{ btn_hr_dec }}, {{ btn_hg_dec }}, {{ btn_hb_dec }}, {{ section.settings.button_hover_opacity | divided_by: 100.0 }}) !important;
    color: {{ section.settings.button_hover_text_color }} !important;
    transform: translateY(-2px) !important;
    {% if section.settings.button_shadow %}
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.3) !important;
    {% endif %}
  }

  /* ============================================
     Mobile Toggle
  ============================================ */

  .mobile-menu-toggle {
    display: none !important;
    flex-direction: column !important;
    gap: 6px !important;
    cursor: pointer !important;
    padding: 10px !important;
    background: transparent !important;
    border: none !important;
    z-index: 1000000 !important;
    position: relative !important;
    width: 35px !important;
    height: 35px !important;
    justify-content: center !important;
    align-items: center !important;
  }

  .mobile-menu-toggle span {
    width: 25px !important;
    height: 3px !important;
    background: var(--header-text) !important;
    transition: all 0.3s ease !important;
    border-radius: 2px !important;
    display: block !important;
    position: absolute !important;
  }

  .mobile-menu-toggle span:nth-child(1) { top: 8px !important; }
  .mobile-menu-toggle span:nth-child(2) { top: 16px !important; }
  .mobile-menu-toggle span:nth-child(3) { top: 24px !important; }

  .mobile-menu-toggle.active span:nth-child(1) {
    top: 16px !important;
    transform: rotate(45deg) !important;
  }
  .mobile-menu-toggle.active span:nth-child(2) { opacity: 0 !important; }
  .mobile-menu-toggle.active span:nth-child(3) {
    top: 16px !important;
    transform: rotate(-45deg) !important;
  }

  /* ============================================
     Mobile Styles
  ============================================ */

  @media only screen and (max-width: 768px) {
    .header-container {
      display: flex !important;
      align-items: center !important;
      justify-content: space-between !important;
    }

    .header-cta {
      order: 1 !important;
      {% if section.settings.hide_button_mobile %}
      display: none !important;
      {% endif %}
    }

    .header-logo {
      order: 2 !important;
      flex: 1 1 auto !important;
      justify-content: center !important;
    }

    .mobile-menu-toggle {
      order: 3 !important;
      display: flex !important;
    }

    /* Hide switcher from header on mobile — show inside mobile menu instead */
    .lang-switcher--desktop {
      display: none !important;
    }

    .header-nav {
      position: fixed !important;
      top: 0 !important;
      {% if is_arabic %}
      left: -100% !important;
      right: auto !important;
      {% else %}
      right: -100% !important;
      left: auto !important;
      {% endif %}
      width: {{ section.settings.mobile_menu_width }}% !important;
      height: 100vh !important;
      {% assign mobile_bg = section.settings.mobile_menu_background_color %}
      {% assign mobile_r = mobile_bg | remove: '#' | slice: 0, 2 | times: 1 %}
      {% assign mobile_g = mobile_bg | remove: '#' | slice: 2, 2 | times: 1 %}
      {% assign mobile_b = mobile_bg | remove: '#' | slice: 4, 2 | times: 1 %}
      {% assign mobile_r_dec = mobile_r | divided_by: 255.0 | times: 255 | round %}
      {% assign mobile_g_dec = mobile_g | divided_by: 255.0 | times: 255 | round %}
      {% assign mobile_b_dec = mobile_b | divided_by: 255.0 | times: 255 | round %}
      background: rgba({{ mobile_r_dec }}, {{ mobile_g_dec }}, {{ mobile_b_dec }}, {{ section.settings.mobile_menu_opacity | divided_by: 100.0 }}) !important;
      {% if section.settings.mobile_menu_blur %}
      backdrop-filter: blur({{ section.settings.mobile_blur_amount }}px) !important;
      -webkit-backdrop-filter: blur({{ section.settings.mobile_blur_amount }}px) !important;
      {% endif %}
      flex-direction: column !important;
      padding: 100px 30px 30px !important;
      transition: {% if is_arabic %}left{% else %}right{% endif %} 0.4s ease !important;
      z-index: 999999 !important;
      overflow-y: auto !important;
      {% if section.settings.mobile_menu_shadow %}
      box-shadow: {% if is_arabic %}5px{% else %}-5px{% endif %} 0 15px rgba(0, 0, 0, 0.3) !important;
      {% endif %}
    }

    .header-nav.active {
      {% if is_arabic %}
      left: 0 !important;
      {% else %}
      right: 0 !important;
      {% endif %}
    }

    .header-nav ul {
      flex-direction: column !important;
      width: 100% !important;
      gap: 0 !important;
    }

    .header-nav > ul > li {
      width: 100% !important;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1) !important;
      text-align: {% if is_arabic %}right{% else %}center{% endif %} !important;
    }

    .header-nav a {
      font-size: {{ section.settings.mobile_font_size }}px !important;
      padding: {{ section.settings.mobile_menu_item_padding }}px !important;
      width: 100% !important;
      text-align: {% if is_arabic %}right{% else %}center{% endif %} !important;
    }

    .header-logo img {
      max-width: {{ section.settings.logo_width_mobile }}px !important;
    }

    .custom-header-belladona {
      border-bottom-left-radius: {{ section.settings.bottom_radius_mobile }}px !important;
      border-bottom-right-radius: {{ section.settings.bottom_radius_mobile }}px !important;
    }

    /* Mobile lang switcher inside nav */
    .lang-switcher--mobile {
      display: flex !important;
      justify-content: {% if is_arabic %}flex-end{% else %}center{% endif %} !important;
      margin-top: 24px !important;
    }

    /* Mobile mega menu */
    .mega-menu-panel {
      position: relative !important;
      margin-top: 0 !important;
      width: 100% !important;
      opacity: 1 !important;
      visibility: visible !important;
      transform: none !important;
      pointer-events: all !important;
      background: transparent !important;
      backdrop-filter: none !important;
      -webkit-backdrop-filter: none !important;
      box-shadow: none !important;
      border-radius: 0 !important;
      border: none !important;
      display: none !important;
      padding: 0 !important;
    }

    .has-mega-menu.mega-open .mega-menu-panel {
      display: block !important;
    }

    .mega-menu-inner {
      padding: 10px 0 10px !important;
    }

    .mega-menu-grid {
      grid-template-columns: repeat(2, 1fr) !important;
      gap: 8px !important;
    }

    .mega-menu-card {
      aspect-ratio: 1 / 1 !important;
    }

    .mega-menu-card-title {
      font-size: {{ section.settings.mega_card_font_size | minus: 2 }}px !important;
    }

    .mega-menu-heading {
      display: none !important;
    }

    .mobile-overlay {
      position: fixed !important;
      top: 0 !important;
      left: 0 !important;
      width: 100% !important;
      height: 100vh !important;
      background: rgba(0, 0, 0, 0.5) !important;
      opacity: 0 !important;
      visibility: hidden !important;
      transition: all 0.4s ease !important;
      z-index: 999998 !important;
    }

    .mobile-overlay.active {
      opacity: 1 !important;
      visibility: visible !important;
    }
  }

  @media only screen and (min-width: 769px) {
    .lang-switcher--mobile {
      display: none !important;
    }
  }

  /* ============================================
     ARABIC OVERRIDES — placed last to win cascade
     High-specificity selectors beat all English rules
  ============================================ */
  {% if is_arabic %}

  /* Nav links */
  .custom-header-belladona[dir="rtl"] .header-nav a,
  .custom-header-belladona[dir="rtl"] .header-nav > ul > li > a {
    font-family: '{{ section.settings.ar_menu_font_family }}', 'Cairo', 'Tajawal', sans-serif !important;
    font-size: {{ section.settings.ar_font_size }}px !important;
    font-weight: {{ section.settings.ar_menu_font_weight }} !important;
    color: {{ section.settings.ar_text_color }} !important;
    letter-spacing: 0 !important;
    text-transform: none !important;
  }

  /* Nav hover */
  .custom-header-belladona[dir="rtl"] .header-nav a:hover,
  .custom-header-belladona[dir="rtl"] .header-nav > ul > li:hover > a {
    color: {{ section.settings.ar_hover_color }} !important;
  }

  /* Mega menu trigger link */
  .custom-header-belladona[dir="rtl"] .mega-menu-trigger-link {
    font-family: '{{ section.settings.ar_menu_font_family }}', 'Cairo', 'Tajawal', sans-serif !important;
    font-size: {{ section.settings.ar_font_size }}px !important;
    font-weight: {{ section.settings.ar_menu_font_weight }} !important;
    color: {{ section.settings.ar_text_color }} !important;
  }

  /* Mega menu heading */
  .custom-header-belladona[dir="rtl"] .mega-menu-heading {
    font-family: '{{ section.settings.ar_menu_font_family }}', 'Cairo', 'Tajawal', sans-serif !important;
    font-size: {{ section.settings.ar_font_size }}px !important;
    font-weight: {{ section.settings.ar_menu_font_weight }} !important;
  }

  /* Mega menu card titles */
  .custom-header-belladona[dir="rtl"] .mega-menu-card-title {
    font-family: '{{ section.settings.ar_menu_font_family }}', 'Cairo', 'Tajawal', sans-serif !important;
    font-size: {{ section.settings.ar_mega_card_font_size }}px !important;
    font-weight: {{ section.settings.ar_mega_card_font_weight }} !important;
    color: {{ section.settings.ar_mega_card_text_color }} !important;
  }

  /* Mega menu card arrow text */
  .custom-header-belladona[dir="rtl"] .mega-menu-card-arrow span {
    font-family: '{{ section.settings.ar_menu_font_family }}', 'Cairo', 'Tajawal', sans-serif !important;
    font-size: {{ section.settings.ar_mega_card_font_size | minus: 2 }}px !important;
  }

  /* Logo text */
  .custom-header-belladona[dir="rtl"] .header-logo-text {
    font-family: '{{ section.settings.ar_menu_font_family }}', 'Cairo', 'Tajawal', sans-serif !important;
    font-size: {{ section.settings.ar_logo_text_size }}px !important;
    font-weight: {{ section.settings.ar_logo_font_weight }} !important;
    color: {{ section.settings.ar_text_color }} !important;
  }

  /* CTA Button */
  .custom-header-belladona[dir="rtl"] .book-now-btn {
    font-family: '{{ section.settings.ar_button_font_family }}', 'Cairo', 'Tajawal', sans-serif !important;
    font-size: {{ section.settings.ar_button_font_size }}px !important;
    font-weight: {{ section.settings.ar_button_font_weight }} !important;
    color: {{ section.settings.ar_button_text_color }} !important;
    letter-spacing: 0 !important;
    text-transform: none !important;
  }

  {% endif %}

</style>

<header class="custom-header-belladona" dir="{{ text_dir }}">
  <div class="header-container">

    <!-- Logo -->
    <div class="header-logo">
      <a href="/">
        {% if section.settings.logo %}
          <img src="{{ section.settings.logo | img_url: 'master' }}" alt="{{ shop.name }}">
        {% else %}
          <span class="header-logo-text">{{ section.settings.logo_text | default: shop.name }}</span>
        {% endif %}
      </a>
    </div>

    <!-- Navigation — driven entirely by blocks -->
    <nav class="header-nav" id="belladonaHeaderNav">
      <ul>

        {% for block in section.blocks %}

          {% comment %} ── Regular nav link ── {% endcomment %}
          {% if block.type == 'nav_item' %}
            {% if is_arabic %}
              {% assign nav_label = block.settings.label_ar | default: block.settings.label_en %}
            {% else %}
              {% assign nav_label = block.settings.label_en %}
            {% endif %}
            <li {{ block.shopify_attributes }}>
              <a href="{{ block.settings.link }}">{{ nav_label }}</a>
            </li>

          {% comment %} ── Mega menu parent — with optional direct link ── {% endcomment %}
          {% elsif block.type == 'mega_parent' %}
            {% if is_arabic %}
              {% assign nav_label = block.settings.nav_title_ar | default: block.settings.nav_title %}
            {% else %}
              {% assign nav_label = block.settings.nav_title %}
            {% endif %}

            {% comment %} Use nav_title as the unique key to match children {% endcomment %}
            {% assign this_parent_key = block.settings.nav_title %}

            {% comment %} If a direct link is set → plain nav link. If blank → dropdown. {% endcomment %}
            {% if block.settings.link != blank %}

              <li {{ block.shopify_attributes }}>
                <a href="{{ block.settings.link }}">{{ nav_label }}</a>
              </li>

            {% else %}

            <li class="has-mega-menu" {{ block.shopify_attributes }}>
              <a href="#" class="mega-menu-trigger-link">{{ nav_label }}</a>

              <div class="mega-menu-panel">
                <div class="mega-menu-inner">
                  {% if section.settings.show_mega_menu_heading %}
                    <span class="mega-menu-heading">{{ nav_label }}</span>
                  {% endif %}

                  <div class="mega-menu-grid">
                    {% comment %}
                      Scan all blocks: collect mega_child blocks that sit
                      between THIS mega_parent and the next mega_parent.
                    {% endcomment %}
                    {% assign capturing = false %}
                    {% for child_block in section.blocks %}
                      {% if child_block.type == 'mega_parent' %}
                        {% if child_block.settings.nav_title == this_parent_key %}
                          {% assign capturing = true %}
                        {% else %}
                          {% assign capturing = false %}
                        {% endif %}
                      {% elsif child_block.type == 'mega_child' and capturing %}

                        {% if is_arabic %}
                          {% assign card_title = child_block.settings.title_ar | default: child_block.settings.title %}
                        {% else %}
                          {% assign card_title = child_block.settings.title %}
                        {% endif %}

                        <a href="{{ child_block.settings.link }}" class="mega-menu-card" {{ child_block.shopify_attributes }}>
                          {% if child_block.settings.image %}
                            <img
                              class="mega-menu-card-image"
                              src="{{ child_block.settings.image | img_url: '600x' }}"
                              alt="{{ card_title }}"
                              loading="lazy"
                            >
                          {% else %}
                            <div class="mega-menu-card-placeholder"></div>
                          {% endif %}
                          <div class="mega-menu-card-overlay"></div>
                          <div class="mega-menu-card-label">
                            <span class="mega-menu-card-title">{{ card_title }}</span>
                            <div class="mega-menu-card-arrow">
                              <span>{{ label_explore }}</span>
                              <div class="mega-menu-card-arrow-icon">
                                <svg viewBox="0 0 10 10" xmlns="http://www.w3.org/2000/svg">
                                  <polyline points="2,5 8,5 6,3" />
                                  <polyline points="6,5 8,5 6,7" />
                                </svg>
                              </div>
                            </div>
                          </div>
                        </a>

                      {% endif %}
                    {% endfor %}
                  </div>
                </div>
              </div>
            </li>

            {% endif %}

          {% endif %}
        {% endfor %}

      </ul>

      <!-- Language switcher inside mobile nav -->
      <div class="lang-switcher lang-switcher--mobile">
        {% if is_arabic %}
          <form action="/localization" method="POST">
            <input type="hidden" name="_method" value="PUT">
            <input type="hidden" name="return_to" value="{{ request.path }}">
            <input type="hidden" name="locale_code" value="en">
            <button type="submit" class="lang-switcher__btn">EN</button>
          </form>
          <span class="lang-switcher__divider">|</span>
          <button class="lang-switcher__btn lang-switcher__btn--active" disabled>عربي</button>
        {% else %}
          <button class="lang-switcher__btn lang-switcher__btn--active" disabled>EN</button>
          <span class="lang-switcher__divider">|</span>
          <form action="/localization" method="POST">
            <input type="hidden" name="_method" value="PUT">
            <input type="hidden" name="return_to" value="{{ request.path }}">
            <input type="hidden" name="locale_code" value="ar">
            <button type="submit" class="lang-switcher__btn">عربي</button>
          </form>
        {% endif %}
      </div>
    </nav>

    <!-- Language Switcher — Desktop -->
    <div class="lang-switcher lang-switcher--desktop">
      {% if is_arabic %}
        <form action="/localization" method="POST">
          <input type="hidden" name="_method" value="PUT">
          <input type="hidden" name="return_to" value="{{ request.path }}">
          <input type="hidden" name="locale_code" value="en">
          <button type="submit" class="lang-switcher__btn">EN</button>
        </form>
        <span class="lang-switcher__divider">|</span>
        <button class="lang-switcher__btn lang-switcher__btn--active" disabled>عربي</button>
      {% else %}
        <button class="lang-switcher__btn lang-switcher__btn--active" disabled>EN</button>
        <span class="lang-switcher__divider">|</span>
        <form action="/localization" method="POST">
          <input type="hidden" name="_method" value="PUT">
          <input type="hidden" name="return_to" value="{{ request.path }}">
          <input type="hidden" name="locale_code" value="ar">
          <button type="submit" class="lang-switcher__btn">عربي</button>
        </form>
      {% endif %}
    </div>

    <!-- CTA Button -->
    <div class="header-cta">
      <a href="{{ section.settings.button_link }}" class="book-now-btn">
        {{ label_book_now }}
      </a>
    </div>

    <!-- Mobile Toggle -->
    <button class="mobile-menu-toggle" id="belladonaMobileToggle" aria-label="{{ label_aria_menu }}">
      <span></span>
      <span></span>
      <span></span>
    </button>

  </div>
</header>

<div class="mobile-overlay" id="belladonaMobileOverlay"></div>

<script>
(function() {
  'use strict';

  var isRTL = {{ is_arabic | json }};

  /* ── Mobile Hamburger Menu ── */
  function initMobileMenu() {
    var menuToggle  = document.getElementById('belladonaMobileToggle');
    var headerNav   = document.getElementById('belladonaHeaderNav');
    var overlay     = document.getElementById('belladonaMobileOverlay');
    if (!menuToggle || !headerNav || !overlay) return;

    function openMenu() {
      menuToggle.classList.add('active');
      headerNav.classList.add('active');
      overlay.classList.add('active');
      document.body.style.overflow   = 'hidden';
      document.body.style.position   = 'fixed';
      document.body.style.width      = '100%';
    }

    function closeMenu() {
      menuToggle.classList.remove('active');
      headerNav.classList.remove('active');
      overlay.classList.remove('active');
      document.body.style.overflow  = '';
      document.body.style.position  = '';
      document.body.style.width     = '';
    }

    menuToggle.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      headerNav.classList.contains('active') ? closeMenu() : openMenu();
    });

    overlay.addEventListener('click', closeMenu);

    headerNav.querySelectorAll('a').forEach(function(link) {
      link.addEventListener('click', function() {
        if (window.innerWidth <= 768) closeMenu();
      });
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeMenu();
    });
  }

  /* ── Mega Menu ── */
  function initMegaMenu() {
    var parents  = document.querySelectorAll('.has-mega-menu');
    if (!parents.length) return;

    function closeAll() {
      parents.forEach(function(p) {
        p.classList.remove('mega-open');
        if (p.closeTimer) clearTimeout(p.closeTimer);
      });
    }

    parents.forEach(function(parent) {
      var panel = parent.querySelector('.mega-menu-panel');
      if (!panel) return;

      parent.closeTimer = null;

      parent.addEventListener('mouseenter', function() {
        if (window.innerWidth > 768) {
          if (parent.closeTimer) clearTimeout(parent.closeTimer);
          closeAll();
          parent.classList.add('mega-open');
        }
      });

      parent.addEventListener('mouseleave', function(e) {
        if (window.innerWidth > 768) {
          var relatedTarget = e.relatedTarget;
          if (relatedTarget && panel.contains(relatedTarget)) return;
          parent.closeTimer = setTimeout(function() {
            parent.classList.remove('mega-open');
          }, 400);
        }
      });

      panel.addEventListener('mouseenter', function() {
        if (window.innerWidth > 768) {
          if (parent.closeTimer) clearTimeout(parent.closeTimer);
          parent.classList.add('mega-open');
        }
      });

      panel.addEventListener('mouseleave', function(e) {
        if (window.innerWidth > 768) {
          var relatedTarget = e.relatedTarget;
          if (relatedTarget && parent.contains(relatedTarget)) return;
          parent.closeTimer = setTimeout(function() {
            parent.classList.remove('mega-open');
          }, 400);
        }
      });

      var triggerLink = parent.querySelector('.mega-menu-trigger-link');
      if (triggerLink) {
        triggerLink.addEventListener('click', function(e) {
          if (window.innerWidth <= 768) {
            e.preventDefault();
            var isOpen = parent.classList.contains('mega-open');
            closeAll();
            if (!isOpen) parent.classList.add('mega-open');
          }
        });
      }
    });

    window.addEventListener('resize', function() {
      if (window.innerWidth > 768) closeAll();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() {
      initMobileMenu();
      initMegaMenu();
    });
  } else {
    initMobileMenu();
    initMegaMenu();
  }
})();

/* ── Disable click navigation for mega menu parents ── */
function disableMegaParentLinks() {
  document.querySelectorAll('.has-mega-menu > a').forEach(function(link) {
    link.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
    });
  });
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', disableMegaParentLinks);
} else {
  disableMegaParentLinks();
}
</script>

{% schema %}
{
  "name": "Custom Header Belladona",
  "settings": [
    { "type": "header", "content": "General" },
