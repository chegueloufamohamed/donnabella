<script
  type="application/json"
  data-section-type="featured-text"
  data-section-id="{{ section.id }}"
>
</script>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@300;400;500;600;700;800;900&family=Montserrat:wght@300;400;500;600;700;800;900&family=Merriweather:wght@300;400;700;900&family=Cormorant+Garamond:wght@300;400;500;600;700&family=Lato:wght@300;400;700;900&family=Raleway:wght@300;400;500;600;700;800;900&family=Poppins:wght@300;400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700;800;900&family=EB+Garamond:wght@400;500;600;700;800&family=Cinzel:wght@400;500;600;700;800;900&family=Crimson+Text:wght@400;600;700&family=Roboto:wght@300;400;500;700;900&family=Open+Sans:wght@300;400;600;700;800&family=Nunito:wght@300;400;600;700;800;900&family=Work+Sans:wght@300;400;500;600;700;800;900&family=Oswald:wght@300;400;500;600;700&family=Tajawal:wght@300;400;500;700;800;900&family=Cairo:wght@300;400;600;700;900&family=Almarai:wght@300;400;700;800&family=Noto+Kufi+Arabic:wght@300;400;500;600;700;800;900&display=swap');
</style>

{% comment %} ============================================================
  ARABIC / ENGLISH LANGUAGE DETECTION
  Detects current locale and assigns content + direction accordingly.
  Arabic locale ISO codes: ar, ar-SA, ar-AE, ar-EG, etc.
================================================================ {% endcomment %}

{% assign current_locale = request.locale.iso_code %}
{% assign is_arabic = false %}
{% if current_locale contains 'ar' %}
  {% assign is_arabic = true %}
{% endif %}

{% comment %} Assign active content based on language {% endcomment %}
{% if is_arabic %}
  {% assign active_title   = section.settings.title_ar   | default: section.settings.title %}
  {% assign active_content = section.settings.content_ar | default: section.settings.content %}
  {% assign active_button_label = section.settings.button_label_ar | default: section.settings.button_label %}
  {% assign text_dir = 'rtl' %}
  {% assign active_title_font   = section.settings.title_font_family_ar %}
  {% assign active_content_font = section.settings.content_font_family_ar %}
  {% assign active_button_font  = section.settings.button_font_family_ar %}
{% else %}
  {% assign active_title   = section.settings.title %}
  {% assign active_content = section.settings.content %}
  {% assign active_button_label = section.settings.button_label %}
  {% assign text_dir = 'ltr' %}
  {% assign active_title_font   = section.settings.title_font_family %}
  {% assign active_content_font = section.settings.content_font_family %}
  {% assign active_button_font  = section.settings.button_font_family %}
{% endif %}

{% style %}
  {% render 'section-space' %}

  /* Title Font Styling */
  #shopify-section-{{ section.id }} .rich-text__heading {
    font-family: '{{ active_title_font }}', serif !important;
    font-size: {{ section.settings.title_font_size }}px !important;
    font-weight: {{ section.settings.title_font_weight }} !important;
    letter-spacing: {{ section.settings.title_letter_spacing }}px !important;
    line-height: {{ section.settings.title_line_height }} !important;
    color: {{ section.settings.title_color }} !important;
    text-transform: {{ section.settings.title_text_transform }} !important;
  }

  /* Content Text Styling */
  #shopify-section-{{ section.id }} .rich-text__text {
    font-family: '{{ active_content_font }}', sans-serif !important;
    font-size: {{ section.settings.content_font_size }}px !important;
    font-weight: {{ section.settings.content_font_weight }} !important;
    line-height: {{ section.settings.content_line_height }} !important;
    color: {{ section.settings.content_color }} !important;
  }

  #shopify-section-{{ section.id }} .rich-text__text p {
    font-family: '{{ active_content_font }}', sans-serif !important;
    font-size: {{ section.settings.content_font_size }}px !important;
    font-weight: {{ section.settings.content_font_weight }} !important;
    line-height: {{ section.settings.content_line_height }} !important;
    color: {{ section.settings.content_color }} !important;
  }

  /* Button Font Styling */
  #shopify-section-{{ section.id }} .global-button {
    font-family: '{{ active_button_font }}', sans-serif !important;
    font-size: {{ section.settings.button_font_size }}px !important;
    font-weight: {{ section.settings.button_font_weight }} !important;
    letter-spacing: {{ section.settings.button_letter_spacing }}px !important;
    text-transform: {{ section.settings.button_text_transform }} !important;
    background-color: {{ section.settings.button_bg_color }} !important;
    color: {{ section.settings.button_text_color }} !important;
    border-radius: {{ section.settings.button_border_radius }}px !important;
    padding: {{ section.settings.button_padding_vertical }}px {{ section.settings.button_padding_horizontal }}px !important;
  }

  #shopify-section-{{ section.id }} .global-button:hover {
    background-color: {{ section.settings.button_hover_bg_color }} !important;
    color: {{ section.settings.button_hover_text_color }} !important;
  }

  /* RTL Layout */
  {% if is_arabic %}
  #shopify-section-{{ section.id }} .rich-text__content {
    direction: rtl !important;
    text-align: right !important;
  }
  #shopify-section-{{ section.id }} .rich-text__heading,
  #shopify-section-{{ section.id }} .rich-text__text,
  #shopify-section-{{ section.id }} .rich-text__text p {
    direction: rtl !important;
    /* Arabic fonts don't benefit from letter-spacing — reset it */
    letter-spacing: 0 !important;
  }
  {% endif %}

  /* Mobile Font Sizes */
  @media (max-width: 768px) {
    #shopify-section-{{ section.id }} .rich-text__heading {
      font-size: {{ section.settings.title_font_size_mobile }}px !important;
    }
    
    #shopify-section-{{ section.id }} .rich-text__text,
    #shopify-section-{{ section.id }} .rich-text__text p {
      font-size: {{ section.settings.content_font_size_mobile }}px !important;
    }

    #shopify-section-{{ section.id }} .global-button {
      font-size: {{ section.settings.button_font_size_mobile }}px !important;
    }
  }

  {%
    render 'css-loop',
    css: section.settings.custom_css,
    id: section.id,
  %}
{% endstyle %}

<section class="section {{ section.settings.css_class }}" dir="{{ text_dir }}">
  <div class="container">
    <div class="one-whole column">
      <div class="rich-text__content {{ section.settings.text_alignment }}">
        {% if section.settings.image %}
          {% if section.settings.mobile_image %}
            <div class="is-hidden-mobile-only">
          {% endif %}
          {%
            render 'image-element',
            image: section.settings.image,
            alt: section.settings.image.alt,
            stretch_width: true,
            focal_point: section.settings.image.presentation.focal_point,
          %}
          {% if section.settings.mobile_image %}
            </div>
            <div class="is-hidden-desktop-only">
              {%
                render 'image-element',
                image: section.settings.mobile_image,
                alt: section.settings.mobile_image.alt,
                stretch_width: true,
                focal_point: section.settings.mobile_image.presentation.focal_point,
              %}
            </div>
          {% endif %}
        {% endif %}

        {% if active_title != blank %}
          <h2 class="rich-text__heading title">
            {{ active_title | escape }}
          </h2>
          <div class="feature-divider"></div>
        {% endif %}

        <div class="rich-text__text {{ section.settings.text_size }}">
          {% if active_content != blank %}
            {{ active_content }}
          {% endif %}

          {% if active_button_label != blank %}
            <a class="global-button" href="{{ section.settings.button_link }}">
              {{ active_button_label }}
            </a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

