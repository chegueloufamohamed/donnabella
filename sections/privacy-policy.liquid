{% assign current_locale = request.locale.iso_code %}
{% assign is_arabic = false %}
{% if current_locale contains 'ar' %}
  {% assign is_arabic = true %}
{% endif %}
{% assign text_dir = 'ltr' %}
{% if is_arabic %}
  {% assign text_dir = 'rtl' %}
{% endif %}



<style>
.pp-wrap *, .pp-wrap *::before, .pp-wrap *::after { box-sizing: border-box; margin: 0; padding: 0; }

.pp-wrap {
  --bg:        #3d5060;
  --bg-dark:   #2f3d4d;
  --bg-darker: #202c38;
  --gold:      #c9a96e;
  --gold-line: rgba(201,169,110,0.35);
  --gold-dim:  rgba(201,169,110,0.10);
  --white:     #ffffff;
  --white-80:  rgba(255,255,255,0.8);
  --white-60:  rgba(255,255,255,0.6);
  --white-40:  rgba(255,255,255,0.4);
  --white-10:  rgba(255,255,255,0.06);
  --serif: 'Cormorant Garamond', Georgia, serif;
  --sans: 'Montserrat', sans-serif;
  --arabic: 'Cairo', 'Tajawal', sans-serif;
  font-family: {% if is_arabic %}var(--arabic){% else %}var(--sans){% endif %};
  font-weight: 300;
  color: var(--white);
  background-color: var(--bg-darker);
  direction: {{ text_dir }};
  min-height: 100vh;
}

/* ── HERO BANNER ── */
.pp-hero {
  background: linear-gradient(180deg, var(--bg-darker) 0%, var(--bg-dark) 100%);
  border-bottom: 1px solid var(--gold-line);
  padding: 100px 40px 64px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.pp-hero::before {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 60% 80% at 50% 100%, rgba(201,169,110,0.07) 0%, transparent 70%);
  pointer-events: none;
}
.pp-hero-tag {
  display: inline-flex; align-items: center; gap: 12px;
  font-size: {% if is_arabic %}12px{% else %}10px{% endif %};
  font-weight: 500;
  letter-spacing: {% if is_arabic %}0{% else %}0.45em{% endif %};
  {% unless is_arabic %}text-transform: uppercase;{% endunless %}
  color: var(--gold); margin-bottom: 24px;
}
.pp-hero-tag::before, .pp-hero-tag::after {
  content: ''; display: block; width: 32px; height: 1px; background: var(--gold-line);
}
.pp-hero-title {
  font-family: {% if is_arabic %}var(--arabic){% else %}var(--serif){% endif %};
  font-size: clamp(36px, 6vw, 72px);
  font-weight: {% if is_arabic %}600{% else %}300{% endif %};
  line-height: {% if is_arabic %}1.3{% else %}1.1{% endif %};
  color: var(--white);
  margin-bottom: 16px;
}
.pp-hero-title em { font-style: {% if is_arabic %}normal{% else %}italic{% endif %}; color: var(--gold); }
.pp-hero-date {
  font-size: 11px;
  letter-spacing: {% if is_arabic %}0{% else %}0.3em{% endif %};
  {% unless is_arabic %}text-transform: uppercase;{% endunless %}
  color: var(--white-40);
}

/* ── CONTENT AREA ── */
.pp-inner {
  max-width: 860px; margin: 0 auto;
  padding: 72px 40px 96px;
}

.pp-section { margin-bottom: 56px; }

.pp-section-title {
  font-family: {% if is_arabic %}var(--arabic){% else %}var(--serif){% endif %};
  font-size: {% if is_arabic %}22px{% else %}26px{% endif %};
  font-weight: {% if is_arabic %}600{% else %}400{% endif %};
  color: var(--white);
  margin-bottom: 20px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--gold-line);
  display: flex; align-items: center; gap: 12px;
}
.pp-section-num {
  font-family: var(--serif);
  font-size: 14px; font-weight: 300;
  color: var(--gold); opacity: 0.7;
  flex-shrink: 0;
}

.pp-text {
  font-size: 14px; line-height: 1.9;
  color: var(--white-60); margin-bottom: 16px;
}
.pp-text:last-child { margin-bottom: 0; }

.pp-list {
  list-style: none; display: flex; flex-direction: column; gap: 10px;
  margin-bottom: 16px;
}
.pp-list li {
  font-size: 14px; line-height: 1.8; color: var(--white-60);
  display: flex; align-items: flex-start; gap: 10px;
  {% if is_arabic %}flex-direction: row-reverse;{% endif %}
}
.pp-list li::before {
  content: ''; display: block; width: 4px; height: 4px;
  border-radius: 50%; background: var(--gold);
  margin-top: 10px; flex-shrink: 0;
}

.pp-highlight {
  background: rgba(201,169,110,0.07);
  border: 1px solid var(--gold-line);
  border-{% if is_arabic %}right{% else %}left{% endif %}: 3px solid var(--gold);
  padding: 20px 24px;
  margin-bottom: 20px;
  font-size: 13.5px; line-height: 1.85; color: var(--white-80);
}

.pp-contact-grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px;
  margin-top: 24px;
}
.pp-contact-card {
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  padding: 24px 20px; text-align: {% if is_arabic %}right{% else %}left{% endif %};
}
.pp-contact-label {
  font-size: {% if is_arabic %}11px{% else %}9px{% endif %};
  letter-spacing: {% if is_arabic %}0{% else %}0.35em{% endif %};
  {% unless is_arabic %}text-transform: uppercase;{% endunless %}
  color: var(--gold); margin-bottom: 8px;
}
.pp-contact-val {
  font-size: 13px; color: var(--white-60); line-height: 1.6;
}
.pp-contact-val a { color: var(--white-60); text-decoration: none; transition: color 0.3s; }
.pp-contact-val a:hover { color: var(--gold); }

/* ── RESPONSIVE ── */
@media (max-width: 768px) {
  .pp-hero { padding: 80px 24px 48px; }
  .pp-inner { padding: 48px 24px 72px; }
  .pp-contact-grid { grid-template-columns: 1fr; }
}
</style>

<div class="pp-wrap" dir="{{ text_dir }}">

  <!-- Hero -->
  <div class="pp-hero">
    <div class="pp-hero-tag">
      {% if is_arabic %}دونا بيلا لإدارة التسويق{% else %}Donna Bella Marketing Management{% endif %}
    </div>
    <h1 class="pp-hero-title">
      {% if is_arabic %}سياسة <em>الخصوصية</em>{% else %}<em>Privacy</em> Policy{% endif %}
    </h1>
    <div class="pp-hero-date">
      {% if is_arabic %}آخر تحديث: مايو 2026{% else %}Last updated: May 2026{% endif %}
    </div>
  </div>

  <!-- Content -->
  <div class="pp-inner">

    <!-- Intro -->
    <div class="pp-section">
      <div class="pp-highlight">
        {% if is_arabic %}
          تلتزم شركة دونا بيلا لإدارة التسويق ذ.م.م بحماية خصوصيتك. توضّح هذه السياسة كيفية جمعنا لمعلوماتك واستخدامها والحفاظ عليها والإفصاح عنها عند استخدامك لموقعنا الإلكتروني أو خدماتنا.
        {% else %}
          Donna Bella Marketing Management L.L.C is committed to protecting your privacy. This policy explains how we collect, use, maintain, and disclose information when you use our website or services.
        {% endif %}
      </div>
    </div>

    <!-- 1. Info we collect -->
    <div class="pp-section">
      <div class="pp-section-title">
        <span class="pp-section-num">01</span>
        {% if is_arabic %}المعلومات التي نجمعها{% else %}Information We Collect{% endif %}
      </div>
      <p class="pp-text">
        {% if is_arabic %}قد نجمع المعلومات الشخصية التالية:{% else %}We may collect the following personal information:{% endif %}
      </p>
      <ul class="pp-list">
        <li>{% if is_arabic %}الاسم الكامل وبيانات التواصل (البريد الإلكتروني، الهاتف، الواتساب){% else %}Full name and contact details (email, phone, WhatsApp){% endif %}</li>
        <li>{% if is_arabic %}معلومات الأعمال (اسم الصالون، الموقع، نوع الخدمة){% else %}Business information (salon name, location, service type){% endif %}</li>
        <li>{% if is_arabic %}بيانات الاستخدام والتفضيلات عند التصفح{% else %}Usage data and browsing preferences on our website{% endif %}</li>
        <li>{% if is_arabic %}أي معلومات تقدمها طوعاً عبر نماذج الحجز أو التواصل{% else %}Any information you voluntarily submit via booking or contact forms{% endif %}</li>
      </ul>
    </div>

    <!-- 2. How we use it -->
    <div class="pp-section">
      <div class="pp-section-title">
        <span class="pp-section-num">02</span>
        {% if is_arabic %}كيف نستخدم معلوماتك{% else %}How We Use Your Information{% endif %}
      </div>
      <p class="pp-text">
        {% if is_arabic %}نستخدم البيانات التي نجمعها للأغراض التالية:{% else %}We use the data we collect for the following purposes:{% endif %}
      </p>
      <ul class="pp-list">
        <li>{% if is_arabic %}الرد على استفساراتك وطلبات الحجز{% else %}Responding to your enquiries and booking requests{% endif %}</li>
        <li>{% if is_arabic %}تقديم وإدارة خدمات التسويق التعاقدية{% else %}Providing and managing contracted marketing services{% endif %}</li>
        <li>{% if is_arabic %}إرسال تحديثات الخدمة والتقارير الشهرية{% else %}Sending service updates and monthly performance reports{% endif %}</li>
        <li>{% if is_arabic %}تحسين موقعنا وعروضنا بناءً على ملاحظاتك{% else %}Improving our website and offerings based on your feedback{% endif %}</li>
        <li>{% if is_arabic %}الامتثال للالتزامات القانونية والتنظيمية في الإمارات{% else %}Complying with legal and regulatory obligations in the UAE{% endif %}</li>
      </ul>
    </div>

    <!-- 3. Sharing -->
    <div class="pp-section">
      <div class="pp-section-title">
        <span class="pp-section-num">03</span>
        {% if is_arabic %}مشاركة المعلومات{% else %}Sharing of Information{% endif %}
      </div>
      <p class="pp-text">
        {% if is_arabic %}
          لا نبيع معلوماتك الشخصية ولا نتاجر بها. قد نشاركها مع أطراف ثالثة موثوقة تساعدنا في تشغيل موقعنا وخدماتنا — شريطة الالتزام بسرية هذه المعلومات. وقد نفصح عن بياناتك عند الاقتضاء القانوني أو لحماية حقوقنا.
        {% else %}
          We do not sell or trade your personal information. We may share it with trusted third parties who assist in operating our website and services — subject to confidentiality obligations. We may also disclose information when required by law or to protect our rights.
        {% endif %}
      </p>
    </div>

    <!-- 4. Cookies -->
    <div class="pp-section">
      <div class="pp-section-title">
        <span class="pp-section-num">04</span>
        {% if is_arabic %}ملفات تعريف الارتباط (الكوكيز){% else %}Cookies{% endif %}
      </div>
      <p class="pp-text">
        {% if is_arabic %}
          قد يستخدم موقعنا ملفات تعريف الارتباط لتحسين تجربة التصفح. يمكنك ضبط متصفحك لرفض الكوكيز، غير أن ذلك قد يؤثر على بعض وظائف الموقع.
        {% else %}
          Our website may use cookies to enhance your browsing experience. You can set your browser to refuse cookies, though this may affect some website functionality.
        {% endif %}
      </p>
    </div>

    <!-- 5. Data security -->
    <div class="pp-section">
      <div class="pp-section-title">
        <span class="pp-section-num">05</span>
        {% if is_arabic %}أمان البيانات{% else %}Data Security{% endif %}
      </div>
      <p class="pp-text">
        {% if is_arabic %}
          نطبّق ممارسات أمنية معيارية في الصناعة لحماية بياناتك من الوصول غير المصرح به أو الإفصاح أو التعديل أو الإتلاف. بيد أنه لا توجد طريقة نقل عبر الإنترنت آمنة بنسبة 100%.
        {% else %}
          We implement industry-standard security practices to protect your data from unauthorized access, disclosure, alteration, or destruction. However, no method of internet transmission is 100% secure.
        {% endif %}
      </p>
    </div>

    <!-- 6. Your rights -->
    <div class="pp-section">
      <div class="pp-section-title">
        <span class="pp-section-num">06</span>
        {% if is_arabic %}حقوقك{% else %}Your Rights{% endif %}
      </div>
      <p class="pp-text">
        {% if is_arabic %}لديك الحق في:{% else %}You have the right to:{% endif %}
      </p>
      <ul class="pp-list">
        <li>{% if is_arabic %}الوصول إلى بياناتك الشخصية التي نحتفظ بها{% else %}Access the personal data we hold about you{% endif %}</li>
        <li>{% if is_arabic %}طلب تصحيح أو حذف بياناتك{% else %}Request correction or deletion of your data{% endif %}</li>
        <li>{% if is_arabic %}الاعتراض على معالجة بياناتك أو تقييدها{% else %}Object to or restrict the processing of your data{% endif %}</li>
        <li>{% if is_arabic %}سحب موافقتك في أي وقت{% else %}Withdraw your consent at any time{% endif %}</li>
      </ul>
      <p class="pp-text">
        {% if is_arabic %}لممارسة أي من هذه الحقوق، يرجى التواصل معنا عبر البيانات الواردة أدناه.{% else %}To exercise any of these rights, please contact us using the details below.{% endif %}
      </p>
    </div>

    <!-- 7. Third-party links -->
    <div class="pp-section">
      <div class="pp-section-title">
        <span class="pp-section-num">07</span>
        {% if is_arabic %}روابط الطرف الثالث{% else %}Third-Party Links{% endif %}
      </div>
      <p class="pp-text">
        {% if is_arabic %}
          قد يحتوي موقعنا على روابط لمواقع خارجية. لا نتحمل مسؤولية ممارسات الخصوصية الخاصة بهذه المواقع ونشجعك على مراجعة سياسات الخصوصية الخاصة بها.
        {% else %}
          Our website may contain links to external sites. We are not responsible for the privacy practices of those sites and encourage you to review their privacy policies.
        {% endif %}
      </p>
    </div>

    <!-- 8. Changes -->
    <div class="pp-section">
      <div class="pp-section-title">
        <span class="pp-section-num">08</span>
        {% if is_arabic %}تغييرات على هذه السياسة{% else %}Changes to This Policy{% endif %}
      </div>
      <p class="pp-text">
        {% if is_arabic %}
          نحتفظ بالحق في تحديث سياسة الخصوصية هذه في أي وقت. سنُعلمك بأي تغييرات جوهرية عن طريق نشر السياسة المُحدَّثة على هذه الصفحة مع تحديث تاريخ "آخر تحديث".
        {% else %}
          We reserve the right to update this privacy policy at any time. We will notify you of material changes by posting the updated policy on this page with a revised "Last updated" date.
        {% endif %}
      </p>
    </div>

    <!-- 9. Cancellations & Refunds -->
    <div class="pp-section">
      <div class="pp-section-title">
        <span class="pp-section-num">09</span>
        {% if is_arabic %}الإلغاء، الحجوزات والاسترداد{% else %}Cancellations, Bookings & Refunds{% endif %}
      </div>
      <p class="pp-text">
        {% if is_arabic %}
          سيتم معالجة وإرجاع أي مبالغ مستردة ناتجة عن إلغاء الحجز، الشكاوى، أو أي مطالبات أخرى بالاسترداد خلال 10 أيام عمل.
        {% else %}
          Any refunds requested due to booking cancellations, complaints, or any other service disputes will be processed and credited within 10 working days.
        {% endif %}
      </p>
    </div>

    <!-- 10. Contact -->
    <div class="pp-section">
      <div class="pp-section-title">
        <span class="pp-section-num">10</span>
        {% if is_arabic %}تواصل معنا{% else %}Contact Us{% endif %}
      </div>
      <p class="pp-text">
        {% if is_arabic %}
          إذا كانت لديك أسئلة حول سياسة الخصوصية هذه، يُرجى التواصل معنا:
        {% else %}
          If you have any questions about this Privacy Policy, please reach out:
        {% endif %}
      </p>
      <div class="pp-contact-grid">
        <div class="pp-contact-card">
          <div class="pp-contact-label">{% if is_arabic %}الشركة{% else %}Company{% endif %}</div>
          <div class="pp-contact-val">{% if is_arabic %}شركة دونا بيلا لإدارة التسويق ذ.م.م{% else %}Donna Bella Marketing Management L.L.C{% endif %}</div>
        </div>
        <div class="pp-contact-card">
          <div class="pp-contact-label">{% if is_arabic %}البريد الإلكتروني{% else %}Email{% endif %}</div>
          <div class="pp-contact-val"><a href="mailto:donnabella.home.services@gmail.com">donnabella.home.services@gmail.com</a></div>
        </div>
        <div class="pp-contact-card">
          <div class="pp-contact-label">{% if is_arabic %}الموقع{% else %}Location{% endif %}</div>
          <div class="pp-contact-val">
            <a href="https://maps.app.goo.gl/o6YjCpTT2aJHJTZS9" target="_blank" rel="noopener">
              {% if is_arabic %}مكتب 1102، برشا 1، دبي، الإمارات{% else %}Office 1102, Barsha 1, Dubai, UAE{% endif %}
            </a>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Privacy Policy",
  "presets": [{ "name": "Privacy Policy" }]
}
{% endschema %}
